# Slack tokens (obtain from api.slack.com/apps after creating the app)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...

# Channel where attendance events get posted (e.g. C012345)
ATTENDANCE_CHANNEL_ID=

# Comma-separated Slack user IDs that receive late alerts
MANAGER_SLACK_IDS=U01ABC123

# Late threshold in minutes (alert manager + agent if no clock-in by this time)
LATE_THRESHOLD_MIN=15

# DM reminder N minutes before shift start
REMINDER_LEAD_MIN=5

# SQLite database path
DB_PATH=./data/bot.db

# Cycle anchor (used for display labels A/B/C/D — date model is absolute)
ANCHOR_DATE=2026-04-13
ANCHOR_CYCLE=A

# IANA timezone shown alongside UTC in /horario-status, /horario-hoy headers
DISPLAY_TIMEZONE=America/Bogota

# Set to 'true' to skip cron jobs (reminders + late alerts). Useful for testing
# without spamming agents. Leave unset/false in production.
CRON_DISABLED=false

# Log level
LOG_LEVEL=info
