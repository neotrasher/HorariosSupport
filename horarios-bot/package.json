{
  "name": "horarios-bot",
  "version": "0.1.0",
  "description": "Slack bot para clock in/out del equipo de support",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "ts-node src/db.ts"
  },
  "dependencies": {
    "@slack/bolt": "^3.21.4",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
