<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<main class="max-w-2xl mx-auto px-4 py-6">
  <a href="/solicitudes" class="text-xs text-gray-500 hover:underline">&larr; Volver a solicitudes</a>
  <h2 class="text-xl font-semibold text-gray-900 mt-1 mb-6">Nueva solicitud</h2>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg p-3 mb-4"><%= error %></div>
  <% } %>

  <form method="post" action="/solicitudes/nueva" class="bg-white rounded-lg border border-gray-200 p-6 space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Tipo</label>
      <select name="type" class="block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
        <option value="permiso" <%= form.type === 'permiso' ? 'selected' : '' %>>📝 Permiso</option>
        <option value="vacaciones" <%= form.type === 'vacaciones' ? 'selected' : '' %>>🏖️ Vacaciones</option>
      </select>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Fecha inicio</label>
        <input type="date" name="start_date" required value="<%= form.start_date %>"
               class="block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Fecha fin</label>
        <input type="date" name="end_date" required value="<%= form.end_date %>"
               class="block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
        <p class="text-[11px] text-gray-400 mt-1">Igual al inicio si es un solo dia.</p>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Motivo <span class="text-gray-400 font-normal">(opcional)</span></label>
      <textarea name="reason" rows="3"
                class="block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"
                placeholder="Ej: cita medica, viaje familiar..."><%= form.reason %></textarea>
    </div>

    <div class="flex justify-end gap-2 pt-2">
      <a href="/solicitudes" class="px-4 py-2 text-sm text-gray-600 hover:bg-gray-50 rounded-lg">Cancelar</a>
      <button type="submit" class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm hover:bg-gray-800">
        Enviar solicitud
      </button>
    </div>
  </form>

  <p class="text-xs text-gray-400 mt-4">Al enviar, los managers (<%= user.role === 'manager' ? 'incluyendote' : 'Diego y Cindy' %>) reciben un DM en Slack para aprobar o rechazar. Te avisamos cuando se resuelva.</p>
</main>
<%- include('partials/foot') %>
