      Iniciar sesion con Slack
    </a>
    <% if (typeof error !== 'undefined' && error) { %>
      <p class="text-red-500 text-sm mt-4">Error al iniciar sesion (<%= error %>). Intenta de nuevo.</p>
    <% } %>
  </div>
</div>
