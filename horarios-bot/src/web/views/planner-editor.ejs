function buildAgentDayCell(emp, day) {
  const cell = document.createElement('div');
  cell.className = 'agent-cell';
  cell.addEventListener('click', () => openAgentDayModal(emp.id, day));

  // ¿Está libre ese día en este ciclo?
  const isOff = (daysOff[emp.id]?.[currentCycle] || []).includes(day);

  // ¿Qué turnos tiene asignados? (busca en todos los depts)
  const assigned = []; // {deptId, sh, crossDept}
  for (const dept of DEPTS) {
    for (const sh of dept.shifts) {
      const cellData = schedule[currentCycle][dept.id][day][sh.id];
      if (cellData.emps.includes(emp.id)) {
        assigned.push({ deptId: dept.id, sh, crossDept: dept.id !== emp.dept });
      }
    }
  }

  // Conflicto: tiene turno asignado Y está marcado como libre
  const conflict = isOff && assigned.length > 0;
  if (conflict) {
    cell.classList.add('conflict');
    const badge = document.createElement('div');
    badge.className = 'conflict-badge';
    badge.textContent = '⚠';
    badge.title = 'Conflicto: agente tiene turno y día libre el mismo día';
    cell.appendChild(badge);
  }

  // Render shifts
  for (const a of assigned) {
    const pill = document.createElement('div');
    pill.className = 'shift-pill' + (a.crossDept ? ' cross' : '');
    pill.style.background = a.sh.color;
    pill.title = `${a.sh.label}${a.crossDept ? ' (cobertura ' + a.deptId + ')' : ''}`;
    pill.innerHTML = `<span>${a.crossDept ? a.deptId + '·' : ''}${a.sh.id} · ${a.sh.label}</span>
      <span class="sp-time">${a.sh.time}</span>`;
    cell.appendChild(pill);
  }

  if (isOff) {
    const off = document.createElement('div');
    off.className = 'off-pill';
    off.textContent = '🌴 libre';
    cell.appendChild(off);
  }

  if (!isOff && assigned.length === 0) {
    cell.classList.add('empty');
    const hint = document.createElement('div');
    hint.className = 'empty-hint';
    hint.textContent = 'sin asignar';
    cell.appendChild(hint);
  }

  return cell;
}

// ── Modal agente×día ────────────────────────────────────────────────────────
function openAgentDayModal(empId, day) {
  const emp = EMPLOYEES.find(e => e.id === empId);
  if (!emp) return;
  adState = { empId, day, sel: new Set(), off: false };
  // Pre-seleccionar turnos actuales
  for (const dept of DEPTS) {
    for (const sh of dept.shifts) {
      if (schedule[currentCycle][dept.id][day][sh.id].emps.includes(empId)) {
        adState.sel.add(dept.id + '|' + sh.id);
      }
    }
  }
  adState.off = (daysOff[empId]?.[currentCycle] || []).includes(day);

  document.getElementById('adTitle').textContent = `${emp.name} — ${DAY_FULL[day]}`;
  document.getElementById('adSub').textContent = `Sem ${currentCycle} · click para asignar/quitar turno`;
  document.getElementById('adEmpDot').style.background = emp.color;
  renderAgentDayBody();
  document.getElementById('ovAgentDay').classList.add('show');
}

function renderAgentDayBody() {
  const body = document.getElementById('adBody');
  body.innerHTML = '';

  for (const dept of DEPTS) {
    const sec = document.createElement('div');
    sec.className = 'qs-section';
    const lbl = document.createElement('div');
    lbl.className = 'qs-lbl';
    lbl.textContent = dept.label;
    sec.appendChild(lbl);

    const pills = document.createElement('div');
    pills.className = 'qs-pills';
    for (const sh of dept.shifts) {
      const key = dept.id + '|' + sh.id;
      const isSel = adState.sel.has(key);
      const pill = document.createElement('button');
      pill.type = 'button';
      pill.className = 'qs-pill' + (isSel ? ' sel' : '');
      pill.style.borderColor = sh.color;
      if (isSel) { pill.style.background = sh.color; pill.style.color = '#fff'; }
      pill.innerHTML = `<span class="qs-pill-dept">${dept.id}</span>
        <span class="qs-pill-sh">${sh.id} · ${sh.label}</span>
        <span class="qs-pill-time">${sh.time}</span>`;
      pill.addEventListener('click', () => {
        if (adState.sel.has(key)) adState.sel.delete(key);
        else adState.sel.add(key);
        renderAgentDayBody();
      });
      pills.appendChild(pill);
    }
    sec.appendChild(pills);
    body.appendChild(sec);
  }

  // Día libre toggle
  const offSec = document.createElement('div');
  offSec.className = 'qs-section';
  const offCount = countOffDaysAllCycles(adState.empId);
  offSec.innerHTML = `<div class="qs-lbl">Día libre</div>
    <label class="qs-radio" style="cursor:pointer">
      <input type="checkbox" id="adOffChk" ${adState.off ? 'checked' : ''}>
      Marcar ${DAY_FULL[adState.day]} como libre en Sem ${currentCycle}
    </label>
    <div style="font-size:10px;color:var(--muted);margin-top:4px">
      Total días libres del agente (todos los ciclos): ${offCount}/8
    </div>`;
  offSec.querySelector('#adOffChk').addEventListener('change', e => {
    adState.off = e.target.checked;
  });
  body.appendChild(offSec);

  // Warning si hay conflicto en la selección actual
  if (adState.off && adState.sel.size > 0) {
    const warn = document.createElement('div');
    warn.style.cssText = 'background:#fff5f5;border:1px solid #fc8181;border-radius:6px;padding:8px 10px;font-size:11px;color:#c53030;margin-top:4px';
    warn.innerHTML = '⚠ Vas a dejar al agente con turno y día libre el mismo día. Quita uno de los dos antes de aplicar.';
    body.appendChild(warn);
  }
}

function countOffDaysAllCycles(empId) {
  if (!daysOff[empId]) return 0;
  return CYCLES.reduce((s, cy) => s + (daysOff[empId][cy] || []).length, 0);
}

function closeAgentDayModal() {
  document.getElementById('ovAgentDay').classList.remove('show');
  adState = null;
}

function saveAgentDayModal() {
  if (!adState) return;
  // Bloquear si quedan conflictos
  if (adState.off && adState.sel.size > 0) {
    showToast('⚠ Conflicto: quita el día libre o los turnos antes de aplicar');
    return;
  }
  const { empId, day, sel, off } = adState;

  // Actualizar shifts: para cada dept/sh, agregar o quitar al agente según sel
  for (const dept of DEPTS) {
    for (const sh of dept.shifts) {
      const key = dept.id + '|' + sh.id;
      const cellData = schedule[currentCycle][dept.id][day][sh.id];
      const wantsAssigned = sel.has(key);
      const isAssigned = cellData.emps.includes(empId);
      if (wantsAssigned && !isAssigned) cellData.emps.push(empId);
      else if (!wantsAssigned && isAssigned) {
        cellData.emps = cellData.emps.filter(id => id !== empId);
      }
    }
  }

  // Actualizar daysOff
  if (!daysOff[empId]) daysOff[empId] = {};
  if (!daysOff[empId][currentCycle]) daysOff[empId][currentCycle] = [];
  const arr = daysOff[empId][currentCycle];
  const i = arr.indexOf(day);
  if (off && i < 0) arr.push(day);
  else if (!off && i >= 0) arr.splice(i, 1);

  closeAgentDayModal();
  render();
  autosave();
  showToast('✓ Día actualizado');
}

function switchViewMode(v) {
  if (v !== 'by-shift' && v !== 'by-agent') return;
  viewMode = v;
  document.querySelectorAll('.vtbtn').forEach(b => b.classList.toggle('active', b.dataset.view === v));
  render();
}

function buildDeptCard(dept) {
  const card = document.createElement('div');
  card.className = 'dept-card';

  // Header
  const hdr = document.createElement('div');
  hdr.className = 'dept-hdr';
  hdr.innerHTML = `<span class="dept-badge badge-${dept.id}">${dept.id}</span>
    <span class="dept-title">${dept.label}</span>`;
  card.appendChild(hdr);

  // Grid: COLUMNS = days, ROWS = shifts
  const wrap = document.createElement('div');
  wrap.className = 'grid-wrap';
  const grid = document.createElement('div');
  grid.className = 'sgrid';
  // 88px for shift label + equal width for each day
  grid.style.gridTemplateColumns = `88px repeat(${DAYS.length}, 1fr)`;

  // ── Row 0: column headers (corner + day names) ──
  const corner = document.createElement('div');
  corner.className = 'gh';
  corner.style.borderLeft = '3px solid transparent';
  grid.appendChild(corner);

  for (const day of DAYS) {
    const h = document.createElement('div');
    h.className = 'gh';
    h.title = DAY_FULL[day];
    h.innerHTML = `<span style="font-size:14px;font-weight:800">${day}</span>
      <br><span style="font-size:9px;color:#a0aec0;font-weight:500">${DAY_FULL[day].slice(0,3)}</span>`;
    grid.appendChild(h);
  }

  // ── Rows 1+: one row per shift ──
  for (let si = 0; si < dept.shifts.length; si++) {
    const sh = dept.shifts[si];
    const isLastRow = si === dept.shifts.length - 1;

    // Shift label cell (left column)
    const shLbl = document.createElement('div');
    shLbl.className = 'gh' + (sh.id === 'E' ? ' gh-E' : '');
    shLbl.style.cssText = `text-align:left;padding:7px 10px;
      border-left:3px solid ${sh.color};
      ${isLastRow ? 'border-bottom:none;' : ''}`;
    shLbl.innerHTML = `<span style="font-size:13px;font-weight:800;color:${sh.color}">${sh.id}</span>
      <span style="font-size:9px;color:#a0aec0;margin-left:4px">${sh.time}</span>
      <br><span style="font-size:9px;color:#718096;font-weight:500">${sh.label}</span>`;
    grid.appendChild(shLbl);

    // One cell per day
    for (let di = 0; di < DAYS.length; di++) {
      const day = DAYS[di];
      const cell = buildCell(dept.id, day, sh.id);
      if (di === DAYS.length - 1) cell.style.borderRight = 'none';
      if (isLastRow) cell.style.borderBottom = 'none';
      grid.appendChild(cell);
    }
  }

  wrap.appendChild(grid);
  card.appendChild(wrap);
  return card;
}

function buildCell(deptId, day, shiftId) {
  const cell = document.createElement('div');
  cell.className = 'gcell' + (shiftId==='E' ? ' gcell-E' : '');
  const data = schedule[currentCycle][deptId][day][shiftId];

  // Resolve shift color (chip color = shift type, not agent)
  const dept = DEPTS.find(d => d.id === deptId);
  const sh = dept ? dept.shifts.find(s => s.id === shiftId) : null;
  const shiftColor = sh ? sh.color : '#64748b';

  for (const eid of data.emps) {
    const emp = EMPLOYEES.find(e=>e.id===eid);
    if (!emp) continue;
    const chip = document.createElement('div');
    const onDayOff = isOffDay(emp.id, day);
    const isDimmed = filteredEmps.size > 0 && !filteredEmps.has(emp.id);
    chip.className = 'chip' + (onDayOff ? ' chip-warn' : '') + (isDimmed ? ' dimmed' : '');
    chip.style.background = shiftColor;
    chip.title = onDayOff ? `⚠ ${emp.name} tiene libre este día` : emp.name;
    // Show dept tag if cross-dept assignment
    const deptTag = emp.dept !== deptId && emp.dept !== 'S'
      ? `<span style="font-size:9px;background:rgba(0,0,0,.25);padding:0 3px;border-radius:3px;margin-right:2px">${emp.dept}</span>`
      : '';
    chip.innerHTML = `${deptTag}<span class="chip-name">${emp.name.split(' ')[0]}</span>
      <span class="chip-x" data-dept="${deptId}" data-day="${day}" data-shift="${shiftId}" data-emp="${eid}">×</span>`;
    chip.querySelector('.chip-x').addEventListener('click', e=>{
      e.stopPropagation();
      removeEmp(deptId, day, shiftId, parseInt(e.target.dataset.emp));
    });
    cell.appendChild(chip);
  }

  if (data.note) {
    const nt = document.createElement('div');
    nt.className = 'chip-note';
    nt.textContent = data.note;
    cell.appendChild(nt);
  }

  const plus = document.createElement('div');
  plus.className = 'add-indicator';
  plus.textContent = '+';
  cell.appendChild(plus);

  cell.addEventListener('click', ()=>openModal(deptId, day, shiftId));
  return cell;
}

function removeEmp(deptId, day, shiftId, empId) {
  const arr = schedule[currentCycle][deptId][day][shiftId].emps;
  const i = arr.indexOf(empId);
  if (i >= 0) { arr.splice(i,1); render(); autosave(); }
}

// ── EMPLOYEE MANAGEMENT ──────────────────────────────────────────────────────
const NEW_EMP_COLORS = ['#6366f1','#ec4899','#f97316','#10b981','#0284c7','#7c3aed','#ef4444','#d97706','#0891b2','#65a30d'];

function openEmpMgmt() {
  renderEmpMgmt();
  document.getElementById('ovEmpMgmt').classList.add('show');
}

function renderEmpMgmt() {
  const body = document.getElementById('empMgmtBody');
  body.innerHTML = '';
  for (const deptId of ['L2','L1']) {
    const group = document.createElement('div');
    group.className = 'mgmt-group';
    const title = document.createElement('div');
    title.className = 'mgmt-group-title';
    title.textContent = `Equipo ${deptId}`;
    group.appendChild(title);
    for (const emp of EMPLOYEES.filter(e => e.dept === deptId))
      group.appendChild(buildMgmtRow(emp));
    const addBtn = document.createElement('button');
    addBtn.className = 'mgmt-add';
    addBtn.innerHTML = `<span style="font-size:16px;line-height:1">+</span> Agregar agente ${deptId}`;
    addBtn.addEventListener('click', () => addEmployee(deptId));
    group.appendChild(addBtn);
    body.appendChild(group);
  }
}

function buildMgmtRow(emp) {
  const row = document.createElement('div');
  row.className = 'mgmt-emp-row';
  // Color picker
  const colorBtn = document.createElement('div');
  colorBtn.className = 'mgmt-color-btn';
  colorBtn.style.background = emp.color;
  colorBtn.title = 'Cambiar color';
  const colorInput = document.createElement('input');
  colorInput.type = 'color';
  colorInput.className = 'mgmt-color-input';
  colorInput.value = emp.color;
  colorInput.addEventListener('input', e => {
    emp.color = e.target.value;
    colorBtn.style.background = e.target.value;
    autosave();
  });
  colorInput.addEventListener('change', () => { render(); });
  colorBtn.appendChild(colorInput);
  row.appendChild(colorBtn);
  // Name input
  const nameInput = document.createElement('input');
  nameInput.className = 'mgmt-name-input';
  nameInput.value = emp.name;
  nameInput.placeholder = 'Nombre';
  nameInput.addEventListener('change', e => {
    const v = e.target.value.trim();
    if (v) { emp.name = v; autosave(); renderSidebar(); }
    else e.target.value = emp.name;
  });
  row.appendChild(nameInput);
  // ID label
  const idLbl = document.createElement('span');
  idLbl.className = 'mgmt-id';
  idLbl.textContent = `#${emp.id}`;
  row.appendChild(idLbl);
  // Delete button
  const delBtn = document.createElement('button');
  delBtn.className = 'mgmt-del';
  delBtn.title = `Eliminar ${emp.name}`;
  delBtn.textContent = '×';
  delBtn.addEventListener('click', () => deleteEmployee(emp.id));
  row.appendChild(delBtn);
  return row;
}

function addEmployee(dept) {
  const newId = Math.max(...EMPLOYEES.map(e => e.id), 17) + 1;
  const color = NEW_EMP_COLORS[EMPLOYEES.length % NEW_EMP_COLORS.length];
  EMPLOYEES.push({ id: newId, name: `Agente ${newId}`, dept, color });
  daysOff[newId] = {};
  for (const cy of CYCLES) daysOff[newId][cy] = [];
  renderEmpMgmt();
  autosave();
}

function deleteEmployee(empId) {
  const emp = EMPLOYEES.find(e => e.id === empId);
  if (!emp) return;
  if (!confirm(`¿Eliminar a ${emp.name}?\nSus turnos asignados también se quitarán.`)) return;
  EMPLOYEES.splice(EMPLOYEES.indexOf(emp), 1);
  for (const cy of CYCLES)
    for (const dept of DEPTS)
      for (const day of DAYS)
        for (const sh of dept.shifts) {
          const cell = schedule[cy][dept.id][day][sh.id];
          const i = cell.emps.indexOf(empId);
          if (i >= 0) cell.emps.splice(i, 1);
        }
  delete daysOff[empId];
  renderEmpMgmt();
  render();
  autosave();
}

// ── DAYS OFF ─────────────────────────────────────────────────────────────────
let daysOff = {};

function initDaysOff() {
  for (const emp of EMPLOYEES) {
    daysOff[emp.id] = {};
    for (const cy of CYCLES) daysOff[emp.id][cy] = [];
  }
}

function isOffDay(empId, day) {
  return (daysOff[empId]?.[currentCycle] || []).includes(day);
}

function openDaysOffModal(empId) {
  const emp = EMPLOYEES.find(e => e.id === empId);
  if (!emp) return;
  document.getElementById('doEmpName').textContent = emp.name;
  document.getElementById('doEmpDot').style.background = emp.color;
  renderDOBody(empId);
  document.getElementById('ovDO').classList.add('show');
}

function renderDOBody(empId) {
  const body = document.getElementById('doBdy');
  body.innerHTML = '';
  const grid = document.createElement('div');
  grid.className = 'do-grid';
  for (const cy of CYCLES) {
    const offDays = daysOff[empId][cy] || [];
    const row = document.createElement('div');
    row.className = 'do-row';
    const lbl = document.createElement('div');
    lbl.className = 'do-cy-lbl';
    lbl.textContent = `Sem ${cy}`;
    row.appendChild(lbl);
    const daysDiv = document.createElement('div');
    daysDiv.className = 'do-days';
    for (const day of DAYS) {
      const btn = document.createElement('div');
      btn.className = 'do-daybtn' + (offDays.includes(day) ? ' off' : '');
      btn.textContent = day;
      btn.title = DAY_FULL[day];
      btn.addEventListener('click', () => toggleDayOff(empId, cy, day));
      daysDiv.appendChild(btn);
    }
    row.appendChild(daysDiv);
    const cnt = document.createElement('span');
    cnt.className = 'do-cnt';
    cnt.textContent = offDays.length > 0 ? `${offDays.length}` : '—';
    row.appendChild(cnt);
    grid.appendChild(row);
  }
  // Total row
  const total = totalDaysOff(empId);
  const totalRow = document.createElement('div');
  totalRow.style.cssText = 'display:flex;justify-content:flex-end;padding-top:6px;border-top:1px solid var(--border);margin-top:4px';
  totalRow.innerHTML = `<span style="font-size:12px;font-weight:700;color:${total>8?'#e53e3e':total===8?'#276749':'var(--muted)'}">
    Total: ${total}/8 días libres</span>`;
  body.appendChild(grid);
  body.appendChild(totalRow);
}

function totalDaysOff(empId) {
  return CYCLES.reduce((sum, cy) => sum + (daysOff[empId][cy]||[]).length, 0);
}

function toggleDayOff(empId, cycle, day) {
  const arr = daysOff[empId][cycle];
  const i = arr.indexOf(day);
  if (i >= 0) {
    arr.splice(i, 1);
  } else {
    if (totalDaysOff(empId) >= 8) { showToast('Máximo 8 días libres en total'); return; }
    arr.push(day);
  }
  renderDOBody(empId);
  renderSchedule();
  autosave();
}

// ── SIDEBAR ──────────────────────────────────────────────────────────────────
function renderSidebar() {
  const body = document.getElementById('sbBody');
  body.innerHTML = '';

  // Filter banner (visible only when filter is active)
  if (filteredEmps.size > 0) {
    const bar = document.createElement('div');
    bar.className = 'filter-bar';
    const names = EMPLOYEES.filter(e => filteredEmps.has(e.id)).map(e => e.name).join(', ');
    bar.innerHTML = `<span>🔍 Filtrando: <strong>${escHtml(names)}</strong></span>
      <button class="filter-bar-clear" type="button">Limpiar</button>`;
    bar.querySelector('.filter-bar-clear').addEventListener('click', clearEmpFilter);
    body.appendChild(bar);
  }

  const stats = calcStats();
  const groups = [{id:'L2',label:'Equipo L2'},{id:'L1',label:'Equipo L1'}];

  for (const g of groups) {
    const title = document.createElement('div');
    title.className = 'sb-dept-title';
    title.textContent = g.label;
    body.appendChild(title);

    for (const emp of EMPLOYEES.filter(e=>e.dept===g.id)) {
      const st = stats[emp.id]||{M:0,T:0,N:0,E:0};
      const row = document.createElement('div');
      row.className = 'emp-row' + (filteredEmps.has(emp.id) ? ' filter-on' : '');
      row.title = `${emp.name} — ${emp.dept} · click para filtrar`;
      const shiftsToShow = ['M','T','N','E'];
      const statHtml = shiftsToShow.map(s=>`<span class="st">${s}${st[s]||0}</span>`).join('');
      // Total turnos del ciclo completo (todas las semanas)
      const totalAll = totalShiftsAllCycles(emp.id);
      const expected = expectedShiftsTotal();
      let totalColor = 'background:#edf2f7;color:#4a5568';
      let totalTitle = `Total en el ciclo: ${totalAll} de ${expected} esperados`;
      if (totalAll > expected) {
        totalColor = 'background:#fc8181;color:#742a2a';
        totalTitle = `⚠ Excede: ${totalAll}/${expected} turnos (sobreasignado)`;
      } else if (totalAll === expected) {
        totalColor = 'background:#9ae6b4;color:#22543d';
        totalTitle = `✓ Exacto: ${totalAll}/${expected}`;
      } else if (totalAll === 0) {
        totalColor = 'background:#fed7aa;color:#7b341e';
        totalTitle = `Sin turnos asignados`;
      }
      const totalHtml = `<span class="st" style="${totalColor};font-weight:800" title="${totalTitle}">Σ${totalAll}/${expected}</span>`;
      const doTags = CYCLES.map(cy => {
        const d = (daysOff[emp.id]?.[cy] || []);
        return d.length
          ? `<span class="do-tag">${cy}:${d.join(',')}</span>`
          : `<span class="do-tag-empty">${cy}:—</span>`;
      }).join('');
      row.innerHTML = `
        <div class="emp-row-top">
          <div class="emp-dot" style="background:${emp.color}"></div>
          <div class="emp-row-name">${emp.name}</div>
          <button class="emp-do-btn" data-emp="${emp.id}" title="Días libres del ciclo">📅</button>
          <button class="qs-add-btn" data-emp="${emp.id}" title="Agregar turno multi-día">+</button>
        </div>
        <div class="emp-row-bot">
          <div class="emp-do-row">${doTags}</div>
          <div class="emp-stats">${statHtml}${totalHtml}</div>
        </div>`;
      row.querySelector('.emp-do-btn').addEventListener('click', e => {
        e.stopPropagation();
        openDaysOffModal(emp.id);
      });
      row.querySelector('.qs-add-btn').addEventListener('click', e => {
        e.stopPropagation();
        openQuickShiftModal(emp.id);
      });
      row.addEventListener('click', () => toggleEmpFilter(emp.id));
      body.appendChild(row);
    }
  }
}

function calcStats() {
  const s = {};
  for (const emp of EMPLOYEES) s[emp.id]={M:0,T:0,N:0,E:0};
  const cy = schedule[currentCycle];
  for (const dept of DEPTS)
    for (const day of DAYS)
      for (const sh of dept.shifts)
        for (const eid of cy[dept.id][day][sh.id].emps)
          if (s[eid]) s[eid][sh.id]=(s[eid][sh.id]||0)+1;
  return s;
}

// Total de turnos del agente sumando TODOS los ciclos activos (no solo el actual)
function totalShiftsAllCycles(empId) {
  let n = 0;
  for (const cy of CYCLES) {
    for (const dept of DEPTS) {
      for (const day of DAYS) {
        for (const sh of dept.shifts) {
          if (schedule[cy][dept.id][day][sh.id].emps.includes(empId)) n++;
        }
      }
    }
  }
  return n;
}

// Total esperado: 5 turnos por semana × N ciclos activos (3 ciclos→15, 4 ciclos→20)
function expectedShiftsTotal() {
  return CYCLES.length * 5;
}

// ── QUICK-SHIFT MODAL (multi-day) ────────────────────────────────────────────
let qsState = { empId: null, shift: null, days: new Set(), allCycles: false, note: '' };

function openQuickShiftModal(empId) {
  const emp = EMPLOYEES.find(e => e.id === empId);
  if (!emp) return;
  qsState = { empId, shift: null, days: new Set(), allCycles: false, note: '' };
  document.getElementById('qsEmpName').textContent = emp.name;
  document.getElementById('qsEmpDot').style.background = emp.color;
  renderQSBody();
  document.getElementById('ovQS').classList.add('show');
}

function renderQSBody() {
  const body = document.getElementById('qsBdy');
  const emp = EMPLOYEES.find(e => e.id === qsState.empId);
  if (!emp) return;
  body.innerHTML = '';

  // Section: Turno (8 pills, 4 L1 + 4 L2)
  const sTurno = document.createElement('div');
  sTurno.className = 'qs-section';
  const lblTurno = document.createElement('div');
  lblTurno.className = 'qs-lbl';
  lblTurno.textContent = 'Turno';
  sTurno.appendChild(lblTurno);
  const pillsBox = document.createElement('div');
  pillsBox.className = 'qs-pills';
  for (const dept of DEPTS) {
    for (const sh of dept.shifts) {
      const pill = document.createElement('button');
      pill.className = 'qs-pill';
      pill.style.borderColor = sh.color;
      const isSel = qsState.shift && qsState.shift.deptId === dept.id && qsState.shift.shiftId === sh.id;
      if (isSel) {
        pill.classList.add('sel');
        pill.style.background = sh.color;
        pill.style.color = '#fff';
      }
      pill.innerHTML = `<span class="qs-pill-dept">${dept.id}</span>
        <span class="qs-pill-sh">${sh.id} · ${sh.label}</span>
        <span class="qs-pill-time">${sh.time}</span>`;
      pill.addEventListener('click', () => {
        qsState.shift = { deptId: dept.id, shiftId: sh.id };
        renderQSBody();
      });
      pillsBox.appendChild(pill);
    }
  }
  sTurno.appendChild(pillsBox);
  body.appendChild(sTurno);

  // Section: Días
  const sDays = document.createElement('div');
  sDays.className = 'qs-section';
  const lblDays = document.createElement('div');
  lblDays.className = 'qs-lbl';
  lblDays.textContent = qsState.allCycles ? 'Aplicar a días (skipea descansos por ciclo)' : `Aplicar a días · Sem ${currentCycle}`;
  sDays.appendChild(lblDays);
  const daysBox = document.createElement('div');
  daysBox.className = 'qs-days';
  // Disable a day button only if it's a rest day in CURRENT cycle (and we're applying single-cycle).
  // For all-cycles mode, rest days per cycle are skipped at apply time, so leave enabled.
  const restCurrent = qsState.allCycles ? null : (daysOff[emp.id]?.[currentCycle] || []);
  for (const day of DAYS) {
    const btn = document.createElement('button');
    btn.className = 'qs-daybtn' + (qsState.days.has(day) ? ' sel' : '');
    btn.textContent = day;
    btn.title = DAY_FULL[day];
    if (restCurrent && restCurrent.includes(day)) {
      btn.classList.add('disabled');
      btn.title = `${DAY_FULL[day]} · día libre del ciclo ${currentCycle}`;
    }
    btn.addEventListener('click', () => {
      if (btn.classList.contains('disabled')) return;
      if (qsState.days.has(day)) qsState.days.delete(day);
      else qsState.days.add(day);
      renderQSBody();
    });
    daysBox.appendChild(btn);
  }
  sDays.appendChild(daysBox);
  body.appendChild(sDays);

  // Section: Ciclos
  const sCycles = document.createElement('div');
  sCycles.className = 'qs-section';
  sCycles.innerHTML = `
    <div class="qs-lbl">Ciclos</div>
    <div class="qs-cyc-row">
      <label class="qs-radio"><input type="radio" name="qsCyc" value="current" ${!qsState.allCycles ? 'checked' : ''}> Solo Sem ${currentCycle}</label>
      <label class="qs-radio"><input type="radio" name="qsCyc" value="all" ${qsState.allCycles ? 'checked' : ''}> Todos los ciclos (A+B+C+D)</label>
    </div>`;
  sCycles.querySelectorAll('input[name="qsCyc"]').forEach(input => {
    input.addEventListener('change', e => {
      qsState.allCycles = e.target.value === 'all';
      renderQSBody();
    });
  });
  body.appendChild(sCycles);

  // Section: Nota
  const sNote = document.createElement('div');
  sNote.className = 'qs-section';
  sNote.innerHTML = `<div class="qs-lbl">Nota (opcional)</div>
    <input type="text" class="qs-note-inp" placeholder="ej: cobertura" value="${escHtml(qsState.note)}">`;
  sNote.querySelector('input').addEventListener('input', e => { qsState.note = e.target.value; });
  body.appendChild(sNote);

  // Update apply button label/disabled
  const counter = countQSCells();
  const btn = document.getElementById('btnQSApply');
  btn.textContent = counter > 0 ? `Aplicar (${counter})` : 'Aplicar';
  btn.disabled = !(qsState.shift && qsState.days.size > 0);
  btn.style.opacity = btn.disabled ? '.5' : '1';
}

function countQSCells() {
  if (!qsState.shift || qsState.days.size === 0) return 0;
  const cycles = qsState.allCycles ? CYCLES : [currentCycle];
  let n = 0;
  for (const cy of cycles) {
    for (const day of qsState.days) {
      const off = daysOff[qsState.empId]?.[cy] || [];
      if (off.includes(day)) continue;
      const cell = schedule[cy][qsState.shift.deptId][day][qsState.shift.shiftId];
      if (!cell.emps.includes(qsState.empId)) n++;
    }
  }
  return n;
}

function applyQuickShift() {
  if (!qsState.shift || qsState.days.size === 0) return;
  const cycles = qsState.allCycles ? CYCLES : [currentCycle];
  let added = 0, skipped = 0;
  for (const cy of cycles) {
    for (const day of qsState.days) {
      const off = daysOff[qsState.empId]?.[cy] || [];
      if (off.includes(day)) { skipped++; continue; }
      const cell = schedule[cy][qsState.shift.deptId][day][qsState.shift.shiftId];
      if (!cell.emps.includes(qsState.empId)) {
        cell.emps.push(qsState.empId);
        added++;
      }
      if (qsState.note && !cell.note) cell.note = qsState.note;
    }
  }
  document.getElementById('ovQS').classList.remove('show');
  render(); autosave();
  let msg = `✓ Turno agregado en ${added} celda${added !== 1 ? 's' : ''}`;
  if (skipped > 0) msg += ` · ${skipped} skipeada${skipped !== 1 ? 's' : ''} (descanso)`;
  showToast(msg);
}

// ── MODAL ─────────────────────────────────────────────────────────────────────
function openModal(deptId, day, shiftId) {
  modalCell = {deptId, day, shiftId};
  const dept = DEPTS.find(d=>d.id===deptId);
  const sh = dept.shifts.find(s=>s.id===shiftId);
  const data = schedule[currentCycle][deptId][day][shiftId];
  modalSel = [...data.emps];
  modalNote = data.note || '';

  document.getElementById('mTitle').textContent = `${DAY_FULL[day]} — Turno ${sh.label} (${sh.time})`;
  document.getElementById('mSub').textContent = `Ciclo Sem ${currentCycle} · ${dept.label}`;

  buildModalBody(deptId);
  document.getElementById('ovCell').classList.add('show');
}

function buildModalBody(deptId) {
  const body = document.getElementById('mBody');
  body.innerHTML = '';

  // Employee list grouped by dept
  const groups = [
    {id: deptId, label: 'Mismo departamento'},
    ...DEPTS.filter(d=>d.id!==deptId).map(d=>({id:d.id, label:d.label}))
  ];

  for (const g of groups) {
    const emps = EMPLOYEES.filter(e=>e.dept===g.id);
    if (!emps.length) continue;
    const lbl = document.createElement('div');
    lbl.className = 'modal-section-lbl';
    lbl.textContent = g.label;
    body.appendChild(lbl);
    for (const emp of emps) {
      const item = document.createElement('div');
      item.className = 'memp' + (modalSel.includes(emp.id)?' sel':'');
      item.dataset.id = emp.id;
      item.innerHTML = `<div class="mcheck">${modalSel.includes(emp.id)?'✓':''}</div>
        <div class="mdot" style="background:${emp.color}"></div>
        <div class="mname">${emp.name}</div>
        <span class="mdept-tag">${emp.dept}</span>`;
      item.addEventListener('click', ()=>toggleModalEmp(emp.id, deptId));
      body.appendChild(item);
    }
  }

  // Note field
  const noteRow = document.createElement('div');
  noteRow.className = 'modal-note-row';
  noteRow.innerHTML = `<label>Nota de celda (ej: "2 L2", "cobertura")</label>
    <input class="modal-note-input" id="noteInput" type="text" placeholder="Opcional…" value="${escHtml(modalNote)}">`;
  body.appendChild(noteRow);
}

function toggleModalEmp(empId, deptId) {
  const i = modalSel.indexOf(empId);
  if (i>=0) modalSel.splice(i,1); else modalSel.push(empId);
  buildModalBody(deptId);
}

function closeModal() {
  document.getElementById('ovCell').classList.remove('show');
  modalCell = null; modalSel = []; modalNote = '';
}

function saveModal() {
  if (!modalCell) return;
  const {deptId, day, shiftId} = modalCell;
  const noteEl = document.getElementById('noteInput');
  schedule[currentCycle][deptId][day][shiftId] = {
    emps: [...modalSel],
    note: noteEl ? noteEl.value.trim() : ''
  };
  closeModal(); render(); autosave();
}

// ── CYCLE ACTIONS ─────────────────────────────────────────────────────────────
function switchCycle(cy) {
  currentCycle = cy;
  document.querySelectorAll('.ctab').forEach(t=>t.classList.toggle('active', t.dataset.cycle===cy));
  render();
}

function clearCycle() {
  if (!confirm(`¿Limpiar TODOS los turnos del ciclo Sem ${currentCycle} y los días libres de todos los empleados?`)) return;
  for (const dept of DEPTS)
    for (const day of DAYS)
      for (const sh of dept.shifts)
        schedule[currentCycle][dept.id][day][sh.id] = {emps:[], note:''};
  for (const emp of EMPLOYEES)
    if (daysOff[emp.id])
      for (const cy of CYCLES) daysOff[emp.id][cy] = [];
  render(); autosave();
  showToast(`Ciclo Sem ${currentCycle} limpiado`);
}

function openCopyModal() {
  document.getElementById('copyFrom').textContent = `Sem ${currentCycle}`;
  const grid = document.getElementById('copyGrid');
  grid.innerHTML = '';
  for (const cy of CYCLES) {
    if (cy===currentCycle) continue;
    const btn = document.createElement('div');
    btn.className = 'ccbtn';
    btn.textContent = `Sem ${cy}`;
    btn.addEventListener('click', ()=>{ copyCycle(cy); document.getElementById('ovCopy').classList.remove('show'); });
    grid.appendChild(btn);
  }
  document.getElementById('ovCopy').classList.add('show');
}

function copyCycle(to) {
  for (const dept of DEPTS)
    for (const day of DAYS)
      for (const sh of dept.shifts) {
        const src = schedule[currentCycle][dept.id][day][sh.id];
        schedule[to][dept.id][day][sh.id] = {emps:[...src.emps], note:src.note};
      }
  autosave();
  showToast(`Sem ${currentCycle} copiado a Sem ${to}`);
}

// ── PERSISTENCE (server-side via /planner/api/state) ─────────────────────────
function setSaveStatus(text, color) {
  const el = document.getElementById('saveStatus');
  if (el) { el.textContent = text || ''; el.style.color = color || '#5b6f88'; }
}

async function postState() {
  const body = JSON.stringify({ schedule, daysOff });
  const r = await fetch('/planner/api/state', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body
  });
  if (!r.ok) throw new Error('save failed');
  const j = await r.json();
  if (!j.ok) throw new Error(j.error || 'save failed');
}

async function saveData() {
  setSaveStatus('Guardando…', '#5b6f88');
  try { await postState(); setSaveStatus('Guardado ✓', '#10b981'); showToast('Guardado en servidor ✓'); }
  catch (e) { setSaveStatus('Error al guardar', '#ef4444'); showToast('❌ ' + e.message); }
}

async function loadData() {
  const r = await fetch('/planner/api/state');
  if (!r.ok) throw new Error('load failed');
  const j = await r.json();

  // Replace employees from server (DB is source of truth)
  EMPLOYEES.length = 0;
  for (const e of (j.employees || [])) EMPLOYEES.push(e);

  // Init daysOff for every employee
  for (const emp of EMPLOYEES) {
    daysOff[emp.id] = {};
    for (const cy of CYCLES) daysOff[emp.id][cy] = [];
  }

  const data = j.state || {};
  // Restore schedule
  if (data.schedule) {
    for (const cy of CYCLES) {
      if (!data.schedule[cy]) continue;
      for (const dept of DEPTS) {
        if (!data.schedule[cy][dept.id]) continue;
        for (const day of DAYS) {
          if (!data.schedule[cy][dept.id][day]) continue;
          for (const sh of dept.shifts) {
            const cell = data.schedule[cy][dept.id][day][sh.id];
            if (!cell) continue;
            schedule[cy][dept.id][day][sh.id] = Array.isArray(cell)
              ? {emps:cell, note:''}
              : {emps:cell.emps||[], note:cell.note||''};
          }
        }
      }
    }
  }
  // Restore days off
  if (data.daysOff) {
    for (const emp of EMPLOYEES) {
      if (data.daysOff[emp.id]) {
        for (const cy of CYCLES)
          daysOff[emp.id][cy] = data.daysOff[emp.id][cy] || [];
      }
    }
  }
  if (data.updated_at) setSaveStatus('Cargado · ' + (data.updated_at || ''), '#5b6f88');
}

let _autosaveT;
function autosave() {
  clearTimeout(_autosaveT);
  setSaveStatus('Cambios sin guardar…', '#f59e0b');
  _autosaveT = setTimeout(async () => {
    try { await postState(); setSaveStatus('Auto-guardado ✓', '#10b981'); }
    catch (e) { setSaveStatus('Auto-guardado fallo', '#ef4444'); }
  }, 1200);
}

// ── PRINT ─────────────────────────────────────────────────────────────────────
function printSchedule() {
  window.print();
}

// ── EXPORT / IMPORT ───────────────────────────────────────────────────────────
function exportData() {
  const data = { schedule, daysOff, employees: EMPLOYEES, exportedAt: new Date().toISOString(), version: 3 };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  const date = new Date().toISOString().slice(0, 10);
  a.href = url;
  a.download = `horarios-support-${date}.json`;
  a.click();
  URL.revokeObjectURL(url);
  showToast('Horario exportado ✓');
}

function importData(file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    try {
      const data = JSON.parse(e.target.result);
      if (!data.schedule) { showToast('Archivo inválido'); return; }
      if (!confirm('¿Reemplazar el horario actual con el archivo importado?')) return;
      // Re-init and load
      initSchedule();
      initDaysOff();
      // Load schedule
      for (const cy of CYCLES) {
        if (!data.schedule[cy]) continue;
        for (const dept of DEPTS) {
          if (!data.schedule[cy][dept.id]) continue;
          for (const day of DAYS) {
            if (!data.schedule[cy][dept.id][day]) continue;
            for (const sh of dept.shifts) {
              const cell = data.schedule[cy][dept.id][day][sh.id];
              if (!cell) continue;
              schedule[cy][dept.id][day][sh.id] = Array.isArray(cell)
                ? { emps: cell, note: '' }
                : { emps: cell.emps || [], note: cell.note || '' };
            }
          }
        }
      }
      // Load daysOff
      if (data.daysOff) {
        for (const emp of EMPLOYEES) {
          if (data.daysOff[emp.id]) {
            for (const cy of CYCLES)
              daysOff[emp.id][cy] = data.daysOff[emp.id][cy] || [];
          }
        }
      }
      autosave();
      render();
      showToast('Horario importado ✓');
    } catch (err) {
      showToast('Error al leer el archivo');
    }
  };
  reader.readAsText(file);
}

// ── UTILS ─────────────────────────────────────────────────────────────────────
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

let _toastT;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(_toastT);
  _toastT = setTimeout(()=>t.classList.remove('show'), 2400);
}

// ── EVENTS ───────────────────────────────────────────────────────────────────
document.getElementById('cycleTabs').addEventListener('click', e=>{
  const t = e.target.closest('.ctab');
  if (t) switchCycle(t.dataset.cycle);
});
document.getElementById('viewToggle').addEventListener('click', e => {
  const t = e.target.closest('.vtbtn');
  if (t) switchViewMode(t.dataset.view);
});
document.getElementById('btnADClose').addEventListener('click', closeAgentDayModal);
document.getElementById('btnADSave').addEventListener('click', saveAgentDayModal);
document.getElementById('ovAgentDay').addEventListener('click', e => {
  if (e.target === document.getElementById('ovAgentDay')) closeAgentDayModal();
});

document.getElementById('btnSave').addEventListener('click', saveData);
document.getElementById('btnExport').addEventListener('click', exportData);
// Apply-to-dates flow
document.getElementById('btnApplyDates').addEventListener('click', () => {
  document.getElementById('ovApply').classList.add('show');
});
document.getElementById('btnApplyClose').addEventListener('click', () => {
  document.getElementById('ovApply').classList.remove('show');
});
document.getElementById('btnApplyContinue').addEventListener('click', async () => {
  // Save first so the server has the latest state, THEN submit the form
  try { await postState(); } catch (e) { showToast('❌ No se pudo guardar antes de aplicar'); return; }
  document.getElementById('applyForm').submit();
});
document.getElementById('ovApply').addEventListener('click', e => {
  if (e.target === document.getElementById('ovApply')) document.getElementById('ovApply').classList.remove('show');
});
document.getElementById('fileImport').addEventListener('change', e => { importData(e.target.files[0]); e.target.value = ''; });
document.getElementById('btnClear').addEventListener('click', clearCycle);
document.getElementById('btnCopy').addEventListener('click', openCopyModal);
document.getElementById('btnPrint').addEventListener('click', printSchedule);
document.getElementById('btnMClose').addEventListener('click', closeModal);
document.getElementById('btnMSave').addEventListener('click', saveModal);
document.getElementById('btnCopyClose').addEventListener('click', ()=>document.getElementById('ovCopy').classList.remove('show'));
document.getElementById('btnDOClose').addEventListener('click', ()=>{ document.getElementById('ovDO').classList.remove('show'); renderSidebar(); });
document.getElementById('btnQSClose').addEventListener('click', ()=>{ document.getElementById('ovQS').classList.remove('show'); });
document.getElementById('btnQSApply').addEventListener('click', applyQuickShift);
document.getElementById('ovQS').addEventListener('click', e => { if (e.target === document.getElementById('ovQS')) document.getElementById('ovQS').classList.remove('show'); });
document.getElementById('ovDO').addEventListener('click', e=>{ if(e.target===document.getElementById('ovDO')){ document.getElementById('ovDO').classList.remove('show'); renderSidebar(); } });

document.getElementById('ovCell').addEventListener('click', e=>{
  if (e.target===document.getElementById('ovCell')) closeModal();
});
document.getElementById('ovCopy').addEventListener('click', e=>{
  if (e.target===document.getElementById('ovCopy')) document.getElementById('ovCopy').classList.remove('show');
});
document.addEventListener('keydown', e=>{
  if (e.key==='Escape') {
    closeModal();
    document.getElementById('ovCopy').classList.remove('show');
    document.getElementById('ovDO').classList.remove('show'); renderSidebar();
  }
  if ((e.ctrlKey||e.metaKey) && e.key==='s') { e.preventDefault(); saveData(); }
});

// ── INIT ─────────────────────────────────────────────────────────────────────
(async function init() {
  initSchedule();
  // initDaysOff needs EMPLOYEES which loadData populates
  try { await loadData(); }
  catch (e) {
    showToast('❌ Error cargando estado: ' + e.message);
    initDaysOff();
  }
  render();
})();
</script>
