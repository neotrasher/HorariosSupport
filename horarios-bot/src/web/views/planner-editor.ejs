<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>
<style>
/* ── Planner-scoped styles (overrides Tailwind defaults inside .planner-shell) ── */
.planner-shell *,.planner-shell *::before,.planner-shell *::after{box-sizing:border-box}
.planner-shell{
  --bg:#f0f4f8;--surface:#fff;--border:#e2e8f0;
  --text:#1a202c;--muted:#718096;--accent:#4299e1;--accent-dk:#2b6cb0;
  --hdr:#1a202c;
  background:var(--bg);color:var(--text);font-size:14px;
  /* Sidebar layout: planner takes the full content area, ~100vh.
     On mobile we still have a 49px top bar from the main shell. */
  height:100vh;overflow:hidden;display:flex;flex-direction:column;
}
@media (max-width: 768px) { .planner-shell { height: calc(100vh - 49px); } }
@media (max-width: 768px) { .planner-mobile-hidden { display: none; } }

/* ── Planner header: align with main app aesthetic (light, ink palette) ── */
.planner-shell .hdr {
  background: #ffffff;
  color: #1f2c3d;
  border-bottom: 1px solid #e6eaf0;
  height: 56px;
  padding: 0 18px;
  gap: 12px;
  box-shadow: 0 1px 2px 0 rgb(15 24 37 / 0.03);
}
.planner-shell .hdr-title {
  font-size: 14px; font-weight: 700; color: #0f1825;
  letter-spacing: -0.01em;
}
.planner-shell .hdr-sep { background: #e6eaf0; height: 22px; }
.planner-shell .hdr-lbl { color: #5b6f88; }

/* Cycle tabs — light surface with ink active */
.planner-shell .cycle-tabs {
  background: #f1f5f9; padding: 3px; border-radius: 8px; border: 1px solid #e6eaf0;
  box-shadow: 0 1px 1px 0 rgb(15 24 37 / 0.03) inset;
}
.planner-shell .ctab {
  color: #5b6f88; font-size: 12px; padding: 5px 12px; border-radius: 6px;
  font-weight: 600;
}
.planner-shell .ctab:hover { color: #1f2c3d; background: rgba(255,255,255,0.6); }
.planner-shell .ctab.active {
  background: linear-gradient(to bottom, #2d3e54 0%, #1f2c3d 100%);
  color: #ffffff;
  box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.12) inset, 0 1px 2px 0 rgb(15 24 37 / 0.20);
}

/* Buttons — match main btn styles */
.planner-shell .btn {
  font-size: 12px; font-weight: 600; padding: 6px 12px; border-radius: 7px;
  transition: background .12s, color .12s, box-shadow .12s, transform .1s;
}
.planner-shell .btn-ghost {
  background: #ffffff; color: #5b6f88; border: 1px solid #e6eaf0;
  box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.6) inset, 0 1px 1px 0 rgb(15 24 37 / 0.04);
}
.planner-shell .btn-ghost:hover { background: #f8fafc; color: #1f2c3d; border-color: #cfd8e3; }
.planner-shell .btn-primary {
  background: linear-gradient(to bottom, #2d3e54 0%, #1f2c3d 100%);
  color: #fff; border: 1px solid #1f2c3d;
  box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.12) inset, 0 1px 2px 0 rgb(15 24 37 / 0.20);
}
.planner-shell .btn-primary:hover {
  background: linear-gradient(to bottom, #34475f 0%, #2a3a4f 100%);
  box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.15) inset, 0 2px 4px 0 rgb(15 24 37 / 0.25);
}
.planner-shell .btn-primary:active { transform: translateY(1px); }
.planner-shell .btn-danger {
  background: #ffffff; color: #dc2626; border: 1px solid #fecaca;
}
.planner-shell .btn-danger:hover { background: #fef2f2; color: #b91c1c; border-color: #fca5a5; }

/* Save status text — chip-style aligned with buttons */
.planner-shell .hdr-status {
  display: inline-flex; align-items: center;
  font-size: 11px; font-weight: 500; color: #5b6f88;
  padding: 4px 10px; border-radius: 6px;
  background: #f1f5f9; border: 1px solid #e6eaf0;
  white-space: nowrap;
  margin-right: 4px;
  height: 28px; line-height: 1;
}
.planner-shell .hdr-status:empty { display: none; }

/* Sidebar of planner (employees panel) — softer borders */
.planner-shell .sidebar { background: #ffffff; border-right: 1px solid #e6eaf0; }
.planner-shell .sb-hdr { background: #f8fafc; border-bottom: 1px solid #e6eaf0; }
.planner-shell .sb-title { color: #5b6f88; }

/* Dept cards in scheduler */
.planner-shell .dept-card {
  border-radius: 10px;
  border: 1px solid #e6eaf0;
  box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.6) inset, 0 1px 2px 0 rgb(15 24 37 / 0.04), 0 1px 3px 0 rgb(15 24 37 / 0.05);
}
.planner-shell .dept-hdr { border-bottom: 1px solid #e6eaf0; }
.planner-shell .gh { background: #f8fafc; color: #5b6f88; border-color: #e6eaf0; }
.planner-shell .gcell { border-color: #e6eaf0; }
.planner-shell .gcell:hover { background: #f1f5f9; }

/* ── Modales del planner: re-skin con ink palette + sombras layered ── */
.planner-shell .overlay { background: rgba(15, 24, 37, 0.50); backdrop-filter: blur(2px); }
.planner-shell .modal {
  border-radius: 14px;
  border: 1px solid #e6eaf0;
  box-shadow:
    0 1px 0 0 rgb(255 255 255 / 0.6) inset,
    0 24px 48px -8px rgb(15 24 37 / 0.30),
    0 8px 16px -4px rgb(15 24 37 / 0.18);
}
.planner-shell .modal-hdr { background: linear-gradient(to bottom, #ffffff 0%, #fafbfc 100%); border-bottom: 1px solid #e6eaf0; padding: 14px 18px; }
.planner-shell .modal-title { color: #0f1825; font-size: 15px; font-weight: 700; letter-spacing: -0.01em; }
.planner-shell .modal-sub { color: #5b6f88; }
.planner-shell .modal-body { padding: 14px 18px; }
.planner-shell .modal-section-lbl {
  color: #5b6f88; font-weight: 700; font-size: 10px;
  border-bottom: 1px solid #e6eaf0; padding: 6px 0 4px; margin: 8px 0 4px;
  letter-spacing: 0.06em;
}
.planner-shell .modal-section-lbl:first-child { margin-top: 0; }
.planner-shell .memp { padding: 7px 8px; border-radius: 8px; transition: background .12s; }
.planner-shell .memp:hover { background: #f1f5f9; }
.planner-shell .memp.sel { background: #e9eef4; }
.planner-shell .mcheck {
  width: 17px; height: 17px; border-radius: 5px;
  border: 2px solid #cfd8e3; transition: all .12s;
}
.planner-shell .memp.sel .mcheck {
  background: linear-gradient(to bottom, #2d3e54 0%, #1f2c3d 100%);
  border-color: #1f2c3d;
  box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.12) inset, 0 1px 2px 0 rgb(15 24 37 / 0.20);
}
.planner-shell .mname { font-size: 13px; font-weight: 600; color: #1f2c3d; }
.planner-shell .mdept-tag {
  background: #e9eef4; color: #5b6f88;
  font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 4px;
  letter-spacing: 0.04em;
}
.planner-shell .modal-note-row label { color: #5b6f88; font-weight: 600; }
.planner-shell .modal-note-input {
  border: 1px solid #cfd8e3; border-radius: 7px;
  padding: 7px 10px; font-size: 13px;
  background: #fff;
}
.planner-shell .modal-note-input:focus { border-color: #2d3e54; outline: 2px solid rgba(45, 62, 84, 0.15); }
.planner-shell .modal-ftr { padding: 12px 18px; border-top: 1px solid #e6eaf0; background: #fafbfc; gap: 10px; }

/* Copy cycle modal grid */
.planner-shell .ccbtn {
  border: 2px solid #e6eaf0; border-radius: 10px; padding: 16px;
  font-weight: 700; color: #5b6f88; font-size: 16px;
  transition: all .15s ease;
  background: #fff;
}
.planner-shell .ccbtn:hover {
  border-color: #2d3e54; color: #1f2c3d; background: #f1f5f9;
  transform: translateY(-1px);
  box-shadow: 0 2px 4px 0 rgb(15 24 37 / 0.08);
}

/* Quick-shift modal pills */
.planner-shell .qs-lbl { color: #5b6f88; font-weight: 700; font-size: 10px; letter-spacing: 0.06em; margin-bottom: 7px; }
.planner-shell .qs-pill {
  border: 2px solid #e6eaf0; border-radius: 9px;
  background: #fff; transition: all .12s ease;
  font-weight: 600;
}
.planner-shell .qs-pill:hover { transform: translateY(-1px); box-shadow: 0 2px 4px 0 rgb(15 24 37 / 0.08); }
.planner-shell .qs-pill.sel {
  box-shadow: 0 2px 6px 0 rgb(15 24 37 / 0.18), 0 1px 0 0 rgb(255 255 255 / 0.20) inset;
}
.planner-shell .qs-daybtn {
  border: 2px solid #e6eaf0; border-radius: 9px;
  background: #fff; color: #5b6f88; font-weight: 700;
  transition: all .12s ease;
}
.planner-shell .qs-daybtn:hover:not(.disabled) { border-color: #cfd8e3; background: #f1f5f9; }
.planner-shell .qs-daybtn.sel {
  background: linear-gradient(to bottom, #2d3e54 0%, #1f2c3d 100%);
  border-color: #1f2c3d; color: #fff;
  box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.12) inset, 0 1px 2px 0 rgb(15 24 37 / 0.20);
}
.planner-shell .qs-cyc-row { color: #1f2c3d; font-size: 12px; }
.planner-shell .qs-radio input[type="radio"] { accent-color: #2d3e54; }
.planner-shell .qs-note-inp {
  border: 1px solid #cfd8e3; border-radius: 7px; padding: 8px 11px;
  background: #fff; font-size: 13px;
}
.planner-shell .qs-note-inp:focus { border-color: #2d3e54; outline: 2px solid rgba(45, 62, 84, 0.15); }

/* Days-off modal */
.planner-shell .do-cy-lbl { color: #5b6f88; font-weight: 700; font-size: 11px; }
.planner-shell .do-daybtn {
  border: 2px solid #e6eaf0; background: #fff;
  font-weight: 700; color: #5b6f88;
  transition: all .12s ease;
}
.planner-shell .do-daybtn:hover { border-color: #cfd8e3; background: #f1f5f9; }
.planner-shell .do-daybtn.off {
  background: #fed7aa; border-color: #f6ad55; color: #7b341e;
}

/* Toast del planner */
.planner-shell .toast {
  background: linear-gradient(to bottom, #2d3e54 0%, #1f2c3d 100%);
  color: #fff; border-radius: 9px; font-weight: 600;
  box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.12) inset, 0 8px 16px -4px rgb(15 24 37 / 0.30);
  padding: 10px 18px;
}

/* HEADER */
.hdr{background:var(--hdr);color:#fff;display:flex;align-items:center;padding:0 16px;height:50px;gap:10px;flex-shrink:0}
.hdr-logo{font-size:15px;font-weight:800;color:#63b3ed;letter-spacing:-.02em;white-space:nowrap}
.hdr-sep{width:1px;height:24px;background:#2d3748}
.hdr-lbl{font-size:10px;color:#718096;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.cycle-tabs{display:flex;gap:2px;background:#2d3748;padding:3px;border-radius:8px}
.ctab{padding:5px 13px;border-radius:5px;cursor:pointer;font-size:13px;font-weight:700;color:#a0aec0;border:none;background:transparent;transition:all .15s}
.ctab:hover{color:#fff}
.ctab.active{background:var(--accent);color:#fff;box-shadow:0 1px 4px rgba(66,153,225,.4)}
.view-toggle{display:flex;gap:2px;background:#2d3748;padding:3px;border-radius:8px}
.vtbtn{padding:5px 13px;border-radius:5px;cursor:pointer;font-size:12px;font-weight:700;color:#a0aec0;border:none;background:transparent;transition:all .15s;font-family:inherit}
.vtbtn:hover{color:#fff}
.vtbtn.active{background:#10b981;color:#fff;box-shadow:0 1px 4px rgba(16,185,129,.4)}
/* Agent-view grid (rows = agents, cols = days) */
.agent-grid{display:grid;min-width:540px}
.agent-name-cell{padding:6px 10px;font-size:12px;font-weight:700;color:var(--text);background:#f7fafc;border-bottom:1px solid var(--border);border-right:1px solid var(--border);display:flex;align-items:center;gap:6px;min-height:46px}
.agent-name-cell .adot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.agent-name-cell .aname{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:600}
.agent-name-cell .ainit{font-size:10px;color:var(--muted);font-weight:700;font-family:ui-monospace,monospace}
.agent-name-cell .adept-tag{font-size:9px;font-weight:800;padding:1px 5px;border-radius:3px;flex-shrink:0}
.subdept-hdr{padding:5px 10px;background:#f1f5f9;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:4px;font-size:11px}
/* Homebase-style chip: time on top, agent name below — fills cell width */
.hb-chip{display:flex;flex-direction:column;padding:4px 7px 4px 8px;border-radius:4px;color:#fff;line-height:1.25;box-shadow:0 1px 2px rgba(0,0,0,.18);position:relative;width:100%;box-sizing:border-box;transition:opacity .12s}
.hb-chip.dimmed{opacity:.2}
.hb-chip.chip-warn{outline:2px solid #f6ad55;outline-offset:1px}
.hb-time{font-size:9.5px;font-weight:600;opacity:.9;font-family:ui-monospace,monospace;letter-spacing:.2px}
.hb-name{font-size:11px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.hb-x{position:absolute;top:2px;right:3px;width:13px;height:13px;border-radius:50%;background:rgba(0,0,0,.18);display:none;align-items:center;justify-content:center;font-size:9px;font-weight:700;cursor:pointer;line-height:1}
.hb-chip:hover .hb-x{display:flex}
.hb-x:hover{background:rgba(0,0,0,.4)}
.agent-cell{padding:4px 5px;border-bottom:1px solid var(--border);border-right:1px solid var(--border);min-height:46px;display:flex;flex-direction:column;gap:2px;cursor:pointer;transition:background .1s;position:relative}
.agent-cell:hover{background:#ebf8ff}
.agent-cell:last-child{border-right:none}
.agent-cell.empty{background:#fafbfc}
.agent-cell.empty:hover{background:#edf2f7}
.agent-cell.conflict{background:#fff5f5;box-shadow:inset 0 0 0 2px #fc8181}
.shift-pill{display:flex;flex-direction:column;padding:3px 6px;border-radius:5px;font-size:10px;font-weight:700;color:#fff;line-height:1.25;box-shadow:0 1px 2px rgba(0,0,0,.15)}
.shift-pill .sp-time{font-size:9px;opacity:.85;font-family:ui-monospace,monospace;font-weight:600;letter-spacing:.2px}
.shift-pill.cross{outline:1px dashed rgba(255,255,255,.45);outline-offset:-2px}
.off-pill{display:inline-flex;align-items:center;gap:3px;padding:3px 7px;border-radius:5px;font-size:10px;font-weight:700;background:#fed7aa;color:#7b341e;align-self:flex-start}
.empty-hint{font-size:10px;color:#cbd5e0;font-weight:600;align-self:flex-start;font-style:italic}
.conflict-badge{position:absolute;top:2px;right:3px;font-size:10px;color:#c53030;font-weight:800;line-height:1}
.agent-cell:hover .add-indicator{display:flex}
.hdr-actions{margin-left:auto;display:flex;gap:6px}
.btn{padding:5px 12px;border-radius:6px;border:none;cursor:pointer;font-size:12px;font-weight:600;transition:all .15s}
.btn-ghost{background:transparent;color:#a0aec0;border:1px solid #4a5568}
.btn-ghost:hover{background:#2d3748;color:#fff}
.btn-primary{background:var(--accent);color:#fff}
.btn-primary:hover{background:var(--accent-dk)}
.btn-danger{background:transparent;color:#fc8181;border:1px solid #63171b}
.btn-danger:hover{background:#63171b;color:#fff}

/* LAYOUT */
.planner-shell .body{display:flex;flex:1;min-height:0}
.planner-shell .hdr{position:sticky;top:0;z-index:10}
/* Mobile: stack sidebar above content */
@media (max-width: 768px) {
  .planner-shell .body{flex-direction:column}
  .planner-shell .sidebar{width:100%;max-height:40vh;border-right:none;border-bottom:1px solid var(--border)}
  .planner-shell .hdr{flex-wrap:wrap;height:auto;padding:8px 12px;gap:6px}
  .planner-shell .hdr-actions{margin-left:0;width:100%;justify-content:flex-start;flex-wrap:wrap;gap:4px}
  .planner-shell .hdr-actions .btn{font-size:11px;padding:4px 8px}
}
.sidebar{width:230px;flex-shrink:0;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sb-hdr{padding:8px 10px 6px;border-bottom:1px solid var(--border);background:#f7fafc}
.sb-title{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em}
.sb-body{overflow-y:auto;flex:1;padding:6px}
.sb-dept-title{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;padding:6px 4px 3px;margin-top:4px;border-bottom:1px solid var(--border)}
.emp-row{display:flex;flex-direction:column;gap:3px;padding:5px 6px;border-radius:6px;cursor:pointer;transition:background .1s,box-shadow .12s}
.emp-row-top{display:flex;align-items:center;gap:6px;width:100%}
.emp-row-bot{display:flex;align-items:center;gap:4px;padding-left:15px;flex-wrap:wrap}
.emp-row:hover{background:var(--bg)}
.emp-row.filter-on{background:#dbeafe;box-shadow:inset 0 0 0 1.5px #3b82f6}
.emp-row.filter-on:hover{background:#bfdbfe}
.emp-do-btn{width:22px;height:22px;border-radius:5px;border:1px solid var(--border);background:var(--surface);color:var(--muted);cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;transition:all .12s;flex-shrink:0;line-height:1;padding:0}
.emp-do-btn:hover{background:#f59e0b;border-color:#d97706;color:#fff}
.filter-bar{display:flex;align-items:center;justify-content:space-between;padding:6px 8px;margin:4px 0 8px;background:#dbeafe;border:1px solid #3b82f6;border-radius:6px;font-size:11px;color:#1e3a8a;font-weight:600}
.filter-bar-clear{cursor:pointer;background:#3b82f6;color:#fff;border:none;padding:3px 8px;border-radius:4px;font-size:10px;font-weight:700;font-family:inherit}
.filter-bar-clear:hover{background:#1d4ed8}
.emp-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.emp-row-name{font-size:12px;font-weight:600;color:var(--text);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0}
.emp-stats{display:flex;gap:2px;flex-shrink:0}
.st{font-size:9px;font-weight:700;padding:1px 4px;border-radius:3px;background:var(--bg)}

/* SCHEDULE AREA */
.sched-area{flex:1;overflow:auto;padding:12px;display:flex;flex-direction:column;gap:12px}

/* DEPT CARD */
.dept-card{background:var(--surface);border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,.07),0 0 0 1px rgba(0,0,0,.04);overflow:hidden}
.dept-hdr{display:flex;align-items:center;padding:8px 14px;gap:8px;border-bottom:1px solid var(--border)}
.dept-badge{padding:2px 9px;border-radius:5px;font-size:11px;font-weight:800;letter-spacing:.05em}
.badge-L2{background:#ebf8ff;color:#2b6cb0}
.badge-L1{background:#f0fff4;color:#276749}
.badge-S{background:#faf5ff;color:#553c9a}
.dept-title{font-size:13px;font-weight:700;color:#4a5568}
.shift-times{margin-left:auto;display:flex;gap:5px}
.shift-lbl{font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px;color:#fff}

/* GRID */
.grid-wrap{overflow-x:auto}
.sgrid{display:grid;min-width:540px}
.gh{padding:7px 8px;background:#f7fafc;font-size:11px;font-weight:700;color:#4a5568;text-align:center;border-bottom:1px solid var(--border);border-right:1px solid var(--border);position:sticky;top:0;z-index:2}
.gh:last-child{border-right:none}
.gday{display:flex;align-items:center;justify-content:center;padding:4px;background:#f7fafc;border-bottom:1px solid var(--border);border-right:1px solid var(--border);font-size:13px;font-weight:800;color:#4a5568;min-height:52px}
.gcell{padding:4px 5px;border-bottom:1px solid var(--border);border-right:1px solid var(--border);min-height:52px;display:flex;flex-wrap:wrap;gap:3px;align-content:flex-start;cursor:pointer;transition:background .1s;position:relative}
.gcell:hover{background:#ebf8ff}
.gcell:last-child{border-right:none}
.grow:last-child .gcell,.grow:last-child .gday{border-bottom:none}
.grow{display:contents}

/* Add indicator */
.add-indicator{display:none;position:absolute;bottom:4px;right:5px;width:18px;height:18px;border-radius:50%;background:#bee3f8;color:#2b6cb0;font-size:14px;font-weight:700;align-items:center;justify-content:center;line-height:1}
.gcell:hover .add-indicator{display:flex}

/* E shift (intermedio) — orange tint */
.gcell-E{background:#fffaf0}
.gcell-E:hover{background:#feebc8}
.gh-E{background:#fff8ed;color:#b45309}

/* Days off */
.emp-row{cursor:pointer}
.emp-do-row{display:flex;gap:3px;flex-wrap:wrap}
.do-tag{font-size:9px;font-weight:700;color:#7b341e;background:#fed7aa;padding:1px 4px;border-radius:3px;white-space:nowrap}
.do-tag-empty{font-size:9px;color:#cbd5e0;padding:1px 3px}
.chip-warn{outline:2px solid #f6ad55;outline-offset:1px}

/* Employee management modal */
.mgmt-group{margin-bottom:14px}
.mgmt-group-title{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;padding:4px 0 7px;border-bottom:1px solid var(--border);margin-bottom:6px}
.mgmt-emp-row{display:flex;align-items:center;gap:7px;padding:3px 0}
.mgmt-color-btn{width:22px;height:22px;border-radius:50%;border:2px solid rgba(0,0,0,.12);cursor:pointer;flex-shrink:0;position:relative;overflow:hidden}
.mgmt-color-input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%;padding:0;border:none}
.mgmt-name-input{flex:1;border:1px solid var(--border);border-radius:6px;padding:5px 8px;font-size:13px;outline:none;min-width:0}
.mgmt-name-input:focus{border-color:var(--accent)}
.mgmt-id{font-size:10px;color:#cbd5e0;font-weight:700;min-width:22px;text-align:right}
.mgmt-del{width:26px;height:26px;border-radius:6px;border:none;background:transparent;color:#fc8181;cursor:pointer;font-size:18px;line-height:1;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.mgmt-del:hover{background:#fff5f5;color:#e53e3e}
.mgmt-add{display:flex;align-items:center;gap:5px;padding:5px 8px;border-radius:6px;border:1px dashed var(--border);background:transparent;color:var(--muted);cursor:pointer;font-size:12px;font-weight:600;width:100%;margin-top:5px;transition:all .15s}
.mgmt-add:hover{border-color:var(--accent);color:var(--accent);background:#ebf8ff}

/* Days-off modal */
.do-grid{display:flex;flex-direction:column;gap:8px;padding:2px 0}
.do-row{display:flex;align-items:center;gap:8px}
.do-cy-lbl{font-size:11px;font-weight:800;color:var(--muted);width:40px;flex-shrink:0}
.do-days{display:flex;gap:3px}
.do-daybtn{width:30px;height:30px;border-radius:6px;border:2px solid var(--border);background:var(--surface);font-size:12px;font-weight:700;color:#4a5568;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .12s;user-select:none}
.do-daybtn:hover{border-color:#a0aec0;background:var(--bg)}
.do-daybtn.off{background:#fed7aa;border-color:#f6ad55;color:#7b341e}
/* Quick-shift modal styles */
.qs-add-btn{width:22px;height:22px;border-radius:5px;border:1px solid var(--border);background:var(--surface);color:var(--muted);cursor:pointer;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;transition:all .12s;flex-shrink:0;line-height:1;padding:0}
.qs-add-btn:hover{background:#3b82f6;border-color:#1d4ed8;color:#fff}
.qs-section{margin-bottom:14px}
.qs-lbl{font-size:11px;font-weight:600;color:var(--muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:.4px}
.qs-pills{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}
.qs-pill{display:flex;flex-direction:column;align-items:center;padding:8px 4px;border:2px solid;border-radius:8px;background:var(--surface);cursor:pointer;transition:all .12s;font-size:11px;font-weight:600;color:var(--text);font-family:inherit}
.qs-pill:hover{transform:translateY(-1px)}
.qs-pill-dept{font-size:10px;opacity:.65;line-height:1.2}
.qs-pill-sh{font-size:14px;font-weight:800;line-height:1.4}
.qs-pill-time{font-size:9px;opacity:.55;font-family:ui-monospace,monospace}
.qs-pill.sel .qs-pill-dept,.qs-pill.sel .qs-pill-time{opacity:.9}
.qs-days{display:flex;gap:6px;flex-wrap:wrap}
.qs-daybtn{width:36px;height:36px;border-radius:8px;border:2px solid var(--border);background:var(--surface);font-size:13px;font-weight:700;color:#4a5568;cursor:pointer;transition:all .12s;display:flex;align-items:center;justify-content:center;font-family:inherit}
.qs-daybtn:hover:not(.disabled){border-color:#a0aec0}
.qs-daybtn.sel{background:#3b82f6;border-color:#1d4ed8;color:#fff}
.qs-daybtn.disabled{opacity:.3;cursor:not-allowed;background:#f3f4f6}
.qs-cyc-row{display:flex;gap:14px;font-size:12px;color:var(--text);flex-wrap:wrap}
.qs-radio{display:flex;align-items:center;gap:5px;cursor:pointer}
.qs-note-inp{width:100%;padding:7px 9px;border:1px solid var(--border);border-radius:6px;font-size:12px;font-family:inherit;box-sizing:border-box}
.do-cnt{font-size:10px;font-weight:700;color:var(--muted);min-width:20px}

/* CHIPS */
.chip{display:inline-flex;align-items:center;gap:2px;padding:2px 6px 2px 7px;border-radius:12px;font-size:11px;font-weight:700;color:#fff;white-space:nowrap;user-select:none;box-shadow:0 1px 2px rgba(0,0,0,.15);max-width:110px;transition:opacity .12s}
.chip.dimmed{opacity:.18}
.chip-name{overflow:hidden;text-overflow:ellipsis;flex:1}
.chip-x{display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border-radius:50%;background:rgba(255,255,255,.25);cursor:pointer;font-size:9px;flex-shrink:0;line-height:1}
.chip-x:hover{background:rgba(255,255,255,.5)}
.chip-note{font-size:9px;background:#fed7aa;color:#7b341e;padding:1px 5px;border-radius:3px;font-weight:700;align-self:center}

/* Cell note */
.cell-note-txt{width:100%;font-size:9px;color:var(--muted);margin-top:2px;font-style:italic}

/* OVERLAY & MODAL */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.38);z-index:100;display:none;align-items:center;justify-content:center}
.overlay.show{display:flex}
.modal{background:#fff;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,.2);width:290px;overflow:hidden;max-height:90vh;display:flex;flex-direction:column}
.modal-hdr{padding:13px 16px;border-bottom:1px solid var(--border)}
.modal-title{font-size:14px;font-weight:700;color:var(--text)}
.modal-sub{font-size:11px;color:var(--muted);margin-top:2px}
.modal-body{padding:12px 16px;overflow-y:auto;flex:1}
.modal-section-lbl{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;padding:4px 0 3px;border-bottom:1px solid var(--border);margin-bottom:4px}
.memp{display:flex;align-items:center;gap:8px;padding:6px 6px;border-radius:7px;cursor:pointer;transition:background .1s}
.memp:hover{background:var(--bg)}
.memp.sel{background:#ebf8ff}
.mcheck{width:16px;height:16px;border-radius:4px;border:2px solid #cbd5e0;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:9px;color:#fff;transition:all .1s}
.memp.sel .mcheck{background:var(--accent);border-color:var(--accent)}
.mdot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.mname{font-size:13px;font-weight:500;color:var(--text);flex:1}
.mdept-tag{font-size:9px;font-weight:700;padding:1px 5px;border-radius:3px;background:var(--bg);color:var(--muted)}
.modal-note-row{padding:10px 0 2px}
.modal-note-row label{font-size:11px;color:var(--muted);font-weight:600;display:block;margin-bottom:4px}
.modal-note-input{width:100%;border:1px solid var(--border);border-radius:6px;padding:6px 8px;font-size:12px;outline:none}
.modal-note-input:focus{border-color:var(--accent)}
.modal-ftr{padding:10px 16px;border-top:1px solid var(--border);display:flex;gap:8px;justify-content:flex-end}

/* Copy modal */
.copy-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:4px 0 8px}
.ccbtn{padding:14px;border:2px solid var(--border);border-radius:8px;text-align:center;cursor:pointer;font-weight:700;font-size:15px;color:#4a5568;transition:all .15s}
.ccbtn:hover{border-color:var(--accent);color:var(--accent);background:#ebf8ff}

/* TOAST */
.toast{position:fixed;bottom:18px;right:18px;background:#2d3748;color:#fff;padding:9px 16px;border-radius:8px;font-size:13px;font-weight:600;box-shadow:0 4px 15px rgba(0,0,0,.2);transform:translateY(70px);opacity:0;transition:all .22s;z-index:200}
.toast.show{transform:translateY(0);opacity:1}

/* Scrollbars */
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-thumb{background:#cbd5e0;border-radius:3px}
::-webkit-scrollbar-track{background:transparent}
</style>

