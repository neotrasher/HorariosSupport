<script>
// ── DATA ─────────────────────────────────────────────────────────────────────

const DAYS = ['L','M','C','J','V','S','D'];
const DAY_FULL = {L:'Lunes',M:'Martes',C:'Miércoles',J:'Jueves',V:'Viernes',S:'Sábado',D:'Domingo'};
// Active cycles come from server config (3 = A/B/C, 4 = A/B/C/D).
// Saved data for inactive cycles is preserved in DB but ignored at render time.
const CYCLES = <%- JSON.stringify(activeCycles) %>;

const DEPTS = [
  { id:'L2', label:'Horario L2', shifts:[
    {id:'M', label:'Mañana',    time:'03–11', color:'#dd6b20'},
    {id:'T', label:'Tarde',     time:'11–19', color:'#2b6cb0'},
    {id:'E', label:'Intermedio',time:'15–23', color:'#b45309'},
    {id:'N', label:'Noche',     time:'19–03', color:'#553c9a'},
  ]},
  { id:'L1', label:'Horario L1', shifts:[
    {id:'M', label:'Mañana',    time:'00–08', color:'#276749'},
    {id:'T', label:'Tarde',     time:'08–16', color:'#97266d'},
    {id:'E', label:'Intermedio',time:'12–20', color:'#b45309'},
    {id:'N', label:'Noche',     time:'16–00', color:'#44337a'},
  ]},
];

// Loaded from /planner/api/state on init
let EMPLOYEES = [];

// schedule[cycle][deptId][day][shiftId] = { emps: [id,...], note: '' }
let schedule = {};

// Filter: empty Set = no filter (show all). Otherwise only those agents stay visible.
let filteredEmps = new Set();

function toggleEmpFilter(empId) {
  if (filteredEmps.has(empId)) filteredEmps.delete(empId);
  else filteredEmps.add(empId);
  render();
}

function clearEmpFilter() {
  filteredEmps.clear();
  render();
}

function initSchedule() {
  for (const cy of CYCLES) {
    schedule[cy] = {};
    for (const dept of DEPTS) {
      schedule[cy][dept.id] = {};
      for (const day of DAYS) {
        schedule[cy][dept.id][day] = {};
        for (const sh of dept.shifts) {
          schedule[cy][dept.id][day][sh.id] = {emps:[], note:''};
        }
      }
    }
  }
}

// ── STATE ────────────────────────────────────────────────────────────────────
let currentCycle = 'A';
let viewMode = 'by-shift';   // 'by-shift' | 'by-agent'
let modalCell = null;        // {deptId, day, shiftId}
let modalSel = [];           // temp employee selection
let modalNote = '';          // temp note
let adState = null;          // {empId, day, sel:Set("deptId|shiftId"), off:boolean}

// ── RENDER ───────────────────────────────────────────────────────────────────
function render() {
  document.getElementById('sbCycleLabel').textContent = currentCycle;
  renderSidebar();
  if (viewMode === 'by-agent') renderScheduleByAgent();
  else renderSchedule();
}

function renderSchedule() {
  const area = document.getElementById('schedArea');
  area.innerHTML = '';
  for (const dept of DEPTS) area.appendChild(buildDeptCard(dept));
}

// ── Vista "por agente" (estilo Homebase) ───────────────────────────────────
// Filas = agentes, columnas = 7 días, celda = turnos del día.
// Agentes agrupados por su turno predominante en el ciclo actual:
// M, T, EL2 (intermedio L2), EL1 (intermedio L1), N, o "Sin asignar".

// Grupos en orden de prioridad (también usado para desempates).
const SHIFT_GROUPS = [
  { key: 'M',   label: 'Mañana',         color: '#276749', hint: 'M' },
  { key: 'T',   label: 'Tarde',          color: '#2b6cb0', hint: 'T' },
  { key: 'EL2', label: 'Intermedio L2',  color: '#b45309', hint: 'E·L2' },
  { key: 'EL1', label: 'Intermedio L1',  color: '#b45309', hint: 'E·L1' },
  { key: 'N',   label: 'Noche',          color: '#553c9a', hint: 'N' },
];

// Devuelve la clave de grupo para un (deptId, shiftId).
// M/T/N son comunes a L1+L2. E se desdobla en EL1 / EL2.
function groupKeyFor(deptId, shiftId) {
  if (shiftId === 'E') return deptId === 'L1' ? 'EL1' : 'EL2';
  return shiftId; // 'M', 'T', 'N'
}

// Calcula el grupo predominante de un agente en el ciclo actual.
// Devuelve la key (string) o null si no tiene turnos asignados.
function principalGroupOf(empId) {
  const counts = {};
  for (const dept of DEPTS) {
    for (const day of DAYS) {
      for (const sh of dept.shifts) {
        if (schedule[currentCycle][dept.id][day][sh.id].emps.includes(empId)) {
          const k = groupKeyFor(dept.id, sh.id);
          counts[k] = (counts[k] || 0) + 1;
        }
      }
    }
  }
  let best = null, bestCount = 0;
  for (const g of SHIFT_GROUPS) {
    const c = counts[g.key] || 0;
    if (c > bestCount) { best = g.key; bestCount = c; }
    // Empate: el orden del array gana (M > T > EL2 > EL1 > N)
  }
  return best;
}

function renderScheduleByAgent() {
  const area = document.getElementById('schedArea');
  area.innerHTML = '';
  // 1 card por turno (M, T, EL2, EL1, N).
  // Eje Y = roles (L1, L2). Eje X = días.
  // Celda = chips de agentes asignados a ese (dept, día, turno), c/u con nombre + hora.
  for (const g of SHIFT_GROUPS) {
    const card = buildShiftCard(g);
    if (card) area.appendChild(card);
  }
}

// Devuelve los pares (deptId, shiftId) que pertenecen a un grupo
function deptShiftsForGroup(groupKey) {
  if (groupKey === 'EL1') return [{ deptId: 'L1', shiftId: 'E' }];
  if (groupKey === 'EL2') return [{ deptId: 'L2', shiftId: 'E' }];
  // M, T, N → uno por dept
  return DEPTS.map(d => ({ deptId: d.id, shiftId: groupKey }));
}

// Devuelve los depts cuyo eje Y debe aparecer en este card
function deptsForGroup(groupKey) {
  if (groupKey === 'EL1') return ['L1'];
  if (groupKey === 'EL2') return ['L2'];
  return ['L1', 'L2'];
}

// Cuenta cuántas asignaciones hay en este grupo en todo el ciclo — para skip cards vacíos
function groupHasAnyAssignment(groupKey) {
  const pairs = deptShiftsForGroup(groupKey);
  for (const day of DAYS) {
    for (const { deptId, shiftId } of pairs) {
      if (schedule[currentCycle][deptId][day][shiftId].emps.length > 0) return true;
    }
  }
  return false;
}

function buildShiftCard(group) {
  // Si nadie está en este grupo en el ciclo, no mostrar el card (evita ruido)
  if (!groupHasAnyAssignment(group.key)) return null;

  const card = document.createElement('div');
  card.className = 'dept-card';

  const hdr = document.createElement('div');
  hdr.className = 'dept-hdr';
  // Contar agentes únicos en el card
  const empSet = new Set();
  for (const day of DAYS) {
    for (const { deptId, shiftId } of deptShiftsForGroup(group.key)) {
      for (const e of schedule[currentCycle][deptId][day][shiftId].emps) empSet.add(e);
    }
  }
  hdr.innerHTML = `
    <span class="dept-badge" style="background:${group.color};color:#fff">${group.hint}</span>
    <span class="dept-title">${group.label}</span>
    <span style="font-size:11px;color:#a0aec0;font-weight:600;margin-left:6px">${empSet.size} agente${empSet.size !== 1 ? 's' : ''}</span>`;
  card.appendChild(hdr);

  const wrap = document.createElement('div');
  wrap.className = 'grid-wrap';
  const grid = document.createElement('div');
  grid.className = 'sgrid';
  grid.style.gridTemplateColumns = `70px repeat(${DAYS.length}, 1fr)`;

  // Header row: corner + días
  const corner = document.createElement('div');
  corner.className = 'gh';
  grid.appendChild(corner);
  for (const day of DAYS) {
    const h = document.createElement('div');
    h.className = 'gh';
    h.title = DAY_FULL[day];
    h.innerHTML = `<span style="font-size:14px;font-weight:800">${day}</span>
      <br><span style="font-size:9px;color:#a0aec0;font-weight:500">${DAY_FULL[day].slice(0,3)}</span>`;
    grid.appendChild(h);
  }

  // Una fila por dept en este card
  const depts = deptsForGroup(group.key);
  for (let i = 0; i < depts.length; i++) {
    const deptId = depts[i];
    const dept = DEPTS.find(d => d.id === deptId);
    const sh = dept.shifts.find(s => s.id === (group.key === 'EL1' || group.key === 'EL2' ? 'E' : group.key));
    const isLastRow = i === depts.length - 1;

    // Label de dept (eje Y)
    const lbl = document.createElement('div');
    lbl.className = 'gh';
    lbl.style.cssText = `text-align:left;padding:7px 10px;border-left:3px solid ${sh.color};${isLastRow ? 'border-bottom:none;' : ''}`;
    lbl.innerHTML = `<span class="dept-badge badge-${deptId}" style="font-size:11px">${deptId}</span>
      <br><span style="font-size:9px;color:#718096;font-weight:500;margin-top:2px;display:inline-block">${sh.time}</span>`;
    grid.appendChild(lbl);

    // Una celda por día
    for (let di = 0; di < DAYS.length; di++) {
      const day = DAYS[di];
      const cell = buildShiftDeptDayCell(deptId, day, sh);
      if (di === DAYS.length - 1) cell.style.borderRight = 'none';
      if (isLastRow) cell.style.borderBottom = 'none';
      grid.appendChild(cell);
    }
  }

  wrap.appendChild(grid);
  card.appendChild(wrap);
  return card;
}

// Celda de un (dept, día, turno) — muestra cada agente asignado como chip
// con nombre + hora, estilo Homebase. Click en celda = abrir modal de selección
// (reusa el modal "Por turno"). Click en × del chip = quitar agente.
function buildShiftDeptDayCell(deptId, day, sh) {
  const cell = document.createElement('div');
  cell.className = 'gcell' + (sh.id === 'E' ? ' gcell-E' : '');
  cell.style.minHeight = '52px';
  cell.style.flexDirection = 'column';
  cell.style.gap = '3px';
  cell.style.alignContent = 'stretch';

  const data = schedule[currentCycle][deptId][day][sh.id];

  for (const eid of data.emps) {
    const emp = EMPLOYEES.find(e => e.id === eid);
    if (!emp) continue;
    const isDimmed = filteredEmps.size > 0 && !filteredEmps.has(emp.id);
    const onDayOff = isOffDay(emp.id, day);

    const chip = document.createElement('div');
    chip.className = 'hb-chip' + (isDimmed ? ' dimmed' : '') + (onDayOff ? ' chip-warn' : '');
    chip.style.background = sh.color;
    chip.title = onDayOff
      ? `⚠ ${emp.name} tiene libre este día`
      : `${emp.name} · ${sh.time}`;
    chip.innerHTML = `
      <div class="hb-time">${sh.time}</div>
      <div class="hb-name">${emp.name}</div>
      <span class="hb-x" data-dept="${deptId}" data-day="${day}" data-shift="${sh.id}" data-emp="${eid}">×</span>`;
    chip.querySelector('.hb-x').addEventListener('click', e => {
      e.stopPropagation();
      removeEmp(deptId, day, sh.id, parseInt(e.target.dataset.emp));
    });
    cell.appendChild(chip);
  }

  if (data.note) {
    const nt = document.createElement('div');
    nt.className = 'chip-note';
    nt.textContent = data.note;
    cell.appendChild(nt);
  }

  const plus = document.createElement('div');
  plus.className = 'add-indicator';
  plus.textContent = '+';
  cell.appendChild(plus);

  cell.addEventListener('click', () => openModal(deptId, day, sh.id));
  return cell;
}

function buildShiftGroupCard(group, emps) {
  const card = document.createElement('div');
  card.className = 'dept-card';

  const hdr = document.createElement('div');
  hdr.className = 'dept-hdr';
  hdr.innerHTML = `
    <span class="dept-badge" style="background:${group.color};color:#fff">${group.hint}</span>
    <span class="dept-title">${group.label}</span>
    <span style="font-size:11px;color:#a0aec0;font-weight:600;margin-left:6px">${emps.length} agente${emps.length !== 1 ? 's' : ''}</span>`;
  card.appendChild(hdr);

  const wrap = document.createElement('div');
  wrap.className = 'grid-wrap';
  const grid = document.createElement('div');
  grid.className = 'agent-grid';
  grid.style.gridTemplateColumns = `140px repeat(${DAYS.length}, 1fr)`;

  // Cabecera: corner + días
  const corner = document.createElement('div');
  corner.className = 'gh';
  grid.appendChild(corner);
  for (const day of DAYS) {
    const h = document.createElement('div');
    h.className = 'gh';
    h.title = DAY_FULL[day];
    h.innerHTML = `<span style="font-size:14px;font-weight:800">${day}</span>
      <br><span style="font-size:9px;color:#a0aec0;font-weight:500">${DAY_FULL[day].slice(0,3)}</span>`;
    grid.appendChild(h);
  }

  // Sub-secciones por dept (L1, L2), cada una con sus agentes
  const subDepts = ['L1', 'L2'];
  // Calcular cuál es el último dept con agentes para no poner border-bottom en su última fila
  const deptHasEmps = {};
  for (const d of subDepts) deptHasEmps[d] = emps.filter(e => e.dept === d);
  const lastDeptWithEmps = subDepts.slice().reverse().find(d => deptHasEmps[d].length > 0);

  for (const deptId of subDepts) {
    const deptEmps = deptHasEmps[deptId];
    if (deptEmps.length === 0) continue;
    deptEmps.sort((a, b) => a.name.localeCompare(b.name, 'es'));

    // Sub-header: una fila que ocupa las 8 columnas (1 nombre + 7 días) usando grid-column span
    const subHdr = document.createElement('div');
    subHdr.className = 'subdept-hdr';
    subHdr.style.gridColumn = `1 / -1`;
    subHdr.innerHTML = `<span class="dept-badge badge-${deptId}" style="font-size:10px">${deptId}</span>
      <span style="font-size:11px;color:#4a5568;font-weight:700;margin-left:5px">${deptEmps.length} agente${deptEmps.length !== 1 ? 's' : ''}</span>`;
    grid.appendChild(subHdr);

    for (let ei = 0; ei < deptEmps.length; ei++) {
      const emp = deptEmps[ei];
      const isLastRowOfLastDept = (deptId === lastDeptWithEmps) && (ei === deptEmps.length - 1);
      const isDimmed = filteredEmps.size > 0 && !filteredEmps.has(emp.id);

      const nameCell = document.createElement('div');
      nameCell.className = 'agent-name-cell';
      if (isLastRowOfLastDept) nameCell.style.borderBottom = 'none';
      if (isDimmed) nameCell.style.opacity = '0.35';
      nameCell.innerHTML = `<div class="adot" style="background:${emp.color}"></div>
        <span class="aname">${emp.name}</span>`;
      grid.appendChild(nameCell);

      for (let di = 0; di < DAYS.length; di++) {
        const day = DAYS[di];
        const cell = buildAgentDayCell(emp, day);
        if (di === DAYS.length - 1) cell.style.borderRight = 'none';
        if (isLastRowOfLastDept) cell.style.borderBottom = 'none';
        if (isDimmed) cell.style.opacity = '0.35';
        grid.appendChild(cell);
      }
    }
  }

  wrap.appendChild(grid);
  card.appendChild(wrap);
  return card;
}

