<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
  <div class="mb-5">
    <div class="flex items-end justify-between gap-3 mb-3 flex-wrap">
      <div class="min-w-0">
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Horarios</h2>
        <p class="text-sm text-slate-500 mt-1">Vista mensual · resumen por dia</p>
      </div>
      <%- include('partials/viewSwitch', { view, currentDate }) %>
    </div>
    <div class="flex flex-wrap items-center gap-2 text-sm">
      <a href="/horarios?view=month&month=<%= prevMonth %>" class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card shrink-0">&larr;</a>
      <label class="relative flex-1 sm:flex-none min-w-0 px-3 py-1.5 font-medium capitalize bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card cursor-pointer inline-flex items-center gap-2"
             onclick="const i=this.querySelector('input');if(i.showPicker)i.showPicker();else i.focus();">
        <span class="pointer-events-none truncate"><%= monthLabel %></span>
        <span class="text-slate-300 text-xs pointer-events-none">📅</span>
        <input type="month" value="<%= monthParam %>"
               onchange="if(this.value) location.href='/horarios?view=month&month='+this.value"
               onclick="event.stopPropagation()"
               class="absolute right-2 top-1/2 -translate-y-1/2 w-1 h-1 opacity-0 pointer-events-none">
      </label>
      <a href="/horarios?view=month&month=<%= nextMonth %>" class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card shrink-0">&rarr;</a>
    </div>
  </div>

  <!-- Leyenda dept -->
  <div class="flex items-center gap-3 text-xs text-slate-500 mb-3">
    <div class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-blue-500 inline-block"></span> L1 (nativos)</div>
    <div class="flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-purple-500 inline-block"></span> L2 (nativos)</div>
    <span class="text-slate-300">·</span>
    <span>Conteo por dept nativo del agente, no por dept del turno. Click en un dia abre el detalle.</span>
  </div>

  <div class="bg-white rounded-lg border border-slate-200 shadow-card overflow-hidden">
    <div class="grid grid-cols-7 bg-slate-50 border-b border-slate-200 text-xs font-semibold text-slate-600">
      <% ['Lunes','Martes','Miercoles','Jueves','Viernes','Sabado','Domingo'].forEach((d, i) => { %>
        <div class="px-2 py-2 text-center <%= i >= 5 ? 'text-slate-400' : '' %>"><%= d %></div>
      <% }) %>
    </div>
    <% weeks.forEach(w => { %>
      <div class="grid grid-cols-7 border-b border-slate-100 last:border-b-0">
        <% w.forEach(c => { %>
          <a href="/horarios?view=day&date=<%= c.date %>"
             class="block min-h-[110px] p-2 border-r border-slate-100 last:border-r-0 transition-colors
            <%= c.inMonth ? 'bg-white hover:bg-blue-50/40' : 'bg-slate-50/40 text-slate-300' %>
            <%= c.isToday ? 'ring-2 ring-inset ring-yellow-400' : '' %>">
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-sm font-bold <%= c.isToday ? 'text-yellow-700' : c.inMonth ? 'text-slate-900' : 'text-slate-300' %>"><%= c.dayNum %></span>
              <% if (c.total > 0) { %>
                <span class="text-[10px] text-slate-400 font-medium"><%= c.total %></span>
              <% } %>
            </div>
            <% if (c.inMonth && c.total > 0) { %>
              <div class="space-y-1">
                <% c.depts.forEach(d => {
                  const isL1 = d.dept === 'L1';
                  const badgeBg = isL1 ? 'bg-blue-500' : (d.dept === 'L2' ? 'bg-purple-500' : 'bg-slate-500');
                  const txtCls = isL1 ? 'text-blue-700' : (d.dept === 'L2' ? 'text-purple-700' : 'text-slate-700');
                %>
                  <div class="flex items-center gap-1 text-[10px]">
                    <span class="px-1 rounded text-white <%= badgeBg %> font-bold"><%= d.dept %>·<%= d.total %></span>
                    <% d.shifts.forEach(sh => { %>
                      <span class="<%= txtCls %>"><%= sh.id %><span class="text-slate-400">·<%= sh.count %></span></span>
                    <% }) %>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </a>
        <% }) %>
      </div>
    <% }) %>
  </div>
</main>
<%- include('partials/foot') %>
