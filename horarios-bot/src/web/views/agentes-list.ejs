<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 py-6">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
    <div class="min-w-0">
      <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Agentes</h2>
      <p class="text-sm text-slate-500 mt-1"><%= agents.length %> agente<%= agents.length === 1 ? '' : 's' %><%= includeInactive ? ' · incluye inactivos' : '' %></p>
    </div>
    <div class="flex items-center gap-2 text-sm flex-wrap">
      <a href="/agentes<%= includeInactive ? '' : '?inactive=1' %>"
         class="px-3 py-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card text-slate-600 font-medium shrink-0">
        <%= includeInactive ? 'Solo activos' : 'Ver inactivos' %>
      </a>
      <a href="/agentes/nuevo" class="btn-primary inline-flex items-center gap-1 px-4 py-2 rounded-lg text-sm font-semibold shrink-0">
        <span class="text-base leading-none">+</span> Nuevo
      </a>
    </div>
  </div>

  <% if (agents.length === 0) { %>
    <div class="bg-white rounded-lg border border-slate-200 shadow-card p-8 text-center text-slate-400">Sin agentes</div>
  <% } else { %>
    <!-- Mobile cards -->
    <div class="md:hidden space-y-2">
      <% agents.forEach(a => { const bal = balanceByAgent[a.slack_id]; %>
        <a href="/agentes/<%= a.slack_id %>"
           class="block bg-white rounded-xl border border-slate-200 shadow-card p-3 hover:bg-slate-50 transition-colors <%= a.active ? '' : 'opacity-60' %>">
          <div class="flex items-start justify-between gap-2">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-semibold text-slate-900 text-sm"><%= a.name %></span>
                <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold tracking-wide
                  <% if (a.dept === 'L1') { %>bg-blue-100 text-blue-700
                  <% } else if (a.dept === 'L2') { %>bg-purple-100 text-purple-700
                  <% } else { %>bg-slate-100 text-slate-600<% } %>"><%= a.dept %></span>
                <% if (a.role === 'manager' || a.role === 'admin') { %>
                  <span class="text-[10px] uppercase font-bold <%= a.role === 'admin' ? 'text-rose-600' : 'text-violet-600' %>"><%= a.role %></span>
                <% } %>
              </div>
              <% if (a.position) { %><div class="text-xs text-slate-500 mt-0.5"><%= a.position %></div><% } %>
              <div class="text-[10px] text-slate-400 mt-0.5 font-mono"><%= a.slack_id %> · #<%= a.planner_id %></div>
            </div>
            <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold ring-1 shrink-0
              <%= a.active ? 'bg-emerald-50 text-emerald-700 ring-emerald-200' : 'bg-slate-100 text-slate-500 ring-slate-200' %>">
              <span class="w-1.5 h-1.5 rounded-full <%= a.active ? 'bg-emerald-500' : 'bg-slate-400' %>"></span>
              <%= a.active ? 'Activo' : 'Inactivo' %>
            </span>
          </div>
          <div class="flex flex-wrap gap-x-3 gap-y-1 mt-2 text-[11px] text-slate-600">
            <% if (a.email_company) { %><span>📧 <%= a.email_company %></span><% } %>
            <% if (a.phone) { %><span>📞 <%= a.phone %></span><% } %>
            <% if (a.start_date) { %><span class="text-slate-400">↗ <%= fmtDate(a.start_date) %></span><% } %>
            <% if (bal && bal.entitled !== null) { %>
              <span class="font-mono <%= bal.available <= 0 ? 'text-rose-700' : bal.available <= 3 ? 'text-amber-700' : 'text-emerald-700' %>">🌴 <%= bal.used %>/<%= bal.entitled %></span>
            <% } %>
          </div>
        </a>
      <% }) %>
    </div>

    <!-- Desktop table -->
    <div class="hidden md:block bg-white rounded-lg border border-slate-200 shadow-card overflow-x-auto">
      <table class="w-full text-sm" id="agentes-table">
        <thead class="bg-slate-50 border-b border-slate-200 text-xs">
          <tr>
            <th class="text-left px-3 py-2 font-medium text-slate-600">Nombre</th>
            <th class="text-left px-3 py-2 font-medium text-slate-600">Cargo</th>
            <th class="text-left px-3 py-2 font-medium text-slate-600">Dept</th>
            <% if (!isAdmin) { %>
              <th class="text-left px-3 py-2 font-medium text-slate-600">Email empresa</th>
              <th class="text-left px-3 py-2 font-medium text-slate-600">Telefono</th>
              <th class="text-left px-3 py-2 font-medium text-slate-600">Ingreso</th>
            <% } else { %>
              <th class="text-left px-3 py-2 font-medium text-slate-600">Ingreso</th>
              <th class="text-right px-3 py-2 font-medium text-slate-600">Sal. anterior</th>
              <th class="text-right px-3 py-2 font-medium text-slate-600">Salario</th>
              <th class="text-right px-3 py-2 font-medium text-slate-600">% aum</th>
              <th class="text-right px-3 py-2 font-medium text-slate-600">Sal. nuevo</th>
              <th class="text-right px-3 py-2 font-medium text-slate-600">Festivo</th>
              <th class="text-right px-3 py-2 font-medium text-slate-600">Ult ajuste</th>
              <th class="text-center px-3 py-2 font-medium text-slate-600"></th>
            <% } %>
            <th class="text-center px-3 py-2 font-medium text-slate-600" title="Saldo de vacaciones <%= balanceYear %>">Vac. <%= balanceYear %></th>
            <th class="text-left px-3 py-2 font-medium text-slate-600">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% agents.forEach(a => { %>
            <tr class="hover:bg-slate-50 <%= a.active ? '' : 'opacity-50' %>" data-slack-id="<%= a.slack_id %>">
              <td class="px-3 py-2">
                <a href="/agentes/<%= a.slack_id %>" class="font-medium text-slate-900 hover:underline"><%= a.name %></a>
                <div class="text-[10px] text-slate-400"><%= a.slack_id %> · #<%= a.planner_id %></div>
              </td>
              <td class="px-3 py-2 text-slate-700 text-xs"><%= a.position || '—' %></td>
              <td class="px-3 py-2 text-xs">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold
                  <% if (a.dept === 'L1') { %>bg-blue-100 text-blue-700
                  <% } else if (a.dept === 'L2') { %>bg-purple-100 text-purple-700
                  <% } else { %>bg-slate-100 text-slate-600<% } %>">
                  <%= a.dept %>
                </span>
                <% if (a.role === 'manager') { %>
                  <span class="ml-1 text-[10px] text-slate-500">manager</span>
                <% } %>
              </td>

              <% if (!isAdmin) { %>
                <td class="px-3 py-2 text-slate-600 text-xs"><%= a.email_company || '—' %></td>
                <td class="px-3 py-2 text-slate-600 text-xs"><%= a.phone || '—' %></td>
                <td class="px-3 py-2 text-slate-600 text-xs"><%= a.start_date ? fmtDate(a.start_date) : '—' %></td>
              <% } else { %>
                <!-- Fecha ingreso (read-only en la tabla; editable desde el detalle) -->
                <td class="px-3 py-2 text-slate-600 text-xs"><%= a.start_date ? fmtDate(a.start_date) : '—' %></td>
                <!-- Salario anterior (historico, read-only) -->
                <td class="px-3 py-2 text-right text-xs font-mono text-slate-500">
                  <%= a.salary_previous != null ? Number(a.salary_previous).toLocaleString() : '—' %>
                </td>
                <!-- Salario actual: inline editable, autosave -->
                <td class="px-2 py-1 text-right">
                  <input type="number" step="0.01"
                    class="w-24 text-right text-xs font-mono border border-slate-200 rounded px-2 py-1 inline-edit salary-input"
                    data-field="salary_current" value="<%= a.salary_current ?? '' %>" placeholder="—">
                </td>
                <!-- % aumento: live calc, applied via form -->
                <form method="post" action="/agentes/<%= a.slack_id %>/apply-raise" class="contents raise-form">
                  <td class="px-2 py-1 text-right">
                    <input type="number" step="0.01" name="pct"
                      class="w-16 text-right text-xs font-mono border border-slate-200 rounded px-2 py-1 pct-input"
                      placeholder="0">
                  </td>
                  <td class="px-2 py-1 text-right text-xs font-mono text-slate-700 sal-nuevo">—</td>
                  <td class="px-2 py-1 text-right text-xs font-mono text-slate-500 festivo">
                    <%= a.salary_current != null ? (a.salary_current / 23).toFixed(2) : '—' %>
                  </td>
                  <td class="px-2 py-1 text-right text-[10px] text-slate-500">
                    <% if (a.last_salary_adjustment_date) { %>
                      <%= fmtDate(a.last_salary_adjustment_date) %>
                      <% if (a.last_adjustment_pct != null) { %>
                        <div class="text-slate-400"><%= a.last_adjustment_pct %>%</div>
                      <% } %>
                    <% } else { %>—<% } %>
                  </td>
                  <td class="px-2 py-1 text-center">
                    <button class="text-[10px] px-2 py-1 bg-rose-600 text-white rounded hover:bg-rose-700 disabled:opacity-30 apply-btn" disabled>
                      Aplicar
                    </button>
                  </td>
                </form>
              <% } %>

              <td class="px-3 py-2 text-center">
                <% const bal = balanceByAgent[a.slack_id]; %>
                <% if (!bal || bal.entitled === null) { %>
                  <span class="text-[10px] text-slate-400 font-mono"><%= bal ? bal.used : 0 %><span class="text-slate-300">/—</span></span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-mono font-semibold ring-1
                    <% if (bal.available <= 0) { %>bg-rose-50 text-rose-700 ring-rose-200
                    <% } else if (bal.available <= 3) { %>bg-amber-50 text-amber-700 ring-amber-200
                    <% } else { %>bg-emerald-50 text-emerald-700 ring-emerald-200<% } %>"
                    title="Usados: <%= bal.used %> · Disponibles: <%= bal.available %> · Total: <%= bal.entitled %>">
                    <%= bal.used %>/<%= bal.entitled %>
                  </span>
                <% } %>
              </td>
              <td class="px-3 py-2 text-xs">
                <span class="pill inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-[10px] font-semibold ring-1
                  <%= a.active ? 'bg-emerald-50 text-emerald-700 ring-emerald-200' : 'bg-slate-100 text-slate-500 ring-slate-200' %>">
                  <span class="w-1.5 h-1.5 rounded-full <%= a.active ? 'bg-emerald-500' : 'bg-slate-400' %>"></span>
                  <%= a.active ? 'Activo' : 'Inactivo' %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (isAdmin) { %>
      <p class="text-xs text-slate-400 mt-3">
        Salario se guarda al salir del campo. % aumento muestra previa de salario nuevo y festivo (= salario / 23). Boton "Aplicar" guarda el aumento como historico (snapshot del salario anterior, fecha y %).
      </p>
    <% } %>
  <% } %>

  <% if (isAdmin) { %>
    <!-- Modal de confirmacion de aumento -->
    <div id="raise-modal" class="hidden fixed inset-0 z-50 bg-black/50 backdrop-blur-sm flex items-center justify-center px-4">
      <div class="bg-white rounded-xl shadow-xl max-w-md w-full p-6">
        <h3 class="text-lg font-semibold text-slate-900 mb-4">Aplicar aumento</h3>
        <p class="text-sm text-slate-600 mb-4">A <strong id="raise-name"></strong>:</p>
        <dl class="grid grid-cols-2 gap-y-2 text-sm bg-slate-50 rounded-lg p-4 mb-6">
          <dt class="text-slate-500">Salario actual</dt>
          <dd class="font-mono text-right text-slate-900" id="raise-current">—</dd>
          <dt class="text-slate-500">Aumento</dt>
          <dd class="font-mono text-right text-rose-700" id="raise-pct">—</dd>
          <dt class="text-slate-500">Salario nuevo</dt>
          <dd class="font-mono text-right text-rose-700 font-semibold" id="raise-new">—</dd>
          <dt class="text-slate-500">Festivo (= sal/23)</dt>
          <dd class="font-mono text-right text-slate-700" id="raise-holiday">—</dd>
        </dl>
        <div class="flex justify-end gap-2">
          <button type="button" id="raise-cancel"
            class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-100 rounded-lg">Cancelar</button>
          <button type="button" id="raise-confirm"
            class="px-4 py-2 text-sm bg-rose-600 text-white rounded-lg hover:bg-rose-700">Aplicar aumento</button>
        </div>
      </div>
    </div>

    <script>
      (() => {
        const HOLIDAY_DIVISOR = 23;
        const fmt = n => isFinite(n) ? n.toFixed(2) : '—';

        // Auto-save on blur for inline-edit fields
        document.querySelectorAll('input.inline-edit').forEach(inp => {
          let lastValue = inp.value;
          inp.addEventListener('blur', async () => {
            if (inp.value === lastValue) return;
            const row = inp.closest('tr');
            const slackId = row.dataset.slackId;
            const field = inp.dataset.field;
            try {
              const res = await fetch(`/agentes/${slackId}/inline-update`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ field, value: inp.value })
              });
              const data = await res.json();
              if (!data.ok) throw new Error(data.error || 'unknown');
              lastValue = inp.value;
              inp.classList.add('border-green-300');
              setTimeout(() => inp.classList.remove('border-green-300'), 800);
              if (field === 'salary_current') updateRowCalc(row);
            } catch (e) {
              inp.classList.add('border-red-400');
              window.appModal.alert({ title: 'Error al guardar', message: e.message, tone: 'danger' });
            }
          });
        });

        // Live calc when % changes
        function updateRowCalc(row) {
          const sal = parseFloat(row.querySelector('.salary-input').value);
          const pct = parseFloat(row.querySelector('.pct-input').value);
          const salNuevoEl = row.querySelector('.sal-nuevo');
          const festivoEl = row.querySelector('.festivo');
          const applyBtn = row.querySelector('.apply-btn');

          if (!isFinite(sal)) {
            salNuevoEl.textContent = '—';
            festivoEl.textContent = '—';
            applyBtn.disabled = true;
            return;
          }

          if (isFinite(pct) && pct !== 0) {
            const nuevo = sal * (1 + pct / 100);
            salNuevoEl.textContent = fmt(nuevo);
            salNuevoEl.classList.add('text-rose-700', 'font-semibold');
            festivoEl.textContent = fmt(nuevo / HOLIDAY_DIVISOR);
            applyBtn.disabled = false;
          } else {
            salNuevoEl.textContent = '—';
            salNuevoEl.classList.remove('text-rose-700', 'font-semibold');
            festivoEl.textContent = fmt(sal / HOLIDAY_DIVISOR);
            applyBtn.disabled = true;
          }
        }

        document.querySelectorAll('tr[data-slack-id]').forEach(row => {
          const pct = row.querySelector('.pct-input');
          const sal = row.querySelector('.salary-input');
          if (pct) pct.addEventListener('input', () => updateRowCalc(row));
          if (sal) sal.addEventListener('input', () => updateRowCalc(row));
        });

        // Custom confirmation modal for applying raise
        const modal = document.getElementById('raise-modal');
        const nameEl = document.getElementById('raise-name');
        const currentEl = document.getElementById('raise-current');
        const pctEl = document.getElementById('raise-pct');
        const newEl = document.getElementById('raise-new');
        const holidayEl = document.getElementById('raise-holiday');
        const confirmBtn = document.getElementById('raise-confirm');
        const cancelBtn = document.getElementById('raise-cancel');
        let pendingForm = null;

        const closeModal = () => {
          modal.classList.add('hidden');
          pendingForm = null;
        };
        cancelBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', e => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal(); });
        confirmBtn.addEventListener('click', () => {
          if (pendingForm) pendingForm.submit();
        });

        document.querySelectorAll('form.raise-form').forEach(form => {
          form.addEventListener('submit', e => {
            const row = form.closest('tr');
            const sal = parseFloat(row.querySelector('.salary-input').value);
            const pct = parseFloat(row.querySelector('.pct-input').value);
            if (!isFinite(sal) || !isFinite(pct) || pct === 0) return;
            e.preventDefault();
            const nuevo = sal * (1 + pct / 100);
            nameEl.textContent = row.querySelector('a').textContent.trim();
            currentEl.textContent = fmt(sal);
            pctEl.textContent = `+${pct}%`;
            newEl.textContent = fmt(nuevo);
            holidayEl.textContent = fmt(nuevo / HOLIDAY_DIVISOR);
            pendingForm = form;
            modal.classList.remove('hidden');
          });
        });
      })();
    </script>
  <% } %>
</main>
<%- include('partials/foot') %>
