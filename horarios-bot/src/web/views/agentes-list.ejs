<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<main class="max-w-7xl mx-auto px-4 py-6">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div>
      <h2 class="text-xl font-semibold text-gray-900">Agentes</h2>
      <p class="text-sm text-gray-500"><%= agents.length %> agente<%= agents.length === 1 ? '' : 's' %><%= includeInactive ? ' (incluye inactivos)' : '' %></p>
    </div>
    <div class="flex items-center gap-2 text-sm">
      <a href="/agentes<%= includeInactive ? '' : '?inactive=1' %>"
         class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50">
        <%= includeInactive ? 'Solo activos' : 'Ver inactivos' %>
      </a>
      <a href="/agentes/nuevo" class="bg-gray-900 text-white px-4 py-2 rounded-lg hover:bg-gray-800">+ Nuevo</a>
    </div>
  </div>

  <% if (agents.length === 0) { %>
    <div class="bg-white rounded-lg border border-gray-200 p-8 text-center text-gray-400">Sin agentes</div>
  <% } else { %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200 text-xs">
          <tr>
            <th class="text-left px-3 py-2 font-medium text-gray-600">Nombre</th>
            <th class="text-left px-3 py-2 font-medium text-gray-600">Cargo</th>
            <th class="text-left px-3 py-2 font-medium text-gray-600">Dept</th>
            <th class="text-left px-3 py-2 font-medium text-gray-600">Email empresa</th>
            <th class="text-left px-3 py-2 font-medium text-gray-600">Telefono</th>
            <th class="text-left px-3 py-2 font-medium text-gray-600">Ingreso</th>
            <% if (isAdmin) { %><th class="text-right px-3 py-2 font-medium text-gray-600">Salario</th><% } %>
            <th class="text-left px-3 py-2 font-medium text-gray-600">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% agents.forEach(a => { %>
            <tr class="hover:bg-gray-50 <%= a.active ? '' : 'opacity-50' %>">
              <td class="px-3 py-2">
                <a href="/agentes/<%= a.slack_id %>" class="font-medium text-gray-900 hover:underline"><%= a.name %></a>
                <div class="text-[10px] text-gray-400"><%= a.slack_id %> · #<%= a.planner_id %></div>
              </td>
              <td class="px-3 py-2 text-gray-700 text-xs"><%= a.position || '—' %></td>
              <td class="px-3 py-2 text-xs">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold
                  <%= a.dept === 'L1' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
                  <%= a.dept %>
                </span>
                <% if (a.role === 'manager') { %>
                  <span class="ml-1 text-[10px] text-gray-500">manager</span>
                <% } %>
              </td>
              <td class="px-3 py-2 text-gray-600 text-xs"><%= a.email_company || '—' %></td>
              <td class="px-3 py-2 text-gray-600 text-xs"><%= a.phone || '—' %></td>
              <td class="px-3 py-2 text-gray-600 text-xs"><%= a.start_date || '—' %></td>
              <% if (isAdmin) { %>
                <td class="px-3 py-2 text-right text-gray-700 text-xs font-mono">
                  <%= a.salary_current != null ? Number(a.salary_current).toLocaleString() : '—' %>
                </td>
              <% } %>
              <td class="px-3 py-2 text-xs">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px]
                  <%= a.active ? 'bg-green-100 text-green-700' : 'bg-gray-200 text-gray-500' %>">
                  <%= a.active ? 'Activo' : 'Inactivo' %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>
<%- include('partials/foot') %>
