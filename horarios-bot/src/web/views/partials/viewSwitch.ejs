<div class="inline-flex rounded-lg border border-gray-200 bg-white text-sm overflow-hidden">
  <a href="/horarios?view=day" class="px-3 py-1.5 <%= view === 'day' ? 'bg-gray-900 text-white' : 'text-gray-600 hover:bg-gray-50' %>">Dia</a>
  <a href="/horarios?view=week" class="px-3 py-1.5 border-l border-gray-200 <%= view === 'week' ? 'bg-gray-900 text-white' : 'text-gray-600 hover:bg-gray-50' %>">Semana</a>
  <a href="/horarios?view=month" class="px-3 py-1.5 border-l border-gray-200 <%= view === 'month' ? 'bg-gray-900 text-white' : 'text-gray-600 hover:bg-gray-50' %>">Mes</a>
</div>
