<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0f1825">
  <title>Horarios Support</title>
  <!-- Apply persisted sidebar + theme state ASAP to avoid flash -->
  <script>
    try {
      if (localStorage.getItem('sidebarCollapsed') === '1') {
        document.documentElement.classList.add('sidebar-collapsed');
      }
      var th = localStorage.getItem('theme');
      if (th === 'dark') document.documentElement.classList.add('dark');
    } catch(e) {}
  </script>
  <!-- PWA -->
  <link rel="manifest" href="/static/manifest.webmanifest">
  <link rel="icon" type="image/svg+xml" href="/static/icon.svg">
  <link rel="apple-touch-icon" href="/static/icon.svg">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Horarios">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', '-apple-system', 'Segoe UI', 'sans-serif']
          },
          colors: {
            ink: {
              50:  '#f5f7fa', 100: '#e9eef4', 200: '#cfd8e3', 300: '#a7b6c8',
              500: '#5b6f88', 700: '#2d3e54', 800: '#1f2c3d', 900: '#0f1825'
            }
          },
          boxShadow: {
            'card':       '0 1px 0 0 rgb(255 255 255 / 0.6) inset, 0 1px 2px 0 rgb(15 24 37 / 0.04), 0 1px 3px 0 rgb(15 24 37 / 0.05)',
            'card-hover': '0 1px 0 0 rgb(255 255 255 / 0.7) inset, 0 4px 8px -2px rgb(15 24 37 / 0.06), 0 2px 4px 0 rgb(15 24 37 / 0.05)',
            'chip':       '0 1px 0 0 rgb(255 255 255 / 0.8) inset, 0 1px 1px 0 rgb(15 24 37 / 0.08), 0 1px 2px 0 rgb(15 24 37 / 0.05)',
            'sidebar':    '1px 0 0 0 rgb(15 24 37 / 0.06), 4px 0 12px -8px rgb(15 24 37 / 0.06)'
          }
        }
      }
    }
  </script>
  <script src="https://unpkg.com/htmx.org@2.0.4"></script>
  <style>
    html { -webkit-text-size-adjust: 100%; overflow-x: hidden; }
    body { font-family: 'Inter', system-ui, -apple-system, sans-serif; font-feature-settings: 'cv11', 'ss01'; overflow-x: hidden; }
    .app-main { overflow-x: hidden; }
    *:focus-visible { outline: 2px solid #2d3e54; outline-offset: 2px; border-radius: 4px; }
    @media (max-width: 768px) {
      button, a.btn, [role="button"] { min-height: 40px; }
    }
    ::-webkit-scrollbar { width: 8px; height: 8px; }
    ::-webkit-scrollbar-thumb { background: #cfd8e3; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #a7b6c8; }
    ::-webkit-scrollbar-track { background: transparent; }

    /* Page background — subtle paper texture */
    body {
      background-color: #f5f7fa;
      background-image: radial-gradient(circle at 1px 1px, rgba(15,24,37,0.045) 1px, transparent 0);
      background-size: 22px 22px;
      background-attachment: fixed;
    }
    /* Card */
    .card {
      background: linear-gradient(to bottom, #ffffff 0%, #fafbfc 100%);
      border: 1px solid #e6eaf0;
      border-radius: 0.625rem;
      box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.6) inset, 0 1px 2px 0 rgb(15 24 37 / 0.04), 0 1px 3px 0 rgb(15 24 37 / 0.05);
    }
    /* Pill / chip with raised feel */
    .pill {
      box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.85) inset, 0 -1px 0 0 rgb(15 24 37 / 0.05) inset, 0 1px 1px 0 rgb(15 24 37 / 0.06);
      transition: transform .12s ease, box-shadow .12s ease;
    }
    .pill:hover {
      transform: translateY(-1px);
      box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.95) inset, 0 -1px 0 0 rgb(15 24 37 / 0.05) inset, 0 2px 3px 0 rgb(15 24 37 / 0.10);
    }
    /* Primary button — deep ink with depth */
    .btn-primary {
      background: linear-gradient(to bottom, #2d3e54 0%, #1f2c3d 100%);
      color: #fff;
      border: 1px solid #1f2c3d;
      box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.12) inset, 0 1px 2px 0 rgb(15 24 37 / 0.20), 0 1px 1px 0 rgb(15 24 37 / 0.10);
      transition: transform .1s ease, box-shadow .12s ease;
    }
    .btn-primary:hover {
      background: linear-gradient(to bottom, #34475f 0%, #2a3a4f 100%);
      box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.15) inset, 0 2px 4px 0 rgb(15 24 37 / 0.25);
    }
    .btn-primary:active { transform: translateY(1px); }

    /* ── App shell layout ─────────────────────────────────────────────── */
    .app-shell { min-height: 100vh; }
    .app-sidebar {
      width: 232px;
      position: fixed; top: 0; left: 0; bottom: 0;
      background: linear-gradient(to bottom, #ffffff 0%, #f8fafc 100%);
      border-right: 1px solid #e6eaf0;
      box-shadow: 1px 0 0 0 rgb(15 24 37 / 0.04), 4px 0 12px -8px rgb(15 24 37 / 0.05);
      display: flex; flex-direction: column;
      z-index: 30;
      transition: width 0.18s ease;
    }
    .app-main { margin-left: 232px; min-width: 0; display: flex; flex-direction: column; transition: margin-left 0.18s ease; }
    .nav-mobile-bar { display: none; }

    /* Collapsed sidebar (desktop only) — icon-only rail.
       Applied via html.sidebar-collapsed (set early to avoid FOUC). */
    @media (min-width: 769px) {
      html.sidebar-collapsed .app-sidebar { width: 60px; }
      html.sidebar-collapsed .app-main    { margin-left: 60px; }
      html.sidebar-collapsed .navlink     { justify-content: center; padding: 10px 0; gap: 0; }
      html.sidebar-collapsed .navlink-label,
      html.sidebar-collapsed .nav-section-label,
      html.sidebar-collapsed .brand-text,
      html.sidebar-collapsed .user-meta,
      html.sidebar-collapsed .user-logout-btn { display: none; }
      html.sidebar-collapsed .navlink-icon { font-size: 18px; }
      html.sidebar-collapsed .nav-brand    { justify-content: center; gap: 0; padding: 0; }
      html.sidebar-collapsed .user-block   { justify-content: center; padding: 6px 0; gap: 0; }
      html.sidebar-collapsed #navCollapseToggle { transform: rotate(180deg); }
    }

    /* Collapse toggle button — small chevron on the sidebar edge (desktop only) */
    #navCollapseToggle {
      display: none;
      position: absolute; top: 18px; right: -12px;
      width: 24px; height: 24px; border-radius: 50%;
      background: #ffffff; border: 1px solid #e6eaf0;
      align-items: center; justify-content: center;
      box-shadow: 0 1px 3px 0 rgb(15 24 37 / 0.10);
      color: #5b6f88; cursor: pointer; z-index: 31;
      transition: transform 0.18s ease, background 0.12s, color 0.12s;
      font-size: 11px;
    }
    #navCollapseToggle:hover { background: #f5f7fa; color: #1f2c3d; }
    @media (min-width: 769px) { #navCollapseToggle { display: flex; } }

    @media (max-width: 768px) {
      .app-sidebar {
        width: 280px; max-width: 85vw;
        transform: translateX(-100%);
        transition: transform 0.22s ease;
        box-shadow: 0 0 32px 0 rgb(15 24 37 / 0.30);
        z-index: 50;
      }
      .app-sidebar.open { transform: translateX(0); }
      .app-main { margin-left: 0; width: 100%; }
      #appOverlay { z-index: 40; }
      .nav-mobile-bar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 8px 14px; background: #ffffff; border-bottom: 1px solid #e6eaf0;
        position: sticky; top: 0; z-index: 20;
        box-shadow: 0 1px 2px 0 rgb(15 24 37 / 0.03);
      }
    }

    /* Sidebar nav links */
    .navlink {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 12px; border-radius: 8px;
      font-size: 14px; font-weight: 500; color: #5b6f88;
      transition: background .12s, color .12s, box-shadow .12s;
    }
    .navlink:hover { background: #f1f5f9; color: #1f2c3d; }
    .navlink.active {
      background: linear-gradient(to bottom, #2d3e54 0%, #1f2c3d 100%);
      color: #fff;
      box-shadow: 0 1px 0 0 rgb(255 255 255 / 0.10) inset, 0 1px 2px 0 rgb(15 24 37 / 0.20);
    }
    .navlink-icon { width: 18px; text-align: center; flex-shrink: 0; }

    /* ─── DARK MODE ───────────────────────────────────────────────────
       Blanket overrides on the most-used Tailwind utilities + custom
       components. Activated when <html class="dark">. Pragma: prefer
       semantic surface colors over inverting everything. */
    html.dark { color-scheme: dark; }
    html.dark body {
      background-color: #0f172a;
      background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.04) 1px, transparent 0);
      color: #e2e8f0;
    }
    html.dark ::-webkit-scrollbar-track { background: #1e293b; }
    html.dark ::-webkit-scrollbar-thumb { background: #475569; }
    html.dark ::-webkit-scrollbar-thumb:hover { background: #64748b; }

    /* Surfaces: white → slate-800; cards/sections */
    html.dark .bg-white               { background-color: #1e293b !important; }
    html.dark .bg-white\/60           { background-color: rgba(30, 41, 59, 0.6) !important; }
    html.dark .bg-slate-50            { background-color: #1e293b !important; }
    html.dark .bg-slate-50\/40        { background-color: rgba(30, 41, 59, 0.4) !important; }
    html.dark .bg-slate-50\/50        { background-color: rgba(30, 41, 59, 0.5) !important; }
    html.dark .bg-slate-50\/60        { background-color: rgba(30, 41, 59, 0.6) !important; }
    html.dark .bg-slate-100           { background-color: #334155 !important; }
    html.dark .hover\:bg-slate-50:hover  { background-color: #334155 !important; }
    html.dark .hover\:bg-slate-100:hover { background-color: #475569 !important; }
    html.dark .hover\:bg-slate-50\/60:hover { background-color: rgba(51, 65, 85, 0.6) !important; }

    /* Text colors */
    html.dark .text-slate-900 { color: #f1f5f9 !important; }
    html.dark .text-slate-800 { color: #e2e8f0 !important; }
    html.dark .text-slate-700 { color: #cbd5e1 !important; }
    html.dark .text-slate-600 { color: #94a3b8 !important; }
    html.dark .text-slate-500 { color: #94a3b8 !important; }
    html.dark .text-slate-400 { color: #64748b !important; }
    html.dark .text-slate-300 { color: #475569 !important; }
    html.dark .text-gray-800  { color: #e2e8f0 !important; }
    html.dark .text-gray-700  { color: #cbd5e1 !important; }
    html.dark .hover\:text-slate-900:hover { color: #f1f5f9 !important; }
    html.dark .hover\:text-slate-800:hover { color: #e2e8f0 !important; }
    html.dark .hover\:text-slate-600:hover { color: #94a3b8 !important; }

    /* Borders & rings */
    html.dark .border-slate-100 { border-color: #334155 !important; }
    html.dark .border-slate-200 { border-color: #334155 !important; }
    html.dark .border-slate-300 { border-color: #475569 !important; }
    html.dark .ring-slate-200   { --tw-ring-color: #334155 !important; }
    html.dark .divide-slate-50  > :not([hidden]) ~ :not([hidden]) { border-color: #334155 !important; }
    html.dark .divide-slate-100 > :not([hidden]) ~ :not([hidden]) { border-color: #334155 !important; }

    /* Form inputs */
    html.dark input, html.dark select, html.dark textarea {
      background-color: #0f172a; color: #e2e8f0; border-color: #334155;
    }
    html.dark input::placeholder, html.dark textarea::placeholder { color: #64748b; }
    html.dark input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.7); }

    /* Code / details */
    html.dark code, html.dark pre { background-color: #0f172a !important; color: #cbd5e1 !important; }

    /* App shell components */
    html.dark .app-sidebar {
      background: linear-gradient(to bottom, #1e293b 0%, #0f172a 100%);
      border-right-color: #334155;
    }
    html.dark .nav-mobile-bar { background: #1e293b; border-bottom-color: #334155; }
    html.dark .navlink { color: #94a3b8; }
    html.dark .navlink:hover { background: #334155; color: #f1f5f9; }
    html.dark .navlink.active {
      background: linear-gradient(to bottom, #475569 0%, #334155 100%);
      color: #ffffff;
    }
    html.dark #navCollapseToggle {
      background: #1e293b; border-color: #334155; color: #94a3b8;
    }
    html.dark #navCollapseToggle:hover { background: #334155; color: #f1f5f9; }
    html.dark .card, html.dark .pill {
      background: #1e293b;
    }
    html.dark .shadow-card, html.dark .shadow-card-hover {
      box-shadow: 0 1px 0 0 rgba(255,255,255,0.04) inset, 0 1px 2px 0 rgba(0,0,0,0.3), 0 1px 3px 0 rgba(0,0,0,0.4);
    }
    html.dark .btn-primary {
      background: linear-gradient(to bottom, #475569 0%, #334155 100%);
    }
    html.dark .btn-primary:hover {
      background: linear-gradient(to bottom, #64748b 0%, #475569 100%);
    }

    /* Pills with light tints — soften in dark to keep contrast */
    html.dark .bg-emerald-50 { background-color: rgba(16, 185, 129, 0.15) !important; }
    html.dark .bg-rose-50    { background-color: rgba(244, 63, 94, 0.15) !important; }
    html.dark .bg-amber-50   { background-color: rgba(245, 158, 11, 0.15) !important; }
    html.dark .bg-sky-50     { background-color: rgba(14, 165, 233, 0.15) !important; }
    html.dark .bg-blue-50    { background-color: rgba(59, 130, 246, 0.15) !important; }
    html.dark .bg-violet-50  { background-color: rgba(139, 92, 246, 0.15) !important; }
    html.dark .bg-cyan-50    { background-color: rgba(6, 182, 212, 0.15) !important; }
    html.dark .bg-lime-50    { background-color: rgba(132, 204, 22, 0.15) !important; }
    html.dark .bg-orange-50  { background-color: rgba(249, 115, 22, 0.15) !important; }
    html.dark .bg-pink-50    { background-color: rgba(236, 72, 153, 0.15) !important; }
    html.dark .bg-yellow-50  { background-color: rgba(234, 179, 8, 0.12) !important; }
    html.dark .bg-yellow-50\/40 { background-color: rgba(234, 179, 8, 0.10) !important; }
    html.dark .bg-yellow-50\/50 { background-color: rgba(234, 179, 8, 0.12) !important; }
    html.dark .bg-yellow-100 { background-color: rgba(234, 179, 8, 0.20) !important; }
    html.dark .text-yellow-700 { color: #facc15 !important; }
    html.dark .text-yellow-800 { color: #fde047 !important; }
    html.dark .ring-yellow-300 { --tw-ring-color: rgba(234, 179, 8, 0.5) !important; }
    html.dark .ring-yellow-400 { --tw-ring-color: #eab308 !important; }
    /* Agent chips (bg-X-100 + text-X-800 + ring-X-300). Use semi-transparent
       fill + bright text + visible ring so chips read clearly on dark bg. */
    html.dark .bg-emerald-100  { background-color: rgba(16, 185, 129, 0.18) !important; }
    html.dark .bg-blue-100     { background-color: rgba(59, 130, 246, 0.18) !important; }
    html.dark .bg-rose-100     { background-color: rgba(244, 63, 94, 0.18) !important; }
    html.dark .bg-amber-100    { background-color: rgba(245, 158, 11, 0.18) !important; }
    html.dark .bg-purple-100   { background-color: rgba(168, 85, 247, 0.18) !important; }
    html.dark .bg-cyan-100     { background-color: rgba(6, 182, 212, 0.18) !important; }
    html.dark .bg-pink-100     { background-color: rgba(236, 72, 153, 0.18) !important; }
    html.dark .bg-lime-100     { background-color: rgba(132, 204, 22, 0.20) !important; }
    html.dark .bg-orange-100   { background-color: rgba(249, 115, 22, 0.20) !important; }
    html.dark .bg-teal-100     { background-color: rgba(20, 184, 166, 0.20) !important; }
    html.dark .bg-violet-100   { background-color: rgba(139, 92, 246, 0.20) !important; }
    html.dark .bg-fuchsia-100  { background-color: rgba(217, 70, 239, 0.20) !important; }
    html.dark .bg-sky-100      { background-color: rgba(14, 165, 233, 0.18) !important; }

    /* Chip text colors (X-800 → bright variants) */
    html.dark .text-emerald-800  { color: #6ee7b7 !important; }
    html.dark .text-blue-800     { color: #93c5fd !important; }
    html.dark .text-rose-800     { color: #fda4af !important; }
    html.dark .text-amber-800    { color: #fcd34d !important; }
    html.dark .text-purple-800   { color: #d8b4fe !important; }
    html.dark .text-cyan-800     { color: #67e8f9 !important; }
    html.dark .text-pink-800     { color: #f9a8d4 !important; }
    html.dark .text-lime-800     { color: #bef264 !important; }
    html.dark .text-orange-800   { color: #fdba74 !important; }
    html.dark .text-teal-800     { color: #5eead4 !important; }
    html.dark .text-violet-800   { color: #c4b5fd !important; }
    html.dark .text-fuchsia-800  { color: #f0abfc !important; }
    html.dark .text-sky-800      { color: #7dd3fc !important; }
    html.dark .text-blue-900, html.dark .text-amber-900 { color: #f1f5f9 !important; }

    /* Chip rings — keep them visible at the right hue */
    html.dark .ring-emerald-300  { --tw-ring-color: rgba(110, 231, 183, 0.5) !important; }
    html.dark .ring-blue-300     { --tw-ring-color: rgba(147, 197, 253, 0.5) !important; }
    html.dark .ring-rose-300     { --tw-ring-color: rgba(253, 164, 175, 0.5) !important; }
    html.dark .ring-amber-300    { --tw-ring-color: rgba(252, 211, 77, 0.5) !important; }
    html.dark .ring-purple-300   { --tw-ring-color: rgba(216, 180, 254, 0.5) !important; }
    html.dark .ring-cyan-300     { --tw-ring-color: rgba(103, 232, 249, 0.5) !important; }
    html.dark .ring-pink-300     { --tw-ring-color: rgba(249, 168, 212, 0.5) !important; }
    html.dark .ring-lime-300     { --tw-ring-color: rgba(190, 242, 100, 0.5) !important; }
    html.dark .ring-orange-300   { --tw-ring-color: rgba(253, 186, 116, 0.5) !important; }
    html.dark .ring-teal-300     { --tw-ring-color: rgba(94, 234, 212, 0.5) !important; }
    html.dark .ring-violet-300   { --tw-ring-color: rgba(196, 181, 253, 0.5) !important; }
    html.dark .ring-fuchsia-300  { --tw-ring-color: rgba(240, 171, 252, 0.5) !important; }

    /* Ink palette (custom brand color) — invert for dark */
    html.dark .text-ink-800   { color: #f1f5f9 !important; }
    html.dark .text-ink-700   { color: #cbd5e1 !important; }
    html.dark .border-ink-800 { border-color: #f1f5f9 !important; }
    html.dark .bg-ink-800     { background-color: #475569 !important; }
    html.dark .bg-ink-700     { background-color: #334155 !important; }
    html.dark .hover\:bg-ink-700:hover { background-color: #475569 !important; }

    /* Strong text colors stay strong but a tad brighter */
    html.dark .text-emerald-700 { color: #4ade80 !important; }
    html.dark .text-emerald-800 { color: #34d399 !important; }
    html.dark .text-rose-600    { color: #fb7185 !important; }
    html.dark .text-rose-700    { color: #fb7185 !important; }
    html.dark .text-rose-800    { color: #fda4af !important; }
    html.dark .text-amber-600   { color: #fbbf24 !important; }
    html.dark .text-amber-700   { color: #fbbf24 !important; }
    html.dark .text-amber-800   { color: #fcd34d !important; }
    html.dark .text-sky-700     { color: #38bdf8 !important; }
    html.dark .text-sky-800     { color: #7dd3fc !important; }
    html.dark .text-blue-700    { color: #60a5fa !important; }
    html.dark .text-violet-600  { color: #a78bfa !important; }
    html.dark .text-violet-700  { color: #a78bfa !important; }
    html.dark .text-cyan-700    { color: #22d3ee !important; }
    html.dark .text-pink-600    { color: #f472b6 !important; }
    html.dark .text-orange-700  { color: #fb923c !important; }
    html.dark .text-lime-700    { color: #a3e635 !important; }
    html.dark .text-purple-700  { color: #c084fc !important; }

    /* Modal backdrop already uses ink-900; bump alpha a bit */
    html.dark #appModalBackdrop, html.dark #tzPickerModal > div:first-child {
      background-color: rgba(0, 0, 0, 0.65);
    }
  </style>
</head>
<body class="text-slate-900 antialiased">
<div class="app-shell">
