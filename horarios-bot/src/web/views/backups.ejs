<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<%
  function fmtSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(0) + ' KB';
    return (bytes / 1024 / 1024).toFixed(1) + ' MB';
  }
%>

<main class="max-w-4xl mx-auto px-4 sm:px-6 py-6">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
    <div class="min-w-0">
      <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Backups</h2>
      <p class="text-sm text-slate-500 mt-1">Backups diarios automáticos · 03:00 UTC · retención <%= retentionDays %> días</p>
    </div>
    <form method="post" action="/backups/run" class="self-start sm:self-auto">
      <button type="submit" class="btn-primary inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold">
        <span>💾</span> Ejecutar backup ahora
      </button>
    </form>
  </div>

  <% if (flash) { %>
    <div class="mb-4 px-4 py-2 rounded-lg text-sm <%= flash.type === 'ok' ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200' : 'bg-rose-50 text-rose-700 ring-1 ring-rose-200' %>">
      <%= flash.text %>
    </div>
  <% } %>

  <% if (backups.length === 0) { %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-card p-12 text-center">
      <div class="text-4xl mb-2 opacity-30">📦</div>
      <p class="text-sm text-slate-400">Sin backups aún. Ejecuta uno manual o espera al cron de las 03:00 UTC.</p>
    </div>
  <% } else { %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200 text-xs">
          <tr>
            <th class="text-left px-4 py-2 font-medium text-slate-600">Fecha</th>
            <th class="text-left px-4 py-2 font-medium text-slate-600">Archivo</th>
            <th class="text-right px-4 py-2 font-medium text-slate-600">Tamaño</th>
            <th class="text-right px-4 py-2 font-medium text-slate-600">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% backups.forEach(b => { %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-2 font-mono text-slate-700"><%= b.date %></td>
              <td class="px-4 py-2 font-mono text-xs text-slate-500"><%= b.name %></td>
              <td class="px-4 py-2 text-right font-mono text-slate-600"><%= fmtSize(b.sizeBytes) %></td>
              <td class="px-4 py-2 text-right">
                <a href="/backups/download/<%= b.name %>"
                   class="inline-flex items-center gap-1 px-3 py-1 text-xs bg-ink-800 hover:bg-ink-700 text-white rounded-md font-semibold">
                  Descargar
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <p class="text-xs text-slate-400 mt-3">
      <%= backups.length %> backup<%= backups.length === 1 ? '' : 's' %> · El más antiguo se borra cuando supera <%= retentionDays %> días.
      Configura la retención en <a href="/settings" class="text-slate-500 hover:underline">/settings</a>.
    </p>
  <% } %>
</main>
<%- include('partials/foot') %>
