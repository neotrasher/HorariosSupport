<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<%
  const statusStyle = (s) => {
    if (s === 'pending')   return 'bg-amber-50 text-amber-800 ring-amber-200';
    if (s === 'approved')  return 'bg-emerald-50 text-emerald-800 ring-emerald-200';
    if (s === 'rejected')  return 'bg-rose-50 text-rose-800 ring-rose-200';
    return 'bg-slate-100 text-slate-600 ring-slate-200';
  };
  const statusDot = (s) => {
    if (s === 'pending')   return 'bg-amber-500';
    if (s === 'approved')  return 'bg-emerald-500';
    if (s === 'rejected')  return 'bg-rose-500';
    return 'bg-slate-400';
  };
  // Map swap-specific statuses to {label, badge style, dot}
  const swapStatusInfo = (s) => {
    switch (s) {
      case 'pending_partner':   return { label: 'Esperando compañero',  cls: 'bg-amber-50 text-amber-800 ring-amber-200',     dot: 'bg-amber-500' };
      case 'pending_approval':  return { label: 'Esperando manager',    cls: 'bg-sky-50 text-sky-800 ring-sky-200',           dot: 'bg-sky-500' };
      case 'approved':          return { label: 'Aprobado',             cls: 'bg-emerald-50 text-emerald-800 ring-emerald-200', dot: 'bg-emerald-500' };
      case 'rejected_partner':  return { label: 'Rechazado por compañero', cls: 'bg-rose-50 text-rose-800 ring-rose-200',     dot: 'bg-rose-500' };
      case 'rejected_approver': return { label: 'Rechazado por manager', cls: 'bg-rose-50 text-rose-800 ring-rose-200',       dot: 'bg-rose-500' };
      case 'cancelled':         return { label: 'Cancelado',            cls: 'bg-slate-100 text-slate-600 ring-slate-200',    dot: 'bg-slate-400' };
      default:                  return { label: s,                      cls: 'bg-slate-100 text-slate-600 ring-slate-200',    dot: 'bg-slate-400' };
    }
  };
%>

<main class="max-w-6xl mx-auto px-4 sm:px-6 py-6">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
    <div class="min-w-0">
      <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Solicitudes</h2>
      <% if (isManager && pendingCount > 0) { %>
        <p class="text-sm text-amber-600 mt-1">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-amber-500 align-middle"></span>
          <%= pendingCount %> pendiente<%= pendingCount === 1 ? '' : 's' %> de revision
        </p>
      <% } else { %>
        <p class="text-sm text-slate-500 mt-1">Vacaciones y permisos del equipo</p>
      <% } %>
    </div>
    <a href="/solicitudes/nueva" class="btn-primary inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-semibold self-start sm:self-auto shrink-0">
      <span class="text-base leading-none">+</span> Nueva solicitud
    </a>
  </div>

  <!-- Tabs: tiempo libre / cambios de turnos -->
  <div class="flex items-center gap-1 mb-5 border-b border-slate-200">
    <a href="/solicitudes"
       class="px-4 py-2 text-sm font-semibold border-b-2 -mb-px transition-colors flex items-center gap-2
              <%= view === 'timeoff' ? 'border-ink-800 text-ink-800' : 'border-transparent text-slate-500 hover:text-slate-800' %>">
      📅 Permisos y vacaciones
      <% if (isManager && pendingCount > 0) { %>
        <span class="inline-flex items-center justify-center px-1.5 py-0.5 text-[10px] font-bold rounded-full bg-amber-100 text-amber-700"><%= pendingCount %></span>
      <% } %>
    </a>
    <a href="/solicitudes?view=swaps"
       class="px-4 py-2 text-sm font-semibold border-b-2 -mb-px transition-colors flex items-center gap-2
              <%= view === 'swaps' ? 'border-ink-800 text-ink-800' : 'border-transparent text-slate-500 hover:text-slate-800' %>">
      ↔ Cambios de turnos
      <% if (isManager && pendingSwapsCount > 0) { %>
        <span class="inline-flex items-center justify-center px-1.5 py-0.5 text-[10px] font-bold rounded-full bg-sky-100 text-sky-700"><%= pendingSwapsCount %></span>
      <% } %>
    </a>
  </div>

  <% if (view === 'swaps') { %>
    <!-- Swap filters -->
    <% if (isManager) {
         function buildSwapQs(overrides) {
           const params = { view: 'swaps', status: filterStatus, agent: filterAgent, from: filterFrom, to: filterTo, ...overrides };
           const parts = Object.entries(params)
             .filter(([k, v]) => v !== '' && v !== undefined && v !== null)
             .map(([k, v]) => `${k}=${encodeURIComponent(v)}`);
           return parts.length ? '?' + parts.join('&') : '';
         }
    %>
      <div class="flex flex-col gap-3 mb-5 text-sm">
        <div class="flex flex-col sm:flex-row sm:items-center gap-2">
          <div class="flex items-center gap-2 flex-wrap">
            <span class="text-slate-500 shrink-0">Estado:</span>
            <% const swFilters = [['','Todos'],['pending_partner','Esperando comp.'],['pending_approval','Esperando mgr.'],['approved','Aprobados'],['rejected_partner','Rech. comp.'],['rejected_approver','Rech. mgr.'],['cancelled','Cancelados']] %>
            <% swFilters.forEach(([val, lbl]) => { %>
              <a href="/solicitudes<%= buildSwapQs({ status: val }) %>"
                 class="px-3 py-1.5 rounded-full text-xs font-semibold whitespace-nowrap <%= filterStatus === val ? 'bg-ink-800 text-white shadow-card' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
                <%= lbl %>
              </a>
            <% }) %>
          </div>
          <div class="flex items-center gap-2 sm:ml-auto">
            <label class="text-slate-500 shrink-0 text-xs">Agente:</label>
            <form method="get" action="/solicitudes" class="flex items-center gap-1">
              <input type="hidden" name="view" value="swaps">
              <input type="hidden" name="status" value="<%= filterStatus %>">
              <input type="hidden" name="from" value="<%= filterFrom %>">
              <input type="hidden" name="to" value="<%= filterTo %>">
              <select name="agent" onchange="this.form.submit()"
                      class="text-xs border border-slate-300 rounded-lg px-2 py-1.5 bg-white">
                <option value="">Todos</option>
                <% agentOptions.forEach(a => { %>
                  <option value="<%= a.slack_id %>" <%= filterAgent === a.slack_id ? 'selected' : '' %>><%= a.name %></option>
                <% }) %>
              </select>
            </form>
            <% if (filterAgent) { %>
              <a href="/solicitudes<%= buildSwapQs({ agent: '' }) %>" class="text-xs text-slate-500 hover:text-rose-600" title="Quitar filtro">×</a>
            <% } %>
          </div>
        </div>
        <!-- Date range filter for swaps -->
        <form method="get" action="/solicitudes" class="flex flex-wrap items-center gap-2">
          <input type="hidden" name="view" value="swaps">
          <input type="hidden" name="status" value="<%= filterStatus %>">
          <input type="hidden" name="agent" value="<%= filterAgent %>">
          <span class="text-slate-500 shrink-0 text-xs">Fechas:</span>
          <input type="date" name="from" value="<%= filterFrom %>"
                 class="text-xs border border-slate-300 rounded-lg px-2 py-1.5 bg-white" title="Desde (inclusive)">
          <span class="text-slate-400 text-xs">→</span>
          <input type="date" name="to" value="<%= filterTo %>"
                 class="text-xs border border-slate-300 rounded-lg px-2 py-1.5 bg-white" title="Hasta (inclusive)">
          <button type="submit" class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-ink-800 text-white shadow-card hover:bg-ink-900">Aplicar</button>
          <% if (filterFrom || filterTo) { %>
            <a href="/solicitudes<%= buildSwapQs({ from: '', to: '' }) %>"
               class="text-xs text-slate-500 hover:text-rose-600 px-2 py-1.5" title="Quitar rango">× limpiar</a>
          <% } %>
          <span class="text-slate-300 text-xs mx-1 hidden sm:inline">·</span>
          <% const today2 = new Date(); const fmt2 = d => d.toISOString().slice(0,10);
             const startMonth2 = fmt2(new Date(today2.getFullYear(), today2.getMonth(), 1));
             const endMonth2 = fmt2(new Date(today2.getFullYear(), today2.getMonth() + 1, 0));
             const startNextMonth2 = fmt2(new Date(today2.getFullYear(), today2.getMonth() + 1, 1));
             const endNextMonth2 = fmt2(new Date(today2.getFullYear(), today2.getMonth() + 2, 0));
             const startYear2 = `${today2.getFullYear()}-01-01`;
             const endYear2 = `${today2.getFullYear()}-12-31`;
          %>
          <a href="/solicitudes<%= buildSwapQs({ from: startMonth2, to: endMonth2 }) %>"
             class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600 hover:bg-slate-200">Este mes</a>
          <a href="/solicitudes<%= buildSwapQs({ from: startNextMonth2, to: endNextMonth2 }) %>"
             class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600 hover:bg-slate-200">Próximo mes</a>
          <a href="/solicitudes<%= buildSwapQs({ from: startYear2, to: endYear2 }) %>"
             class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600 hover:bg-slate-200"><%= today2.getFullYear() %></a>
        </form>
      </div>
    <% } %>

    <% if (swaps.length === 0) { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-card p-12 text-center">
        <div class="text-4xl mb-2 opacity-30">↔</div>
        <p class="text-sm text-slate-400">Sin cambios de turnos</p>
        <p class="text-xs text-slate-400 mt-1">Los swaps se piden desde Slack con <code class="bg-slate-100 px-1.5 py-0.5 rounded">/horario-swap</code></p>
      </div>
    <% } else { %>
      <!-- Desktop: tabla -->
      <div class="hidden md:block bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-slate-50/60 border-b border-slate-200 text-xs uppercase tracking-wider">
            <tr>
              <th class="text-left px-4 py-3 font-semibold text-slate-500">Solicitante</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Su turno</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Compañero</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Su turno</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Estado</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Creado</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% swaps.forEach(s => { const si = swapStatusInfo(s.status); %>
              <tr class="hover:bg-slate-50/60">
                <td class="px-4 py-3 font-medium text-slate-900"><%= s.requesterName %></td>
                <td class="px-3 py-3 text-xs">
                  <div class="font-mono text-slate-700"><%= fmtDate(s.requester_date) %></div>
                  <div class="text-slate-500 mt-0.5"><%= s.requesterSnapshotLabel %></div>
                </td>
                <td class="px-3 py-3 font-medium text-slate-900"><%= s.partnerName %></td>
                <td class="px-3 py-3 text-xs">
                  <div class="font-mono text-slate-700"><%= fmtDate(s.partner_date) %></div>
                  <div class="text-slate-500 mt-0.5"><%= s.partnerSnapshotLabel %></div>
                </td>
                <td class="px-3 py-3">
                  <span class="pill inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= si.cls %>">
                    <span class="w-1.5 h-1.5 rounded-full <%= si.dot %>"></span>
                    <%= si.label %>
                  </span>
                  <% if (s.approverName && (s.status === 'approved' || s.status === 'rejected_approver')) { %>
                    <div class="text-[10px] text-slate-500 mt-1" title="<%= s.approvalAtLocal ? fmtDateTime(s.approvalAtLocal) : '' %>">
                      por <span class="font-semibold text-slate-700"><%= s.approverName %></span>
                    </div>
                  <% } %>
                  <% if (s.note) { %>
                    <div class="text-[10px] text-slate-400 mt-1 max-w-xs truncate" title="<%= s.note %>">📝 <%= s.note %></div>
                  <% } %>
                  <% if (s.rejection_reason) { %>
                    <div class="text-[10px] text-rose-500 mt-1 max-w-xs truncate" title="<%= s.rejection_reason %>">✗ <%= s.rejection_reason %></div>
                  <% } %>
                </td>
                <td class="px-3 py-3 text-slate-500 text-xs"><%= fmtDateTime(s.createdLocal) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile: cards -->
      <div class="md:hidden space-y-2">
        <% swaps.forEach(s => { const si = swapStatusInfo(s.status); %>
          <div class="bg-white rounded-xl border border-slate-200 shadow-card p-3">
            <div class="flex items-center justify-between gap-2 mb-2 flex-wrap">
              <span class="pill inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= si.cls %>">
                <span class="w-1.5 h-1.5 rounded-full <%= si.dot %>"></span>
                <%= si.label %>
              </span>
              <% if (s.approverName && (s.status === 'approved' || s.status === 'rejected_approver')) { %>
                <span class="text-[10px] text-slate-500">por <span class="font-semibold text-slate-700"><%= s.approverName %></span></span>
              <% } %>
              <span class="text-[10px] text-slate-400 ml-auto"><%= fmtDateTime(s.createdLocal) %></span>
            </div>
            <div class="text-xs space-y-2">
              <div>
                <div class="font-semibold text-slate-900"><%= s.requesterName %></div>
                <div class="text-slate-600"><span class="font-mono"><%= fmtDate(s.requester_date) %></span> · <%= s.requesterSnapshotLabel %></div>
              </div>
              <div class="text-center text-slate-400">↔</div>
              <div>
                <div class="font-semibold text-slate-900"><%= s.partnerName %></div>
                <div class="text-slate-600"><span class="font-mono"><%= fmtDate(s.partner_date) %></span> · <%= s.partnerSnapshotLabel %></div>
              </div>
            </div>
            <% if (s.note) { %>
              <div class="text-[11px] text-slate-500 mt-2 pt-2 border-t border-slate-100">📝 <%= s.note %></div>
            <% } %>
            <% if (s.rejection_reason) { %>
              <div class="text-[11px] text-rose-600 mt-2 pt-2 border-t border-slate-100">✗ <%= s.rejection_reason %></div>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
    <p class="text-xs text-slate-400 mt-4">
      Los cambios de turno se inician desde Slack con <code class="bg-slate-100 px-1.5 py-0.5 rounded">/horario-swap</code>.
      Solo se aprueban cuando el compañero acepta y luego un manager confirma.
    </p>
  <% } else { %>

  <% if (isManager) {
       // Helper: build a query string preserving other active filters
       function buildQs(overrides) {
         const params = { status: filterStatus, agent: filterAgent, from: filterFrom, to: filterTo, ...overrides };
         const parts = Object.entries(params)
           .filter(([k, v]) => v !== '' && v !== undefined && v !== null)
           .map(([k, v]) => `${k}=${encodeURIComponent(v)}`);
         return parts.length ? '?' + parts.join('&') : '';
       }
  %>
    <div class="flex flex-col gap-3 mb-5 text-sm">
      <div class="flex flex-col sm:flex-row sm:items-center gap-2">
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-slate-500 shrink-0">Estado:</span>
          <% const filters = [['','Todas'],['pending','Pendientes'],['approved','Aprobadas'],['rejected','Rechazadas'],['cancelled','Canceladas']] %>
          <% filters.forEach(([val, lbl]) => { %>
            <a href="/solicitudes<%= buildQs({ status: val }) %>"
               class="px-3 py-1.5 rounded-full text-xs font-semibold whitespace-nowrap <%= filterStatus === val ? 'bg-ink-800 text-white shadow-card' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
              <%= lbl %>
            </a>
          <% }) %>
        </div>
        <div class="flex items-center gap-2 sm:ml-auto">
          <label class="text-slate-500 shrink-0 text-xs">Agente:</label>
          <form method="get" action="/solicitudes" class="flex items-center gap-1">
            <input type="hidden" name="status" value="<%= filterStatus %>">
            <input type="hidden" name="from" value="<%= filterFrom %>">
            <input type="hidden" name="to" value="<%= filterTo %>">
            <select name="agent" onchange="this.form.submit()"
                    class="text-xs border border-slate-300 rounded-lg px-2 py-1.5 bg-white">
              <option value="">Todos</option>
              <% agentOptions.forEach(a => { %>
                <option value="<%= a.slack_id %>" <%= filterAgent === a.slack_id ? 'selected' : '' %>><%= a.name %></option>
              <% }) %>
            </select>
          </form>
          <% if (filterAgent) { %>
            <a href="/solicitudes<%= buildQs({ agent: '' }) %>" class="text-xs text-slate-500 hover:text-rose-600" title="Quitar filtro">×</a>
          <% } %>
        </div>
      </div>
      <!-- Date range filter -->
      <form method="get" action="/solicitudes" class="flex flex-wrap items-center gap-2">
        <input type="hidden" name="status" value="<%= filterStatus %>">
        <input type="hidden" name="agent" value="<%= filterAgent %>">
        <span class="text-slate-500 shrink-0 text-xs">Fechas:</span>
        <input type="date" name="from" value="<%= filterFrom %>"
               class="text-xs border border-slate-300 rounded-lg px-2 py-1.5 bg-white" title="Desde (inclusive)">
        <span class="text-slate-400 text-xs">→</span>
        <input type="date" name="to" value="<%= filterTo %>"
               class="text-xs border border-slate-300 rounded-lg px-2 py-1.5 bg-white" title="Hasta (inclusive)">
        <button type="submit" class="text-xs font-semibold px-3 py-1.5 rounded-lg bg-ink-800 text-white shadow-card hover:bg-ink-900">Aplicar</button>
        <% if (filterFrom || filterTo) { %>
          <a href="/solicitudes<%= buildQs({ from: '', to: '' }) %>"
             class="text-xs text-slate-500 hover:text-rose-600 px-2 py-1.5" title="Quitar rango">× limpiar</a>
        <% } %>
        <!-- Quick range chips -->
        <span class="text-slate-300 text-xs mx-1 hidden sm:inline">·</span>
        <% const today = new Date(); const fmt = d => d.toISOString().slice(0,10);
           const startMonth = fmt(new Date(today.getFullYear(), today.getMonth(), 1));
           const endMonth = fmt(new Date(today.getFullYear(), today.getMonth() + 1, 0));
           const startNextMonth = fmt(new Date(today.getFullYear(), today.getMonth() + 1, 1));
           const endNextMonth = fmt(new Date(today.getFullYear(), today.getMonth() + 2, 0));
           const startYear = `${today.getFullYear()}-01-01`;
           const endYear = `${today.getFullYear()}-12-31`;
        %>
        <a href="/solicitudes<%= buildQs({ from: startMonth, to: endMonth }) %>"
           class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600 hover:bg-slate-200">Este mes</a>
        <a href="/solicitudes<%= buildQs({ from: startNextMonth, to: endNextMonth }) %>"
           class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600 hover:bg-slate-200">Próximo mes</a>
        <a href="/solicitudes<%= buildQs({ from: startYear, to: endYear }) %>"
           class="text-xs px-2 py-1 rounded bg-slate-100 text-slate-600 hover:bg-slate-200"><%= today.getFullYear() %></a>
      </form>
    </div>
  <% } %>

  <% if (requests.length === 0) { %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-card p-12 text-center">
      <div class="text-4xl mb-2 opacity-30">◌</div>
      <p class="text-sm text-slate-400">Sin solicitudes</p>
    </div>
  <% } else { %>
    <!-- Desktop table -->
    <div class="hidden md:block bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50/60 border-b border-slate-200 text-xs uppercase tracking-wider">
          <tr>
            <% if (isManager) { %><th class="text-left px-4 py-3 font-semibold text-slate-500">Agente</th><% } %>
            <th class="text-left px-3 py-3 font-semibold text-slate-500">Tipo</th>
            <th class="text-left px-3 py-3 font-semibold text-slate-500">Fechas</th>
            <th class="text-left px-3 py-3 font-semibold text-slate-500">Motivo</th>
            <th class="text-left px-3 py-3 font-semibold text-slate-500">Estado</th>
            <th class="text-left px-3 py-3 font-semibold text-slate-500">Creada</th>
            <th class="text-right px-4 py-3 font-semibold text-slate-500">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% requests.forEach(r => { %>
            <tr class="hover:bg-slate-50/60 transition-colors align-top">
              <% if (isManager) { %><td class="px-4 py-3 font-semibold text-slate-900"><%= r.requesterName %></td><% } %>
              <td class="px-3 py-3">
                <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold ring-1
                  <%= r.type === 'vacaciones' ? 'bg-cyan-50 text-cyan-800 ring-cyan-200' : 'bg-amber-50 text-amber-800 ring-amber-200' %>">
                  <%= r.type === 'vacaciones' ? '🏖️' : '📝' %>
                  <%= r.type %>
                </span>
              </td>
              <td class="px-3 py-3 text-slate-700 text-xs">
                <% if (r.start_date === r.end_date) { %>
                  <span class="font-mono"><%= fmtDate(r.start_date) %></span>
                <% } else { %>
                  <span class="font-mono"><%= fmtDate(r.start_date) %></span>
                  <span class="text-slate-400">→</span>
                  <span class="font-mono"><%= fmtDate(r.end_date) %></span>
                <% } %>
                <% if (r.start_time && r.end_time) { %>
                  <span class="ml-1 inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-amber-100 text-amber-800 ring-1 ring-amber-300" title="Permiso por horas">⏱ <%= r.start_time %>–<%= r.end_time %> UTC</span>
                <% } else { %>
                  <span class="text-slate-400 ml-1">(<%= r.days %>d)</span>
                <% } %>
              </td>
              <td class="px-3 py-3 text-slate-600 text-xs max-w-xs"><%= r.reason || '—' %></td>
              <td class="px-3 py-3">
                <span class="pill inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold ring-1 <%= statusStyle(r.status) %>">
                  <span class="w-1.5 h-1.5 rounded-full <%= statusDot(r.status) %>"></span>
                  <%= r.status %>
                </span>
                <% if (r.approverName && (r.status === 'approved' || r.status === 'rejected')) { %>
                  <div class="text-[10px] text-slate-500 mt-1" title="<%= r.approvalAtLocal ? fmtDateTime(r.approvalAtLocal) : '' %>">
                    por <span class="font-semibold text-slate-700"><%= r.approverName %></span>
                  </div>
                <% } %>
                <% if (r.status === 'rejected' && r.rejection_reason) { %>
                  <div class="text-[10px] text-slate-500 mt-1 italic">"<%= r.rejection_reason %>"</div>
                <% } %>
              </td>
              <td class="px-3 py-3 text-slate-500 text-xs"><%= fmtDateTime(r.createdLocal) %></td>
              <td class="px-4 py-3 text-right whitespace-nowrap">
                <% if (r.status === 'pending') { %>
                  <% const canResolve = isManager && (r.requester_slack_id !== user.slack_id || user.role === 'admin'); %>
                  <% if (canResolve) { %>
                    <a href="/solicitudes/<%= r.id %>/coverage" class="text-sky-700 hover:text-sky-800 text-xs font-semibold mr-2" title="Ver candidatos para cubrir">📋 Cobertura</a>
                    <form method="post" action="/solicitudes/<%= r.id %>/approve" class="inline">
                      <button class="text-emerald-700 hover:text-emerald-800 text-xs font-semibold mr-2">Aprobar</button>
                    </form>
                    <details class="inline-block relative">
                      <summary class="text-rose-600 hover:text-rose-700 text-xs font-semibold cursor-pointer list-none">Rechazar</summary>
                      <form method="post" action="/solicitudes/<%= r.id %>/reject" class="absolute z-10 mt-1 bg-white border border-slate-200 rounded-lg shadow-card-hover p-3 right-0 w-64">
                        <textarea name="rejection_reason" rows="2" placeholder="Motivo (opcional)" class="block w-full text-xs border border-slate-200 rounded p-2 mb-2"></textarea>
                        <button class="bg-rose-600 hover:bg-rose-700 text-white text-xs px-3 py-1.5 rounded font-semibold w-full">Confirmar rechazo</button>
                      </form>
                    </details>
                  <% } %>
                  <% if (r.requester_slack_id === user.slack_id) { %>
                    <form method="post" action="/solicitudes/<%= r.id %>/cancel" class="inline">
                      <button class="text-slate-500 hover:text-slate-700 text-xs font-semibold">Cancelar</button>
                    </form>
                  <% } else if (isManager) { %>
                    <form method="post" action="/solicitudes/<%= r.id %>/cancel" class="inline ml-2"
                          data-confirm="Cancelar esta solicitud pendiente del agente?" data-confirm-tone="warn" data-confirm-text="Sí, cancelar">
                      <button class="text-slate-500 hover:text-slate-700 text-xs font-semibold">Cancelar</button>
                    </form>
                  <% } %>
                <% } %>
                <% if (isManager) { %>
                  <form method="post" action="/solicitudes/<%= r.id %>/delete" class="inline ml-2"
                        data-confirm="<%= r.status === 'approved' ? 'Eliminar esta solicitud APROBADA? El horario original del agente se restablece.' : 'Eliminar esta solicitud?' %>" data-confirm-tone="danger" data-confirm-text="Eliminar">
                    <button class="text-slate-400 hover:text-rose-600 text-xs font-semibold" title="Eliminar">🗑</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Mobile card list -->
    <ul class="md:hidden space-y-3">
      <% requests.forEach(r => { %>
        <li class="bg-white rounded-xl border border-slate-200 shadow-card p-4">
          <div class="flex items-start justify-between gap-3 mb-2">
            <div class="flex-1 min-w-0">
              <% if (isManager) { %>
                <div class="font-semibold text-slate-900 text-sm truncate"><%= r.requesterName %></div>
              <% } %>
              <div class="flex items-center gap-2 mt-1 flex-wrap">
                <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1
                  <%= r.type === 'vacaciones' ? 'bg-cyan-50 text-cyan-800 ring-cyan-200' : 'bg-amber-50 text-amber-800 ring-amber-200' %>">
                  <%= r.type === 'vacaciones' ? '🏖️' : '📝' %> <%= r.type %>
                </span>
                <span class="pill inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= statusStyle(r.status) %>">
                  <span class="w-1.5 h-1.5 rounded-full <%= statusDot(r.status) %>"></span>
                  <%= r.status %>
                </span>
                <% if (r.approverName && (r.status === 'approved' || r.status === 'rejected')) { %>
                  <span class="text-[10px] text-slate-500">por <span class="font-semibold text-slate-700"><%= r.approverName %></span></span>
                <% } %>
              </div>
            </div>
          </div>
          <div class="text-xs text-slate-700 mb-1">
            <% if (r.start_date === r.end_date) { %>
              <span class="font-mono"><%= fmtDate(r.start_date) %></span>
            <% } else { %>
              <span class="font-mono"><%= fmtDate(r.start_date) %></span> <span class="text-slate-400">→</span> <span class="font-mono"><%= fmtDate(r.end_date) %></span>
            <% } %>
            <span class="text-slate-400">(<%= r.days %>d)</span>
          </div>
          <% if (r.reason) { %>
            <p class="text-xs text-slate-600 mb-2 leading-relaxed"><%= r.reason %></p>
          <% } %>
          <% if (r.status === 'rejected' && r.rejection_reason) { %>
            <p class="text-[11px] text-rose-700 italic mt-1">Rechazo: <%= r.rejection_reason %></p>
          <% } %>
          <div class="mt-3 pt-2 border-t border-slate-100 flex flex-col gap-2">
            <span class="text-[10px] text-slate-400"><%= fmtDateTime(r.createdLocal) %></span>
            <% const canResolveM = isManager && (r.requester_slack_id !== user.slack_id || user.role === 'admin'); %>
            <% const canCancelM = r.status === 'pending' && (r.requester_slack_id === user.slack_id || isManager); %>
            <% const showActions = (r.status === 'pending' && (canResolveM || canCancelM)) || isManager; %>
            <% if (showActions) { %>
              <div class="flex flex-wrap gap-2 items-center">
                <% if (r.status === 'pending' && canResolveM) { %>
                  <a href="/solicitudes/<%= r.id %>/coverage" class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-sky-50 text-sky-700 ring-1 ring-sky-200 hover:bg-sky-100 inline-block">📋 Cobertura</a>
                  <form method="post" action="/solicitudes/<%= r.id %>/approve" class="inline">
                    <button class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200 hover:bg-emerald-100">✓ Aprobar</button>
                  </form>
                  <details class="inline-block relative">
                    <summary class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-rose-50 text-rose-700 ring-1 ring-rose-200 hover:bg-rose-100 cursor-pointer list-none">✕ Rechazar</summary>
                    <form method="post" action="/solicitudes/<%= r.id %>/reject" class="absolute z-10 mt-1 bg-white border border-slate-200 rounded-lg shadow-card-hover p-3 left-0 w-64 max-w-[calc(100vw-2rem)]">
                      <textarea name="rejection_reason" rows="2" placeholder="Motivo (opcional)" class="block w-full text-xs border border-slate-200 rounded p-2 mb-2"></textarea>
                      <button class="bg-rose-600 hover:bg-rose-700 text-white text-xs px-3 py-1.5 rounded font-semibold w-full">Confirmar rechazo</button>
                    </form>
                  </details>
                <% } %>
                <% if (canCancelM) { %>
                  <form method="post" action="/solicitudes/<%= r.id %>/cancel" class="inline"
                        <% if (r.requester_slack_id !== user.slack_id) { %>data-confirm="Cancelar esta solicitud pendiente del agente?" data-confirm-tone="warn" data-confirm-text="Sí, cancelar"<% } %>>
                    <button class="px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-100 text-slate-600 ring-1 ring-slate-200 hover:bg-slate-200">Cancelar</button>
                  </form>
                <% } %>
                <% if (isManager) { %>
                  <form method="post" action="/solicitudes/<%= r.id %>/delete" class="inline ml-auto"
                        data-confirm="<%= r.status === 'approved' ? 'Eliminar esta solicitud APROBADA? El horario original del agente se restablece.' : 'Eliminar esta solicitud?' %>" data-confirm-tone="danger" data-confirm-text="Eliminar">
                    <button class="px-2 py-1.5 rounded-lg text-xs font-semibold text-slate-400 hover:bg-rose-50 hover:text-rose-600" title="Eliminar">🗑</button>
                  </form>
                <% } %>
              </div>
            <% } %>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
  <% } %><!-- /view === timeoff -->
</main>
<%- include('partials/foot') %>
