<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<main class="max-w-3xl mx-auto px-4 sm:px-6 py-6">
  <div class="mb-5">
    <a href="/settings" class="text-xs text-slate-400 hover:text-slate-600">← Volver a Configuración</a>
    <h2 class="text-2xl font-bold text-slate-900 tracking-tight mt-2">User groups de Slack</h2>
    <p class="text-sm text-slate-500 mt-1">Lista los grupos visibles para el bot. Usa el botón "Copiar mención" para pegar el formato listo en <a href="/settings" class="underline">/settings</a>.</p>
  </div>

  <% if (error) { %>
    <div class="bg-rose-50 ring-1 ring-rose-200 text-rose-800 rounded-lg p-4 text-sm mb-4">
      ⚠ <%= error %>
    </div>
  <% } %>

  <% if (groups.length === 0 && !error) { %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-card p-8 text-center">
      <div class="text-4xl mb-2 opacity-30">∅</div>
      <p class="text-sm text-slate-400">El workspace no tiene user groups o el bot no los puede ver.</p>
    </div>
  <% } %>

  <% if (groups.length > 0) { %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200 text-xs">
          <tr>
            <th class="text-left px-4 py-2 font-medium text-slate-600">Handle</th>
            <th class="text-left px-4 py-2 font-medium text-slate-600">Nombre</th>
            <th class="text-left px-4 py-2 font-medium text-slate-600">ID</th>
            <th class="text-right px-4 py-2 font-medium text-slate-600">Usuarios</th>
            <th class="text-right px-4 py-2 font-medium text-slate-600">Mención</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% groups.forEach(g => { %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-2 font-mono text-slate-700">@<%= g.handle %></td>
              <td class="px-4 py-2 text-slate-600 text-xs"><%= g.name %></td>
              <td class="px-4 py-2 font-mono text-xs text-slate-500"><%= g.id %></td>
              <td class="px-4 py-2 text-right text-slate-500 text-xs"><%= g.userCount %></td>
              <td class="px-4 py-2 text-right">
                <button type="button" onclick="copyMention(this, '<%= g.mentionTag %>')"
                  class="px-3 py-1 text-xs bg-ink-800 hover:bg-ink-700 text-white rounded-md font-semibold font-mono">
                  Copiar mención
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <p class="text-xs text-slate-400 mt-4">
      Pegá el código de mención en <code>/settings → Mención en cumpleaños</code> o <code>Mención en aniversario laboral</code>.
      Slack lo renderiza como <code>@handle</code> y notifica a los miembros del grupo.
    </p>
  <% } %>
</main>

<script>
function copyMention(btn, code) {
  navigator.clipboard.writeText(code).then(() => {
    const orig = btn.textContent;
    btn.textContent = '✓ Copiado';
    btn.classList.add('bg-emerald-700');
    btn.classList.remove('bg-ink-800', 'hover:bg-ink-700');
    setTimeout(() => {
      btn.textContent = orig;
      btn.classList.remove('bg-emerald-700');
      btn.classList.add('bg-ink-800', 'hover:bg-ink-700');
    }, 1500);
  });
}
</script>

<%- include('partials/foot') %>
