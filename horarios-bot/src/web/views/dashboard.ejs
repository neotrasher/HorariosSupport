<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<main class="max-w-6xl mx-auto px-4 py-6">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-xl font-semibold text-gray-900">Dashboard</h2>
    <span class="text-sm text-gray-500"><%= now %> UTC</span>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <div class="text-2xl font-bold text-green-600"><%= counts.active %></div>
      <div class="text-xs text-gray-500 mt-1">En turno</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <div class="text-2xl font-bold text-red-600"><%= counts.alert %></div>
      <div class="text-xs text-gray-500 mt-1">Sin marcar</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <div class="text-2xl font-bold text-yellow-600"><%= counts.warning %></div>
      <div class="text-xs text-gray-500 mt-1">Sin clock out</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <div class="text-2xl font-bold text-blue-600"><%= counts.upcoming %></div>
      <div class="text-xs text-gray-500 mt-1">Proximos</div>
    </div>
    <div class="bg-white rounded-lg border border-gray-200 p-4">
      <div class="text-2xl font-bold text-gray-600"><%= counts.completed %></div>
      <div class="text-xs text-gray-500 mt-1">Finalizados</div>
    </div>
  </div>

  <!-- Shift table -->
  <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Agente</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Dept</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Turno</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Horario (UTC)</th>
          <th class="text-left px-4 py-3 font-medium text-gray-600">Estado</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if (rows.length === 0) { %>
          <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">Sin turnos activos</td></tr>
        <% } %>
        <% rows.forEach(r => { %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 font-medium text-gray-900"><%= r.agent %></td>
            <td class="px-4 py-3 text-gray-600"><%= r.dept %></td>
            <td class="px-4 py-3 text-gray-600"><%= r.shiftLabel %></td>
            <td class="px-4 py-3 text-gray-600"><%= r.startUtc %>–<%= r.endUtc %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <% if (r.statusClass === 'active') { %>bg-green-100 text-green-700
                <% } else if (r.statusClass === 'break') { %>bg-orange-100 text-orange-700
                <% } else if (r.statusClass === 'alert') { %>bg-red-100 text-red-700
                <% } else if (r.statusClass === 'warning') { %>bg-yellow-100 text-yellow-700
                <% } else if (r.statusClass === 'upcoming') { %>bg-blue-100 text-blue-700
                <% } else if (r.statusClass === 'completed') { %>bg-gray-100 text-gray-600
                <% } %>">
                <%= r.status %>
              </span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>
<%- include('partials/foot') %>
