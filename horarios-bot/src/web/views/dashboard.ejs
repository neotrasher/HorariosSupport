<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<main class="max-w-[1700px] mx-auto px-4 sm:px-6 py-6">
  <!-- Page header -->
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-6">
    <div class="min-w-0">
      <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Hola, <%= (user.name || '').split(' ')[0] %></h2>
      <p class="text-sm text-slate-500 mt-0.5">Resumen de turnos en vivo del equipo.</p>
    </div>
    <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200 rounded-lg shadow-card self-start sm:self-auto shrink-0">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
      <span class="text-xs font-mono text-slate-600"><%= now %> UTC</span>
    </div>
  </div>

  <!-- Admin/Manager Insights -->
  <% if (insights) {
       function gradeCls(g) {
         return g === 'A' ? 'bg-emerald-50 text-emerald-700 ring-emerald-200'
              : g === 'B' ? 'bg-lime-50 text-lime-700 ring-lime-200'
              : g === 'C' ? 'bg-amber-50 text-amber-700 ring-amber-200'
              : g === 'D' ? 'bg-orange-50 text-orange-700 ring-orange-200'
              : g === 'F' ? 'bg-rose-50 text-rose-700 ring-rose-200'
              : 'bg-slate-50 text-slate-500 ring-slate-200';
       }
       function deptCls(d) {
         return d === 'L1' ? 'bg-blue-100 text-blue-700'
              : d === 'L2' ? 'bg-violet-100 text-violet-700'
              : 'bg-slate-100 text-slate-600';
       }
       const teamAvg = insights.teamScoreAvg;
       const teamCls = teamAvg === null ? 'text-slate-400'
                     : teamAvg >= 85 ? 'text-emerald-700'
                     : teamAvg >= 70 ? 'text-amber-700'
                     : 'text-rose-700';
  %>
  <section class="mb-6">
    <!-- KPI strip: 4 highlights -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
      <a href="/reportes?preset=last-30" class="block relative bg-white rounded-xl border border-slate-200 shadow-card p-4 hover:shadow-card-hover transition-shadow overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 <%= teamAvg !== null && teamAvg >= 85 ? 'bg-emerald-500' : teamAvg !== null && teamAvg >= 70 ? 'bg-amber-500' : 'bg-rose-500' %>"></div>
        <div class="text-[10px] uppercase tracking-wider font-bold text-slate-400">Score promedio (90d)</div>
        <div class="text-3xl font-extrabold mt-1 <%= teamCls %>">
          <% if (teamAvg === null) { %>—<% } else { %><%= teamAvg %><span class="text-sm text-slate-400 font-bold">/100</span><% } %>
        </div>
        <div class="text-[10px] text-slate-400 mt-0.5"><%= insights.teamScoreEvaluated %> agentes con datos</div>
      </a>

      <a href="/solicitudes?status=pending" class="block relative bg-white rounded-xl border border-slate-200 shadow-card p-4 hover:shadow-card-hover transition-shadow overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 <%= insights.pendingRequests > 0 ? 'bg-sky-500' : 'bg-slate-300' %>"></div>
        <div class="text-[10px] uppercase tracking-wider font-bold text-slate-400">Solicitudes pendientes</div>
        <div class="text-3xl font-extrabold mt-1 <%= insights.pendingRequests > 0 ? 'text-sky-700' : 'text-slate-300' %>"><%= insights.pendingRequests %></div>
        <div class="text-[10px] text-slate-400 mt-0.5">requieren aprobación</div>
      </a>

      <div class="relative bg-white rounded-xl border border-slate-200 shadow-card p-4 overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-slate-400"></div>
        <div class="text-[10px] uppercase tracking-wider font-bold text-slate-400">Esta semana</div>
        <div class="text-3xl font-extrabold mt-1 text-slate-700"><%= insights.shiftsThisWeek %></div>
        <div class="text-[10px] text-slate-400 mt-0.5">turnos · <%= insights.unmarkedThisWeek %> sin marcar · <%= insights.lateThisWeek %> tarde</div>
      </div>

      <a href="/auditoria" class="block relative bg-white rounded-xl border border-slate-200 shadow-card p-4 hover:shadow-card-hover transition-shadow overflow-hidden">
        <div class="absolute top-0 left-0 right-0 h-1 bg-violet-500"></div>
        <div class="text-[10px] uppercase tracking-wider font-bold text-slate-400">Atención requerida</div>
        <div class="text-3xl font-extrabold mt-1 <%= insights.needsAttention.length > 0 ? 'text-rose-700' : 'text-slate-300' %>"><%= insights.needsAttention.length %></div>
        <div class="text-[10px] text-slate-400 mt-0.5">agentes con score D/F</div>
      </a>
    </div>

    <!-- Insights row -->
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4 mb-4">
      <!-- Top performers -->
      <% if (insights.topPerformers.length > 0) { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
        <header class="px-4 py-2.5 border-b border-slate-100 flex items-center justify-between">
          <h3 class="text-xs uppercase tracking-wider font-bold text-slate-500">🏆 Top puntualidad (90d)</h3>
        </header>
        <ul class="divide-y divide-slate-50">
          <% insights.topPerformers.forEach((a, idx) => { %>
            <li class="px-4 py-2 flex items-center gap-3">
              <span class="w-5 text-center font-bold text-slate-300 text-sm"><%= idx + 1 %></span>
              <span class="flex-1 truncate text-sm text-slate-800"><%= a.name %></span>
              <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold tracking-wide <%= deptCls(a.dept) %>"><%= a.dept %></span>
              <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold ring-1 <%= gradeCls(a.grade) %>">
                <span class="font-mono"><%= a.score %></span>·<%= a.grade %>
              </span>
            </li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <!-- Needs attention -->
      <% if (insights.needsAttention.length > 0) { %>
      <div class="bg-white rounded-xl border border-rose-200 shadow-card overflow-hidden">
        <header class="px-4 py-2.5 border-b border-rose-100 bg-rose-50/40 flex items-center justify-between">
          <h3 class="text-xs uppercase tracking-wider font-bold text-rose-700">⚠ Atención requerida</h3>
        </header>
        <ul class="divide-y divide-slate-50">
          <% insights.needsAttention.forEach(a => { %>
            <li class="px-4 py-2 flex items-center gap-3">
              <span class="flex-1 truncate text-sm text-slate-800"><%= a.name %></span>
              <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold tracking-wide <%= deptCls(a.dept) %>"><%= a.dept %></span>
              <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold ring-1 <%= gradeCls(a.grade) %>">
                <span class="font-mono"><%= a.score %></span>·<%= a.grade %>
              </span>
              <span class="text-[10px] text-slate-400"><%= a.pastShifts %>t</span>
            </li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <!-- Vacaciones críticas -->
      <% if (insights.vacationCritical.length > 0) { %>
      <div class="bg-white rounded-xl border border-amber-200 shadow-card overflow-hidden">
        <header class="px-4 py-2.5 border-b border-amber-100 bg-amber-50/40 flex items-center justify-between">
          <h3 class="text-xs uppercase tracking-wider font-bold text-amber-700">🌴 Vacaciones casi agotadas</h3>
        </header>
        <ul class="divide-y divide-slate-50">
          <% insights.vacationCritical.slice(0, 5).forEach(a => { %>
            <li class="px-4 py-2 flex items-center gap-3">
              <a href="/agentes/<%= a.slack_id %>" class="flex-1 truncate text-sm text-slate-800 hover:underline"><%= a.name %></a>
              <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold tracking-wide <%= deptCls(a.dept) %>"><%= a.dept %></span>
              <span class="font-mono text-xs <%= a.available <= 0 ? 'text-rose-700 font-bold' : 'text-amber-700' %>"><%= a.used %>/<%= a.entitled %></span>
              <span class="text-[10px] text-slate-400"><%= a.available %> disp.</span>
            </li>
          <% }) %>
        </ul>
        <% if (insights.vacationCritical.length > 5) { %>
          <div class="px-4 py-2 text-[10px] text-slate-400 border-t border-slate-50">+ <%= insights.vacationCritical.length - 5 %> más</div>
        <% } %>
      </div>
      <% } %>

      <!-- Próximas evaluaciones -->
      <% if (insights.upcomingEvaluations.length > 0) { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
        <header class="px-4 py-2.5 border-b border-slate-100 flex items-center justify-between">
          <h3 class="text-xs uppercase tracking-wider font-bold text-slate-500">📋 Próximas evaluaciones (30d)</h3>
        </header>
        <ul class="divide-y divide-slate-50">
          <% insights.upcomingEvaluations.slice(0, 5).forEach(a => { %>
            <li class="px-4 py-2 flex items-center gap-3">
              <a href="/agentes/<%= a.slack_id %>" class="flex-1 truncate text-sm text-slate-800 hover:underline"><%= a.name %></a>
              <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold tracking-wide <%= deptCls(a.dept) %>"><%= a.dept %></span>
              <span class="font-mono text-[10px] text-slate-500"><%= fmtDate(a.date) %></span>
              <span class="text-[10px] font-bold <%= a.daysUntil <= 7 ? 'text-rose-700' : a.daysUntil <= 15 ? 'text-amber-700' : 'text-slate-500' %>">
                <%= a.daysUntil === 0 ? 'hoy' : 'en ' + a.daysUntil + 'd' %>
              </span>
            </li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <!-- Cumpleaños -->
      <% if (insights.upcomingBirthdays.length > 0) { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
        <header class="px-4 py-2.5 border-b border-slate-100 flex items-center justify-between">
          <h3 class="text-xs uppercase tracking-wider font-bold text-slate-500">🎂 Cumpleaños (30d)</h3>
        </header>
        <ul class="divide-y divide-slate-50">
          <% insights.upcomingBirthdays.slice(0, 5).forEach(a => { %>
            <li class="px-4 py-2 flex items-center gap-3">
              <span class="flex-1 truncate text-sm text-slate-800"><%= a.name %></span>
              <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold tracking-wide <%= deptCls(a.dept) %>"><%= a.dept %></span>
              <span class="font-mono text-[10px] text-slate-500"><%= fmtDate(a.date).slice(0, 5) %></span>
              <span class="text-[10px] font-bold <%= a.daysUntil <= 7 ? 'text-pink-600' : 'text-slate-500' %>">
                <%= a.daysUntil === 0 ? '¡hoy!' : 'en ' + a.daysUntil + 'd' %>
              </span>
            </li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <!-- Aniversarios laborales -->
      <% if (insights.upcomingAnniversaries.length > 0) { %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
        <header class="px-4 py-2.5 border-b border-slate-100 flex items-center justify-between">
          <h3 class="text-xs uppercase tracking-wider font-bold text-slate-500">🎉 Aniversarios laborales (30d)</h3>
        </header>
        <ul class="divide-y divide-slate-50">
          <% insights.upcomingAnniversaries.slice(0, 5).forEach(a => { %>
            <li class="px-4 py-2 flex items-center gap-3">
              <span class="flex-1 truncate text-sm text-slate-800"><%= a.name %></span>
              <span class="inline-block px-1.5 py-0.5 rounded text-[10px] font-bold tracking-wide <%= deptCls(a.dept) %>"><%= a.dept %></span>
              <% if (a.years !== null) { %>
                <span class="text-[10px] font-bold text-violet-700"><%= a.years %><span class="text-slate-400 font-normal">a</span></span>
              <% } %>
              <span class="font-mono text-[10px] text-slate-500"><%= fmtDate(a.date).slice(0, 5) %></span>
              <span class="text-[10px] font-bold <%= a.daysUntil <= 7 ? 'text-violet-600' : 'text-slate-500' %>">
                <%= a.daysUntil === 0 ? '¡hoy!' : 'en ' + a.daysUntil + 'd' %>
              </span>
            </li>
          <% }) %>
        </ul>
      </div>
      <% } %>
    </div>
  </section>
  <% } %>

  <!-- Stats grid -->
  <%
    const stats = [
      { key: 'active',    label: 'En turno',        value: counts.active,    accent: 'emerald', icon: '●' },
      { key: 'alert',     label: 'Sin marcar',      value: counts.alert,     accent: 'rose',    icon: '!' },
      { key: 'warning',   label: 'Sin clock out',   value: counts.warning,   accent: 'amber',   icon: '◷' },
      { key: 'upcoming',  label: 'Proximos (8h)',   value: counts.upcoming,  accent: 'blue',    icon: '↗' },
      { key: 'completed', label: 'Finalizados',     value: counts.completed, accent: 'slate',   icon: '✓' }
    ];
    const accentMap = {
      emerald: { ring: 'ring-emerald-200', text: 'text-emerald-700', bg: 'bg-emerald-50',  border: 'border-emerald-200',  dot: 'bg-emerald-500' },
      rose:    { ring: 'ring-rose-200',    text: 'text-rose-700',    bg: 'bg-rose-50',     border: 'border-rose-200',     dot: 'bg-rose-500'    },
      amber:   { ring: 'ring-amber-200',   text: 'text-amber-700',   bg: 'bg-amber-50',    border: 'border-amber-200',    dot: 'bg-amber-500'   },
      blue:    { ring: 'ring-sky-200',     text: 'text-sky-700',     bg: 'bg-sky-50',      border: 'border-sky-200',      dot: 'bg-sky-500'     },
      slate:   { ring: 'ring-slate-200',   text: 'text-slate-700',   bg: 'bg-slate-100',   border: 'border-slate-200',    dot: 'bg-slate-400'   }
    };
  %>
  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
    <% stats.forEach(s => { const c = accentMap[s.accent]; %>
      <div class="relative bg-white rounded-xl border border-slate-200 shadow-card p-4 overflow-hidden group transition-shadow hover:shadow-card-hover">
        <!-- Accent strip on top -->
        <div class="absolute top-0 left-0 right-0 h-1 <%= c.dot %>"></div>
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0 flex-1">
            <div class="text-[11px] uppercase tracking-wider font-bold text-slate-400 truncate"><%= s.label %></div>
            <div class="text-3xl font-extrabold mt-1 <%= s.value > 0 ? c.text : 'text-slate-300' %>"><%= s.value %></div>
          </div>
          <div class="w-9 h-9 rounded-lg <%= c.bg %> <%= c.text %> flex items-center justify-center text-base font-bold ring-1 <%= c.ring %> shrink-0">
            <%= s.icon %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Shift table -->
  <section class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden">
    <header class="flex items-center justify-between px-5 py-3 border-b border-slate-200 bg-slate-50/50">
      <h3 class="font-semibold text-slate-900 text-sm">Turnos en vivo</h3>
      <span class="text-xs text-slate-500"><%= rows.length %> turno<%= rows.length === 1 ? '' : 's' %></span>
    </header>

    <% if (rows.length === 0) { %>
      <div class="px-5 py-12 text-center">
        <div class="text-4xl mb-2 opacity-30">◌</div>
        <p class="text-sm text-slate-400">Sin turnos activos en este momento</p>
      </div>
    <% } else { %>
      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-slate-50/60 border-b border-slate-200 text-xs uppercase tracking-wider">
            <tr>
              <th class="text-left px-5 py-3 font-semibold text-slate-500">Agente</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Dept</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Turno</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Horario (UTC)</th>
              <th class="text-left px-3 py-3 font-semibold text-slate-500">Estado</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% rows.forEach(r => { %>
              <tr class="hover:bg-slate-50/60 transition-colors">
                <td class="px-5 py-3 font-semibold text-slate-900"><%= r.agent %></td>
                <td class="px-3 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold tracking-wide
                    <%= r.dept === 'L1' ? 'bg-blue-100 text-blue-700' : 'bg-violet-100 text-violet-700' %>">
                    <%= r.dept %>
                  </span>
                </td>
                <td class="px-3 py-3 text-slate-600 text-xs"><%= r.shiftLabel %></td>
                <td class="px-3 py-3 text-slate-500 text-xs font-mono"><%= r.startUtc %>–<%= r.endUtc %></td>
                <td class="px-3 py-3">
                  <span class="pill inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold ring-1
                    <% if (r.statusClass === 'active') { %>bg-emerald-50 text-emerald-700 ring-emerald-200
                    <% } else if (r.statusClass === 'break') { %>bg-orange-50 text-orange-700 ring-orange-200
                    <% } else if (r.statusClass === 'alert') { %>bg-rose-50 text-rose-700 ring-rose-200
                    <% } else if (r.statusClass === 'warning') { %>bg-amber-50 text-amber-700 ring-amber-200
                    <% } else if (r.statusClass === 'upcoming') { %>bg-sky-50 text-sky-700 ring-sky-200
                    <% } else if (r.statusClass === 'completed') { %>bg-slate-100 text-slate-600 ring-slate-200
                    <% } %>">
                    <span class="w-1.5 h-1.5 rounded-full
                      <% if (r.statusClass === 'active') { %>bg-emerald-500
                      <% } else if (r.statusClass === 'break') { %>bg-orange-500
                      <% } else if (r.statusClass === 'alert') { %>bg-rose-500
                      <% } else if (r.statusClass === 'warning') { %>bg-amber-500
                      <% } else if (r.statusClass === 'upcoming') { %>bg-sky-500
                      <% } else { %>bg-slate-400<% } %>"></span>
                    <%= r.status %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile card list -->
      <ul class="md:hidden divide-y divide-slate-100">
        <% rows.forEach(r => { %>
          <li class="px-4 py-3 flex items-start gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2">
                <span class="font-semibold text-slate-900 text-sm truncate"><%= r.agent %></span>
                <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-bold tracking-wide
                  <%= r.dept === 'L1' ? 'bg-blue-100 text-blue-700' : 'bg-violet-100 text-violet-700' %>">
                  <%= r.dept %>
                </span>
              </div>
              <div class="text-xs text-slate-500 mt-0.5">
                <%= r.shiftLabel %> · <span class="font-mono"><%= r.startUtc %>–<%= r.endUtc %></span>
              </div>
            </div>
            <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold ring-1 shrink-0
              <% if (r.statusClass === 'active') { %>bg-emerald-50 text-emerald-700 ring-emerald-200
              <% } else if (r.statusClass === 'break') { %>bg-orange-50 text-orange-700 ring-orange-200
              <% } else if (r.statusClass === 'alert') { %>bg-rose-50 text-rose-700 ring-rose-200
              <% } else if (r.statusClass === 'warning') { %>bg-amber-50 text-amber-700 ring-amber-200
              <% } else if (r.statusClass === 'upcoming') { %>bg-sky-50 text-sky-700 ring-sky-200
              <% } else { %>bg-slate-100 text-slate-600 ring-slate-200<% } %>">
              <%= r.status %>
            </span>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</main>
<%- include('partials/foot') %>
