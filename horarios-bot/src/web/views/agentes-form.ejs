<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<%
  // Color helper para el avatar inicial
  function initialBg(name) {
    const palette = ['bg-blue-500','bg-emerald-500','bg-rose-500','bg-amber-500','bg-violet-500','bg-cyan-500','bg-fuchsia-500','bg-orange-500'];
    let h = 0;
    for (let i = 0; i < (name || '').length; i++) h = (h * 31 + name.charCodeAt(i)) | 0;
    return palette[Math.abs(h) % palette.length];
  }
%>

<main class="max-w-4xl mx-auto px-4 sm:px-6 py-6">
  <a href="/agentes" class="text-xs text-slate-500 hover:text-slate-900 inline-flex items-center gap-1 mb-3">
    <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
    Volver a agentes
  </a>

  <!-- ─── Hero del agente ─── -->
  <div class="bg-white rounded-xl border border-slate-200 shadow-card p-5 mb-5">
    <div class="flex flex-col sm:flex-row sm:items-center gap-4">
      <% if (mode === 'edit') { %>
        <div class="w-14 h-14 rounded-full <%= initialBg(agent.name) %> text-white flex items-center justify-center text-xl font-bold shrink-0 shadow-card">
          <%= (agent.name || '?').charAt(0).toUpperCase() %>
        </div>
      <% } else { %>
        <div class="w-14 h-14 rounded-full bg-slate-200 text-slate-500 flex items-center justify-center text-2xl font-bold shrink-0">+</div>
      <% } %>
      <div class="flex-1 min-w-0">
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight truncate">
          <%= mode === 'create' ? 'Nuevo agente' : agent.name %>
        </h2>
        <% if (mode === 'edit') { %>
          <div class="flex flex-wrap items-center gap-2 mt-1">
            <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold tracking-wide
              <% if (agent.dept === 'L1') { %>bg-blue-100 text-blue-700
              <% } else if (agent.dept === 'L2') { %>bg-violet-100 text-violet-700
              <% } else { %>bg-slate-100 text-slate-600<% } %>"><%= agent.dept %></span>
            <span class="text-[10px] uppercase tracking-wider px-2 py-0.5 rounded font-bold
              <% if (agent.role === 'admin') { %>bg-rose-100 text-rose-700
              <% } else if (agent.role === 'manager') { %>bg-violet-100 text-violet-700
              <% } else { %>bg-blue-100 text-blue-700<% } %>"><%= agent.role %></span>
            <% if (!agent.active) { %>
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[10px] font-bold bg-slate-200 text-slate-600">Inactivo</span>
            <% } %>
            <span class="text-xs text-slate-400 font-mono"><%= agent.slack_id %> · #<%= agent.planner_id %></span>
          </div>
        <% } else { %>
          <p class="text-sm text-slate-500 mt-1">Vincula un usuario de Slack a un agente del equipo.</p>
        <% } %>
      </div>
      <% if (mode === 'edit') { %>
        <div class="flex items-center gap-2 shrink-0">
          <a href="/horarios/agente/<%= agent.planner_id %>" class="text-xs px-3 py-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card text-slate-600 font-medium">Ver horario</a>
          <form method="post" action="/agentes/<%= agent.slack_id %>/toggle-active" class="inline">
            <button class="text-xs px-3 py-2 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card text-slate-600 font-medium">
              <%= agent.active ? 'Desactivar' : 'Reactivar' %>
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </div>

  <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 text-sm rounded-lg p-3 mb-4"><%= error %></div>
  <% } %>

  <!-- ─── Tabs nav ─── -->
  <div class="overflow-x-auto -mx-4 sm:mx-0 px-4 sm:px-0 mb-4">
    <div class="inline-flex bg-white border border-slate-200 rounded-lg shadow-card p-1 gap-1" role="tablist" id="tabsNav">
      <button type="button" class="tab-btn px-3 py-1.5 rounded-md text-xs font-semibold text-slate-600 hover:bg-slate-50 whitespace-nowrap" data-tab="identidad">
        <span class="hidden sm:inline">👤 </span>Identidad
      </button>
      <button type="button" class="tab-btn px-3 py-1.5 rounded-md text-xs font-semibold text-slate-600 hover:bg-slate-50 whitespace-nowrap" data-tab="contacto">
        <span class="hidden sm:inline">📞 </span>Contacto
      </button>
      <button type="button" class="tab-btn px-3 py-1.5 rounded-md text-xs font-semibold text-slate-600 hover:bg-slate-50 whitespace-nowrap" data-tab="trabajo">
        <span class="hidden sm:inline">💼 </span>Trabajo
      </button>
      <% if (isAdmin) { %>
        <button type="button" class="tab-btn px-3 py-1.5 rounded-md text-xs font-semibold text-slate-600 hover:bg-slate-50 whitespace-nowrap" data-tab="sensibles">
          <span class="hidden sm:inline">🔒 </span>Sensibles
        </button>
      <% } %>
    </div>
  </div>

  <form method="post" action="<%= mode === 'create' ? '/agentes/nuevo' : '/agentes/' + agent.slack_id %>" id="agentForm">

    <!-- ── Tab: Identidad ── -->
    <section data-tabpanel="identidad" class="bg-white rounded-xl border border-slate-200 shadow-card p-5 hidden">
      <% if (mode === 'create') { %>
        <h3 class="font-semibold text-slate-900 mb-1 text-sm">Vinculación con Slack</h3>
        <p class="text-xs text-slate-500 mb-4">Identificadores que enlazan al usuario de Slack con su agente del planner.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5 pb-5 border-b border-slate-100">
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Slack ID</label>
            <input type="text" name="slack_id" required value="<%= agent.slack_id %>"
                   placeholder="U01ABCDE"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm font-mono">
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Planner ID</label>
            <input type="number" name="planner_id" required value="<%= agent.planner_id || '' %>"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
          </div>
        </div>
      <% } %>

      <h3 class="font-semibold text-slate-900 mb-1 text-sm">Identidad</h3>
      <p class="text-xs text-slate-500 mb-4">Nombre, departamento y rol dentro del bot.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="sm:col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Nombre completo</label>
          <input type="text" name="name" required value="<%= agent.name || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Departamento</label>
          <select name="dept" class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
            <option value="L1" <%= agent.dept === 'L1' ? 'selected' : '' %>>L1</option>
            <option value="L2" <%= agent.dept === 'L2' ? 'selected' : '' %>>L2</option>
            <option value="MGMT" <%= agent.dept === 'MGMT' ? 'selected' : '' %>>MGMT (sin turnos)</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Rol</label>
          <select name="role" class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm" <%= isAdmin ? '' : 'disabled' %>>
            <option value="agent"   <%= agent.role === 'agent'   ? 'selected' : '' %>>agent</option>
            <option value="manager" <%= agent.role === 'manager' ? 'selected' : '' %>>manager</option>
            <% if (isAdmin) { %>
              <option value="admin" <%= agent.role === 'admin' ? 'selected' : '' %>>admin</option>
            <% } %>
          </select>
          <p class="text-[10px] text-slate-400 mt-1">
            <% if (isAdmin) { %>
              Admin aprueba todo · manager solicitudes y swaps · agent solo recibe.
            <% } else { %>
              Solo admin puede cambiar el rol.
            <% } %>
          </p>
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Usuario admin <span class="text-slate-400 font-normal">(panel admin externo)</span></label>
          <input type="text" name="admin_user" value="<%= agent.admin_user || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
      </div>
    </section>

    <!-- ── Tab: Contacto ── -->
    <section data-tabpanel="contacto" class="bg-white rounded-xl border border-slate-200 shadow-card p-5 hidden">
      <h3 class="font-semibold text-slate-900 mb-1 text-sm">Datos de contacto</h3>
      <p class="text-xs text-slate-500 mb-4">Cómo contactar al agente y datos personales.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Email empresa</label>
          <input type="email" name="email_company" value="<%= agent.email_company || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Email personal</label>
          <input type="email" name="email_personal" value="<%= agent.email_personal || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Telefono</label>
          <input type="text" name="phone" value="<%= agent.phone || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Cumpleaños</label>
          <input type="date" name="birthdate" value="<%= agent.birthdate || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div class="sm:col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Direccion</label>
          <input type="text" name="address" value="<%= agent.address || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
      </div>
    </section>

    <!-- ── Tab: Trabajo ── -->
    <section data-tabpanel="trabajo" class="bg-white rounded-xl border border-slate-200 shadow-card p-5 hidden">
      <h3 class="font-semibold text-slate-900 mb-1 text-sm">Datos de trabajo</h3>
      <p class="text-xs text-slate-500 mb-4">Cargo, fechas, evaluaciones, vacaciones y zona horaria.</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="sm:col-span-2">
          <label class="block text-xs font-medium text-slate-700 mb-1">Cargo</label>
          <input type="text" name="position" value="<%= agent.position || '' %>"
                 placeholder="L1 Support, Team Lead..."
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Fecha ingreso</label>
          <input type="date" name="start_date" value="<%= agent.start_date || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Fecha egreso</label>
          <input type="date" name="end_date" value="<%= agent.end_date || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Ultima evaluacion</label>
          <input type="date" name="last_evaluation_date" value="<%= agent.last_evaluation_date || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Proxima evaluacion</label>
          <input type="date" name="next_evaluation_date" value="<%= agent.next_evaluation_date || '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Dias de vacaciones / año</label>
          <input type="number" name="vacation_days_per_year" min="0" max="60"
                 value="<%= agent.vacation_days_per_year ?? '' %>"
                 class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
          <% if (typeof vacationBalance !== 'undefined' && vacationBalance) { %>
            <p class="text-[10px] text-slate-500 mt-1">
              <%= vacationBalance.year %>: usados <span class="font-mono"><%= vacationBalance.used %></span>
              · disponibles <span class="font-mono <%= vacationBalance.available < 0 ? 'text-red-600' : 'text-emerald-700' %>"><%= vacationBalance.available %></span>
              <% if (vacationBalance.entitled !== null) { %>de <%= vacationBalance.entitled %><% } %>
            </p>
          <% } %>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-700 mb-1">Zona horaria <span class="text-slate-400 font-normal">(IANA)</span></label>
          <select name="timezone" class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
            <% const TZS = ['','America/Bogota','America/Caracas','America/Mexico_City','America/Argentina/Buenos_Aires','America/Lima','America/Santiago','America/Sao_Paulo','America/New_York','America/Los_Angeles','Europe/Madrid','UTC']; %>
            <% TZS.forEach(tz => { %>
              <option value="<%= tz %>" <%= (agent.timezone || '') === tz ? 'selected' : '' %>><%= tz || '— Default del sistema —' %></option>
            <% }) %>
          </select>
          <p class="text-[10px] text-slate-400 mt-1">Si vacio usa el default del sistema.</p>
        </div>
      </div>
    </section>

    <!-- ── Tab: Sensibles (admin only) ── -->
    <% if (isAdmin) { %>
      <section data-tabpanel="sensibles" class="bg-rose-50/40 rounded-xl border border-rose-200 shadow-card p-5 hidden">
        <div class="flex items-center gap-2 mb-1">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" class="text-rose-700"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          <h3 class="font-semibold text-rose-900 text-sm">Datos sensibles</h3>
        </div>
        <p class="text-xs text-rose-700/70 mb-4">Solo visibles para admin. No se renderizan para managers.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Cedula</label>
            <input type="text" name="id_number" value="<%= agent.id_number || '' %>"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Salario actual</label>
            <input type="number" step="0.01" name="salary_current" value="<%= agent.salary_current ?? '' %>"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm font-mono">
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Salario anterior</label>
            <input type="number" step="0.01" name="salary_previous" value="<%= agent.salary_previous ?? '' %>"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm font-mono">
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Salario nuevo</label>
            <input type="number" step="0.01" name="salary_new" value="<%= agent.salary_new ?? '' %>"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm font-mono">
            <p class="text-[10px] text-slate-400 mt-1">Tras un aumento, antes de aplicar.</p>
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">% Ult. ajuste</label>
            <input type="number" step="0.01" name="last_adjustment_pct" value="<%= agent.last_adjustment_pct ?? '' %>"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm font-mono">
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Fecha ult. ajuste salario</label>
            <input type="date" name="last_salary_adjustment_date" value="<%= agent.last_salary_adjustment_date || '' %>"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm">
          </div>
          <div>
            <label class="block text-xs font-medium text-slate-700 mb-1">Monto dia festivo</label>
            <input type="number" step="0.01" name="holiday_day_amount" value="<%= agent.holiday_day_amount ?? '' %>"
                   class="block w-full border border-slate-300 rounded-lg px-3 py-2 text-sm font-mono">
          </div>
        </div>
      </section>
    <% } %>

    <!-- Sticky footer con submit -->
    <div class="sticky bottom-0 mt-5 -mx-4 sm:-mx-6 px-4 sm:px-6 py-3 bg-slate-50/95 backdrop-blur-sm border-t border-slate-200 flex justify-end gap-2">
      <a href="/agentes" class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-100 rounded-lg font-medium">Cancelar</a>
      <button type="submit" class="btn-primary px-5 py-2 rounded-lg text-sm font-semibold">
        <%= mode === 'create' ? 'Crear agente' : 'Guardar cambios' %>
      </button>
    </div>
  </form>
</main>

<script>
(function() {
  const KEY = 'agente.tab';
  const nav = document.getElementById('tabsNav');
  if (!nav) return;
  const buttons = nav.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('[data-tabpanel]');
  const validTabs = Array.from(buttons).map(b => b.dataset.tab);

  function setTab(tab) {
    if (!validTabs.includes(tab)) tab = validTabs[0];
    buttons.forEach(b => {
      const sel = b.dataset.tab === tab;
      b.classList.toggle('bg-ink-800', sel);
      b.classList.toggle('text-white', sel);
      b.classList.toggle('text-slate-600', !sel);
      b.classList.toggle('hover:bg-slate-50', !sel);
    });
    panels.forEach(p => {
      p.classList.toggle('hidden', p.dataset.tabpanel !== tab);
    });
    try { localStorage.setItem(KEY, tab); } catch(e) {}
  }

  buttons.forEach(b => b.addEventListener('click', () => setTab(b.dataset.tab)));

  // Restore last tab, fallback to first
  let saved = null; try { saved = localStorage.getItem(KEY); } catch(e) {}
  setTab(saved || validTabs[0]);

  // If a field has invalid validation on submit, jump to its tab
  const form = document.getElementById('agentForm');
  if (form) {
    form.addEventListener('invalid', (ev) => {
      const target = ev.target;
      const panel = target.closest('[data-tabpanel]');
      if (panel) setTab(panel.dataset.tabpanel);
    }, true);
  }
})();
</script>
<%- include('partials/foot') %>
