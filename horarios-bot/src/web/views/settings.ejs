<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<%
  const groupTitles = {
    attendance: 'Asistencia y breaks',
    cycle: 'Ciclo de turnos',
    slack: 'Slack',
    rrhh: 'RRHH',
    misc: 'Misc'
  };
%>

<main class="max-w-3xl mx-auto px-4 py-6">
  <h2 class="text-xl font-semibold text-slate-900 mb-1">Configuracion</h2>
  <p class="text-xs text-slate-500 mb-6">Solo admin. Los cambios se aplican en caliente (sin reiniciar) a cron jobs y rutas.</p>

  <% if (flash) { %>
    <div class="mb-4 px-4 py-2 rounded-lg text-sm <%= flash.type === 'ok' ? 'bg-emerald-50 border border-emerald-200 text-emerald-800' : 'bg-red-50 border border-red-200 text-red-700' %>">
      <%= flash.text %>
    </div>
  <% } %>

  <form method="post" action="/settings" class="space-y-6">
    <% Object.keys(groupTitles).forEach(g => { %>
      <% const items = rows.filter(r => r.group === g); %>
      <% if (items.length === 0) return; %>
      <section class="bg-white rounded-lg border border-slate-200 shadow-card overflow-hidden">
        <header class="px-4 py-3 bg-slate-50 border-b border-slate-200">
          <h3 class="font-semibold text-slate-900"><%= groupTitles[g] %></h3>
        </header>
        <div class="divide-y divide-slate-100">
          <% items.forEach(r => { %>
            <div class="px-4 py-3 flex items-start gap-4">
              <div class="flex-1">
                <label for="f_<%= r.key %>" class="block text-sm font-medium text-gray-800"><%= r.label %></label>
                <% if (r.hint) { %><p class="text-xs text-slate-400 mt-0.5"><%= r.hint %></p><% } %>
                <p class="text-[10px] text-slate-300 mt-0.5 font-mono"><%= r.key %></p>
              </div>
              <div class="w-48 shrink-0">
                <input id="f_<%= r.key %>" name="<%= r.key %>" type="<%= r.type === 'int' ? 'number' : 'text' %>"
                       <%= r.min !== undefined ? `min="${r.min}"` : '' %>
                       <%= r.max !== undefined ? `max="${r.max}"` : '' %>
                       value="<%= r.value %>"
                       class="block w-full border border-slate-300 rounded-lg px-3 py-1.5 text-sm">
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    <% }) %>

    <div class="flex justify-end gap-2">
      <a href="/" class="px-4 py-2 text-sm text-slate-600 hover:bg-slate-50 rounded-lg">Cancelar</a>
      <button type="submit" class="bg-ink-800 text-white px-4 py-2 rounded-lg text-sm hover:bg-ink-700">Guardar</button>
    </div>
  </form>
</main>
<%- include('partials/foot') %>
