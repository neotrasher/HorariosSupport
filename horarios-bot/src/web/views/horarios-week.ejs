<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<%
  // Tailwind palette for agent chips. 12 colors so we have variety.
  const CHIP_COLORS = [
    'bg-emerald-100 text-emerald-800 ring-emerald-300',
    'bg-blue-100 text-blue-800 ring-blue-300',
    'bg-rose-100 text-rose-800 ring-rose-300',
    'bg-amber-100 text-amber-800 ring-amber-300',
    'bg-purple-100 text-purple-800 ring-purple-300',
    'bg-cyan-100 text-cyan-800 ring-cyan-300',
    'bg-pink-100 text-pink-800 ring-pink-300',
    'bg-lime-100 text-lime-800 ring-lime-300',
    'bg-orange-100 text-orange-800 ring-orange-300',
    'bg-teal-100 text-teal-800 ring-teal-300',
    'bg-violet-100 text-violet-800 ring-violet-300',
    'bg-fuchsia-100 text-fuchsia-800 ring-fuchsia-300'
  ];
%>

<main class="max-w-[1700px] mx-auto px-4 sm:px-6 py-6">
  <div class="mb-5">
    <div class="flex items-end justify-between gap-3 mb-3 flex-wrap">
      <div class="min-w-0">
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Horarios</h2>
        <p class="text-sm text-slate-500 mt-1">Vista semanal · grilla 7 dias</p>
      </div>
      <%- include('partials/viewSwitch', { view, currentDate }) %>
    </div>
    <div class="flex items-center gap-1.5 sm:gap-2 text-sm">
      <a href="/horarios?view=week&date=<%= prev %>" class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card shrink-0">&larr;</a>
      <label class="relative flex-1 min-w-0 px-2 sm:px-3 py-1.5 font-medium bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card cursor-pointer inline-flex items-center justify-center gap-1.5 sm:gap-2"
             onclick="const i=this.querySelector('input');if(i.showPicker)i.showPicker();else i.focus();">
        <span class="pointer-events-none truncate"><%= weekLabel %></span>
        <span class="text-slate-400 font-normal text-xs pointer-events-none whitespace-nowrap hidden sm:inline">Sem <%= cycle %></span>
        <span class="text-slate-400 font-normal text-[10px] pointer-events-none whitespace-nowrap sm:hidden"><%= cycle %></span>
        <span class="text-slate-300 text-xs pointer-events-none">📅</span>
        <input type="date" value="<%= currentDate %>"
               onchange="if(this.value) location.href='/horarios?view=week&date='+this.value"
               onclick="event.stopPropagation()"
               class="absolute right-2 top-1/2 -translate-y-1/2 w-1 h-1 opacity-0 pointer-events-none">
      </label>
      <a href="/horarios?view=week&date=<%= next %>" class="px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card shrink-0">&rarr;</a>
      <a href="/horarios?view=week&date=<%= today %>" class="px-2.5 sm:px-3 py-1.5 bg-white border border-slate-200 rounded-lg hover:bg-slate-50 shadow-card text-slate-600 shrink-0 text-xs sm:text-sm">Hoy</a>
      <% if (isManager) { %>
        <button id="editToggle" type="button"
                class="px-2.5 sm:px-3 py-1.5 border rounded-lg text-xs sm:text-sm border-slate-200 bg-white hover:bg-slate-50 shadow-card shrink-0">
          ✏️ Editar
        </button>
      <% } %>
    </div>
  </div>

  <% if (isManager) { %>
    <div id="editBanner" class="hidden mb-4 px-4 py-2 bg-amber-50 border border-amber-200 rounded-lg text-sm text-amber-800">
      <span class="font-medium">Modo edición activo</span> · click <span class="font-mono">×</span> en un chip para quitarlo · click <span class="font-mono">+</span> en una celda para agregar agente.
    </div>
  <% } %>

  <!-- TZ toggle -->
  <div class="flex items-center gap-2 mb-4">
    <span class="text-xs text-slate-500 font-medium">Mostrar horas en:</span>
    <div class="inline-flex rounded-lg border border-slate-200 bg-white text-xs overflow-hidden shadow-card" id="tzToggle">
      <button type="button" data-tz="utc" class="tz-btn px-3 py-1.5 font-semibold bg-ink-800 text-white">UTC</button>
      <button type="button" data-tz="local" class="tz-btn px-3 py-1.5 font-semibold border-l border-slate-200 text-slate-600 hover:bg-slate-50"><%= localTz %></button>
    </div>
  </div>

  <!-- ───────────────── Mobile: stacked by day ───────────────── -->
  <div class="md:hidden space-y-4">
    <% days.forEach((d, dayIdx) => { %>
      <% const dayHasShifts = blocks.some(b => b.rows.some(r => r.cells[dayIdx].agents.length > 0)); %>
      <% const dayHasOff = offRow && offRow[dayIdx] && offRow[dayIdx].agents.length > 0; %>
      <section class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden <%= d.isToday ? 'ring-2 ring-yellow-400' : '' %>">
        <header class="px-4 py-3 bg-slate-50/60 border-b border-slate-200 flex items-baseline gap-2">
          <span class="text-2xl font-extrabold text-slate-900"><%= d.dayCode %></span>
          <span class="text-sm font-semibold text-slate-600 capitalize"><%= d.dayName %> <%= d.dayNum %></span>
          <% if (d.isToday) { %><span class="ml-auto text-[10px] uppercase font-bold text-yellow-700 bg-yellow-100 px-2 py-0.5 rounded">Hoy</span><% } %>
        </header>
        <div class="divide-y divide-slate-100">
          <% if (!dayHasShifts && !dayHasOff) { %>
            <div class="px-4 py-3 text-xs text-slate-300 italic">Sin turnos asignados</div>
          <% } %>
          <% blocks.forEach(block => { %>
            <% block.rows.forEach(row => { %>
              <% const cell = row.cells[dayIdx]; %>
              <% if (cell.agents.length > 0 || isManager) { %>
                <div class="px-4 py-3 flex items-start gap-3 <%= cell.agents.length === 0 ? 'edit-only hidden' : '' %>">
                  <div class="w-16 shrink-0">
                    <div class="flex items-center gap-1">
                      <span class="text-[10px] font-bold uppercase tracking-wide
                        <%= block.dept === 'L1' ? 'text-blue-700' : 'text-violet-700' %>"><%= block.dept %></span>
                      <span class="text-base font-bold text-slate-900"><%= row.id %></span>
                    </div>
                    <div class="text-[10px] text-slate-500 font-mono"
                         data-utc="<%= row.startUtcStr %>–<%= row.endUtcStr %>"
                         data-local="<%= row.startLocalStr %>–<%= row.endLocalStr %>"><%= row.startUtcStr %>–<%= row.endUtcStr %></div>
                  </div>
                  <div class="flex-1 flex flex-wrap gap-1.5 min-w-0 items-center">
                    <% cell.agents.forEach(a => { %>
                      <% const cls = CHIP_COLORS[a.colorIdx]; %>
                      <% const tip = a.name + (a.custom ? ' · custom' : '') + (!a.native ? ' · presta de ' + a.nativeDept : '') + (a.swapped ? ' · cambio' : ''); %>
                      <span class="relative inline-flex items-center" data-chip data-pid="<%= a.plannerId %>" data-shift="<%= block.dept %>:<%= row.id %>" data-date="<%= d.date %>">
                        <% if (isManager) { %>
                          <a href="/horarios/agente/<%= a.plannerId %>"
                             class="chip-link pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= cls %> <%= a.swapped ? 'ring-2 ring-amber-400' : '' %>"
                             title="<%= tip %>">
                            <% if (!a.native) { %><span class="px-1 rounded bg-white/60 text-[9px] font-bold"><%= a.nativeDept %></span><% } %>
                            <%= a.name.split(' ')[0] %><% if (a.custom) { %><span class="opacity-60">*</span><% } %>
                            <% if (a.swapped) { %><span class="text-[11px]" title="Cambio de turno aprobado">🔁</span><% } %><% if (a.pendingTimeoff) { %><span class="text-[11px]" title="Tiene <%= a.pendingTimeoff %> pendiente de aprobar">⏳</span><% } %><% if (a.pendingSwap) { %><span class="text-[11px]" title="Tiene un cambio de turno pendiente (<%= a.pendingSwap === 'requester' ? 'pidió' : 'le pidieron' %>)">↔️</span><% } %>
                          </a>
                        <% } else { %>
                          <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= cls %> <%= a.swapped ? 'ring-2 ring-amber-400' : '' %>"
                                title="<%= tip %>">
                            <% if (!a.native) { %><span class="px-1 rounded bg-white/60 text-[9px] font-bold"><%= a.nativeDept %></span><% } %>
                            <%= a.name.split(' ')[0] %><% if (a.custom) { %><span class="opacity-60">*</span><% } %>
                            <% if (a.swapped) { %><span class="text-[11px]" title="Cambio de turno aprobado">🔁</span><% } %><% if (a.pendingTimeoff) { %><span class="text-[11px]" title="Tiene <%= a.pendingTimeoff %> pendiente de aprobar">⏳</span><% } %><% if (a.pendingSwap) { %><span class="text-[11px]" title="Tiene un cambio de turno pendiente (<%= a.pendingSwap === 'requester' ? 'pidió' : 'le pidieron' %>)">↔️</span><% } %>
                          </span>
                        <% } %>
                        <% if (isManager) { %>
                          <button type="button"
                                  class="edit-only hidden absolute -top-1.5 -right-1.5 w-4 h-4 rounded-full bg-red-500 text-white text-[10px] leading-none font-bold shadow hover:bg-red-600"
                                  data-action="remove" data-name="<%= a.name %>" data-shift-id="<%= row.id %>" data-dept="<%= block.dept %>" data-pid="<%= a.plannerId %>" data-date="<%= d.date %>"
                                  title="Quitar de este turno">×</button>
                        <% } %>
                      </span>
                    <% }) %>
                    <% if (isManager) { %>
                      <button type="button"
                              class="edit-only hidden inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-medium border border-dashed border-slate-300 text-slate-500 hover:bg-slate-50 hover:border-slate-400"
                              data-action="add" data-shift-id="<%= row.id %>" data-dept="<%= block.dept %>" data-date="<%= d.date %>">
                        + Agregar
                      </button>
                    <% } %>
                  </div>
                </div>
              <% } %>
            <% }) %>
          <% }) %>
          <% if (dayHasOff) { %>
            <div class="px-4 py-3 flex items-start gap-3 bg-cyan-50/30">
              <div class="w-16 shrink-0">
                <span class="inline-block px-2 py-0.5 rounded text-[10px] font-bold bg-cyan-600 text-white">OFF</span>
              </div>
              <div class="flex-1 flex flex-wrap gap-1.5 min-w-0">
                <% offRow[dayIdx].agents.forEach(o => { %>
                  <% const cls = o.isVac ? 'bg-cyan-50 text-cyan-800 ring-cyan-300' : 'bg-amber-50 text-amber-800 ring-amber-300'; %>
                  <% const ico = o.isVac ? '🏖️' : '📝'; %>
                  <% if (isManager) { %>
                    <a href="/horarios/agente/<%= o.plannerId %>"
                       class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= cls %>"
                       title="<%= o.name %> · <%= o.reason || 'time off' %>">
                      <span class="text-[9px]"><%= ico %></span>
                      <span class="line-through opacity-80"><%= o.name.split(' ')[0] %></span>
                    </a>
                  <% } else { %>
                    <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= cls %>">
                      <span class="text-[9px]"><%= ico %></span>
                      <span class="line-through opacity-80"><%= o.name.split(' ')[0] %></span>
                    </span>
                  <% } %>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>
      </section>
    <% }) %>
  </div>

  <!-- ───────────────── Desktop: full week grid ───────────────── -->
  <div class="hidden md:block">
  <% blocks.forEach(block => { %>
    <section class="bg-white rounded-xl border border-slate-200 shadow-card overflow-hidden mb-5">
      <header class="flex items-center gap-3 px-5 py-3 bg-slate-50/60 border-b border-slate-200">
        <span class="inline-block px-2.5 py-0.5 rounded text-xs font-bold tracking-wide shadow-card
          <%= block.dept === 'L1' ? 'bg-blue-600 text-white' : 'bg-violet-600 text-white' %>">
          <%= block.dept %>
        </span>
        <h3 class="font-semibold text-slate-900 text-sm">Horario <%= block.dept %></h3>
      </header>

      <div class="overflow-x-auto">
        <table class="w-full text-xs table-fixed min-w-[760px]">
          <colgroup>
            <col style="width: 5.5rem">
            <% days.forEach(() => { %><col style="width: calc((100% - 5.5rem) / 7)"><% }) %>
          </colgroup>
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200 sticky top-0 z-[1]">
              <th class="px-3 py-2"></th>
              <% days.forEach(d => { %>
                <th class="px-2 py-2 text-center font-medium <%= d.isToday ? 'bg-yellow-50' : '' %>">
                  <div class="text-slate-900 font-bold capitalize"><%= d.dayCode %></div>
                  <div class="text-[10px] text-slate-400 capitalize"><%= d.dayName %> <%= d.dayNum %></div>
                </th>
              <% }) %>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% block.rows.forEach(row => { %>
              <tr>
                <th class="px-3 py-2 text-left bg-slate-50/40 align-top">
                  <div class="font-bold text-slate-900 text-sm"><%= row.id %></div>
                  <div class="text-[10px] text-slate-500 font-mono"
                       data-utc="<%= row.startUtcStr %>–<%= row.endUtcStr %>"
                       data-local="<%= row.startLocalStr %>–<%= row.endLocalStr %>"><%= row.startUtcStr %>–<%= row.endUtcStr %></div>
                  <div class="text-[10px] text-slate-400"><%= row.label %></div>
                </th>
                <% row.cells.forEach(cell => { %>
                  <td class="px-1.5 py-1.5 align-top <%= cell.isToday ? 'bg-yellow-50/40' : '' %>">
                    <div class="flex flex-wrap gap-1 items-center">
                      <% cell.agents.forEach(a => { %>
                        <% const cls = CHIP_COLORS[a.colorIdx]; %>
                        <% const tip = a.name + (a.custom ? ' · custom hours' : '') + (!a.native ? ' · presta de ' + a.nativeDept : '') + (a.swapped ? ' · cambio aprobado' : ''); %>
                        <span class="relative inline-flex items-center" data-chip data-pid="<%= a.plannerId %>" data-shift="<%= block.dept %>:<%= row.id %>" data-date="<%= cell.date %>">
                          <% if (isManager) { %>
                            <a href="/horarios/agente/<%= a.plannerId %>"
                               class="chip-link pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 hover:ring-2 <%= cls %> <%= a.swapped ? 'ring-2 ring-amber-400' : '' %>"
                               title="<%= tip %>">
                              <% if (!a.native) { %><span class="px-1 rounded bg-white/60 text-[9px] font-bold"><%= a.nativeDept %></span><% } %>
                              <%= a.name.split(' ')[0] %><% if (a.custom) { %><span class="opacity-60">*</span><% } %>
                              <% if (a.swapped) { %><span class="text-[11px]" title="Cambio de turno aprobado">🔁</span><% } %><% if (a.pendingTimeoff) { %><span class="text-[11px]" title="Tiene <%= a.pendingTimeoff %> pendiente de aprobar">⏳</span><% } %><% if (a.pendingSwap) { %><span class="text-[11px]" title="Tiene un cambio de turno pendiente (<%= a.pendingSwap === 'requester' ? 'pidió' : 'le pidieron' %>)">↔️</span><% } %>
                            </a>
                          <% } else { %>
                            <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= cls %> <%= a.swapped ? 'ring-2 ring-amber-400' : '' %>"
                                  title="<%= tip %>">
                              <% if (!a.native) { %><span class="px-1 rounded bg-white/60 text-[9px] font-bold"><%= a.nativeDept %></span><% } %>
                              <%= a.name.split(' ')[0] %><% if (a.custom) { %><span class="opacity-60">*</span><% } %>
                              <% if (a.swapped) { %><span class="text-[11px]" title="Cambio de turno aprobado">🔁</span><% } %><% if (a.pendingTimeoff) { %><span class="text-[11px]" title="Tiene <%= a.pendingTimeoff %> pendiente de aprobar">⏳</span><% } %><% if (a.pendingSwap) { %><span class="text-[11px]" title="Tiene un cambio de turno pendiente (<%= a.pendingSwap === 'requester' ? 'pidió' : 'le pidieron' %>)">↔️</span><% } %>
                            </span>
                          <% } %>
                          <% if (isManager) { %>
                            <button type="button"
                                    class="edit-only hidden absolute -top-1.5 -right-1.5 w-4 h-4 rounded-full bg-red-500 text-white text-[10px] leading-none font-bold shadow hover:bg-red-600"
                                    data-action="remove" data-name="<%= a.name %>" data-shift-id="<%= row.id %>" data-dept="<%= block.dept %>" data-pid="<%= a.plannerId %>" data-date="<%= cell.date %>"
                                    title="Quitar de este turno">×</button>
                          <% } %>
                        </span>
                      <% }) %>
                      <% if (isManager) { %>
                        <button type="button"
                                class="edit-only hidden inline-flex items-center gap-0.5 px-1.5 py-0.5 rounded-full text-[10px] font-medium border border-dashed border-slate-300 text-slate-500 hover:bg-slate-50 hover:border-slate-400"
                                data-action="add" data-shift-id="<%= row.id %>" data-dept="<%= block.dept %>" data-date="<%= cell.date %>"
                                title="Agregar agente">+</button>
                      <% } %>
                    </div>
                  </td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  <% }) %>

  <% const hasOff = offRow && offRow.some(c => c.agents.length > 0); %>
  <% if (hasOff) { %>
    <section class="bg-white rounded-lg border border-slate-200 shadow-card overflow-hidden mb-6">
      <header class="flex items-center gap-3 px-4 py-3 bg-slate-50 border-b border-slate-200">
        <span class="inline-block px-2 py-0.5 rounded text-xs font-bold bg-cyan-600 text-white">OFF</span>
        <h3 class="font-semibold text-slate-900">Tiempo libre</h3>
      </header>
      <div class="overflow-x-auto">
        <table class="w-full text-xs table-fixed min-w-[760px]">
          <colgroup>
            <col style="width: 5.5rem">
            <% offRow.forEach(() => { %><col style="width: calc((100% - 5.5rem) / 7)"><% }) %>
          </colgroup>
          <tbody>
            <tr>
              <th class="px-3 py-2 text-left bg-slate-50/40 align-top text-[10px] text-slate-500 uppercase">Off</th>
              <% offRow.forEach(c => { %>
                <td class="px-1.5 py-1.5 align-top <%= c.isToday ? 'bg-yellow-50/40' : '' %>">
                  <div class="flex flex-wrap gap-1">
                    <% c.agents.forEach(o => { %>
                      <% const cls = o.isVac ? 'bg-cyan-50 text-cyan-800 ring-cyan-300' : 'bg-amber-50 text-amber-800 ring-amber-300'; %>
                      <% const ico = o.isVac ? '🏖️' : '📝'; %>
                      <% if (isManager) { %>
                        <a href="/horarios/agente/<%= o.plannerId %>"
                           class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 hover:ring-2 <%= cls %>"
                           title="<%= o.name %> · <%= o.reason || 'time off' %>">
                          <span class="text-[9px]"><%= ico %></span>
                          <span class="line-through opacity-80"><%= o.name.split(' ')[0] %></span>
                        </a>
                      <% } else { %>
                        <span class="pill inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold ring-1 <%= cls %>"
                              title="<%= o.name %> · <%= o.reason || 'time off' %>">
                          <span class="text-[9px]"><%= ico %></span>
                          <span class="line-through opacity-80"><%= o.name.split(' ')[0] %></span>
                        </span>
                      <% } %>
                    <% }) %>
                  </div>
                </td>
              <% }) %>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>

  </div><!-- /.hidden md:block (desktop grid) -->

  <p class="text-xs text-slate-400 mt-3 hidden md:block">Cada agente tiene un color consistente. <span class="font-mono">*</span> = horas custom · <span>🔁</span> = cambio aprobado · <span>⏳</span> = solicitud de permiso/vacaciones pendiente · <span>↔️</span> = cambio de turno pendiente. Click en el chip (managers) abre el drill-down.</p>

<% if (isManager) { %>
  <%- include('partials/horariosEditModals', { dateStrForEdit: '', allAgents }) %>
<% } %>
</main>
<script>
(function() {
  const KEY = 'tzPref';
  const toggle = document.getElementById('tzToggle');
  if (!toggle) return;
  function apply(pref) {
    toggle.querySelectorAll('.tz-btn').forEach(b => {
      const sel = b.dataset.tz === pref;
      b.classList.toggle('bg-ink-800', sel);
      b.classList.toggle('text-white', sel);
      b.classList.toggle('text-slate-600', !sel);
      b.classList.toggle('hover:bg-slate-50', !sel);
    });
    document.querySelectorAll('[data-utc][data-local]').forEach(el => {
      el.textContent = pref === 'utc' ? el.dataset.utc : el.dataset.local;
    });
    try { localStorage.setItem(KEY, pref); } catch(e) {}
  }
  toggle.querySelectorAll('.tz-btn').forEach(b => {
    b.addEventListener('click', () => apply(b.dataset.tz));
  });
  let saved = null; try { saved = localStorage.getItem(KEY); } catch(e) {}
  apply(saved === 'local' ? 'local' : 'utc');
})();
</script>
<%- include('partials/foot') %>
