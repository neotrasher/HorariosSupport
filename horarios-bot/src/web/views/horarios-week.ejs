<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<main class="max-w-7xl mx-auto px-4 py-6">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex items-center gap-3">
      <h2 class="text-xl font-semibold text-gray-900">Horarios</h2>
      <%- include('partials/viewSwitch', { view }) %>
    </div>
    <div class="flex items-center gap-2 text-sm">
      <a href="/horarios?view=week&date=<%= prev %>" class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50">&larr;</a>
      <span class="px-3 py-1.5 font-medium"><%= weekLabel %> <span class="text-gray-400 font-normal">Sem <%= cycle %></span></span>
      <a href="/horarios?view=week&date=<%= next %>" class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50">&rarr;</a>
      <a href="/horarios?view=week&date=<%= today %>" class="ml-2 px-3 py-1.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600">Hoy</a>
    </div>
  </div>

  <% if (rows.length === 0) { %>
    <div class="bg-white rounded-lg border border-gray-200 p-8 text-center text-gray-400">
      Sin agentes
    </div>
  <% } else { %>
    <div class="bg-white rounded-lg border border-gray-200 overflow-x-auto">
      <table class="w-full text-xs">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-3 py-2 font-medium text-gray-600 sticky left-0 bg-gray-50">Agente</th>
            <% days.forEach(d => { %>
              <th class="text-center px-2 py-2 font-medium <%= d.isToday ? 'bg-yellow-50 text-yellow-800' : 'text-gray-600' %>">
                <%= d.dayName %>
              </th>
            <% }) %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% rows.forEach(r => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-3 py-2 sticky left-0 bg-white">
                <% if (isManager) { %>
                  <a href="/horarios/agente/<%= r.plannerId %>" class="font-medium text-gray-900 hover:underline"><%= r.name %></a>
                <% } else { %>
                  <span class="font-medium text-gray-900"><%= r.name %></span>
                <% } %>
                <span class="text-gray-400 ml-1"><%= r.dept %></span>
              </td>
              <% r.cells.forEach(c => { %>
                <td class="px-2 py-2 text-center">
                  <% if (c) { %>
                    <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold
                      <% if (c.dept === 'L1') { %>bg-blue-100 text-blue-700<% } else { %>bg-purple-100 text-purple-700<% } %>"
                      title="<%= c.dept %> <%= c.shiftId %> <%= c.label %> <%= c.startUtc %>–<%= c.endUtc %> UTC<%= c.custom ? ' (custom)' : '' %>">
                      <%= c.shiftId %><%= c.custom ? '*' : '' %>
                    </span>
                  <% } else { %>
                    <span class="text-gray-300">·</span>
                  <% } %>
                </td>
              <% }) %>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-400 mt-2">Pasa el cursor sobre un turno para ver el horario completo. <span class="font-mono">*</span> indica horas custom.</p>
  <% } %>
</main>
<%- include('partials/foot') %>
