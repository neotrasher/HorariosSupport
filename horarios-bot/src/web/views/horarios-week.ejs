<%- include('partials/head') %>
<%- include('partials/nav', { user }) %>

<%
  // Tailwind palette for agent chips. 12 colors so we have variety.
  const CHIP_COLORS = [
    'bg-emerald-100 text-emerald-800 ring-emerald-300',
    'bg-blue-100 text-blue-800 ring-blue-300',
    'bg-rose-100 text-rose-800 ring-rose-300',
    'bg-amber-100 text-amber-800 ring-amber-300',
    'bg-purple-100 text-purple-800 ring-purple-300',
    'bg-cyan-100 text-cyan-800 ring-cyan-300',
    'bg-pink-100 text-pink-800 ring-pink-300',
    'bg-lime-100 text-lime-800 ring-lime-300',
    'bg-orange-100 text-orange-800 ring-orange-300',
    'bg-teal-100 text-teal-800 ring-teal-300',
    'bg-violet-100 text-violet-800 ring-violet-300',
    'bg-fuchsia-100 text-fuchsia-800 ring-fuchsia-300'
  ];
%>

<main class="max-w-7xl mx-auto px-4 py-6">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
    <div class="flex items-center gap-3">
      <h2 class="text-xl font-semibold text-gray-900">Horarios</h2>
      <%- include('partials/viewSwitch', { view }) %>
    </div>
    <div class="flex items-center gap-2 text-sm">
      <a href="/horarios?view=week&date=<%= prev %>" class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50">&larr;</a>
      <span class="px-3 py-1.5 font-medium"><%= weekLabel %> <span class="text-gray-400 font-normal">Sem <%= cycle %></span></span>
      <a href="/horarios?view=week&date=<%= next %>" class="px-3 py-1.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50">&rarr;</a>
      <a href="/horarios?view=week&date=<%= today %>" class="ml-2 px-3 py-1.5 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 text-gray-600">Hoy</a>
    </div>
  </div>

  <% blocks.forEach(block => { %>
    <section class="bg-white rounded-lg border border-gray-200 overflow-hidden mb-6">
      <header class="flex items-center gap-3 px-4 py-3 bg-gray-50 border-b border-gray-200">
        <span class="inline-block px-2 py-0.5 rounded text-xs font-bold
          <%= block.dept === 'L1' ? 'bg-blue-600 text-white' : 'bg-purple-600 text-white' %>">
          <%= block.dept %>
        </span>
        <h3 class="font-semibold text-gray-900">Horario <%= block.dept %></h3>
      </header>

      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-3 py-2 w-24"></th>
              <% days.forEach(d => { %>
                <th class="px-2 py-2 text-center font-medium <%= d.isToday ? 'bg-yellow-50' : '' %>">
                  <div class="text-gray-900 font-bold capitalize"><%= d.dayCode %></div>
                  <div class="text-[10px] text-gray-400 capitalize"><%= d.dayName %> <%= d.dayNum %></div>
                </th>
              <% }) %>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% block.rows.forEach(row => { %>
              <tr>
                <th class="px-3 py-2 text-left bg-gray-50/40 align-top w-24">
                  <div class="font-bold text-gray-900 text-sm"><%= row.id %></div>
                  <div class="text-[10px] text-gray-500"><%= row.startHour.toString().padStart(2,'0') %>–<%= (row.endHour % 24).toString().padStart(2,'0') %></div>
                  <div class="text-[10px] text-gray-400"><%= row.label %></div>
                </th>
                <% row.cells.forEach(cell => { %>
                  <td class="px-1.5 py-1.5 align-top min-w-[100px] <%= cell.isToday ? 'bg-yellow-50/40' : '' %>">
                    <div class="flex flex-wrap gap-1">
                      <% cell.agents.forEach(a => { %>
                        <% const cls = CHIP_COLORS[a.colorIdx]; %>
                        <% const tip = a.name + (a.custom ? ' · custom hours' : '') + (!a.native ? ' · presta de ' + a.nativeDept : '') + (a.swapped ? ' · cambio aprobado' : ''); %>
                        <% if (isManager) { %>
                          <a href="/horarios/agente/<%= a.plannerId %>"
                             class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-medium ring-1 hover:ring-2 <%= cls %> <%= a.swapped ? 'ring-2 ring-amber-400' : '' %>"
                             title="<%= tip %>">
                            <% if (!a.native) { %><span class="px-1 rounded bg-white/60 text-[9px] font-bold"><%= a.nativeDept %></span><% } %>
                            <%= a.name %><% if (a.custom) { %><span class="opacity-60">*</span><% } %>
                            <% if (a.swapped) { %><span class="px-1 rounded bg-amber-200 text-amber-900 text-[9px] font-bold">↔</span><% } %>
                          </a>
                        <% } else { %>
                          <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-medium ring-1 <%= cls %> <%= a.swapped ? 'ring-2 ring-amber-400' : '' %>"
                                title="<%= tip %>">
                            <% if (!a.native) { %><span class="px-1 rounded bg-white/60 text-[9px] font-bold"><%= a.nativeDept %></span><% } %>
                            <%= a.name %><% if (a.custom) { %><span class="opacity-60">*</span><% } %>
                            <% if (a.swapped) { %><span class="px-1 rounded bg-amber-200 text-amber-900 text-[9px] font-bold">↔</span><% } %>
                          </span>
                        <% } %>
                      <% }) %>
                    </div>
                  </td>
                <% }) %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  <% }) %>

  <p class="text-xs text-gray-400">Cada agente tiene un color consistente. <span class="font-mono">*</span> = horas custom · <span class="px-1 rounded bg-amber-200 text-amber-900 text-[9px] font-bold">↔</span> = turno cambiado (cambio aprobado). Click en el chip (managers) abre el drill-down.</p>
</main>
<%- include('partials/foot') %>
